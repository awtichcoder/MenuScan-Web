@model MenuQr.Models.Sql.Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hóa Đơn Thanh Toán #@Model.Id</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #000000;
            padding: 20px;
            font-size: 11px;
            line-height: 1.4;
        }
        .receipt-container {
            max-width: 320px;
            margin: 0 auto;
            border: 1px dashed #d1d5db;
            padding: 16px;
            border-radius: 8px;
        }
        .header {
            text-align: center;
            margin-bottom: 16px;
        }
        .header h1 {
            font-size: 16px;
            font-weight: 800;
            margin: 0;
            letter-spacing: 1px;
        }
        .header p {
            margin: 3px 0 0 0;
            font-size: 9px;
            color: #4b5563;
        }
        .divider {
            border-top: 1px dashed #000000;
            margin: 12px 0;
        }
        .meta-grid {
            display: grid;
            grid-template-cols: 1fr 1fr;
            row-gap: 4px;
            margin-bottom: 12px;
            font-size: 9px;
        }
        .meta-grid div:nth-child(even) {
            text-align: right;
        }
        .item-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 12px;
        }
        .item-table th {
            text-align: left;
            border-bottom: 1px dashed #000000;
            padding-bottom: 4px;
            font-size: 9px;
            text-transform: uppercase;
        }
        .item-table td {
            padding: 6px 0;
            vertical-align: top;
        }
        .item-name {
            font-weight: 700;
        }
        .item-options {
            font-size: 8px;
            color: #4b5563;
            margin-top: 2px;
        }
        .totals-grid {
            display: grid;
            grid-template-cols: 1fr 120px;
            row-gap: 6px;
            font-size: 10px;
        }
        .totals-grid div:nth-child(even) {
            text-align: right;
            font-weight: 700;
        }
        .final-total {
            font-size: 13px;
            font-weight: 800;
            border-top: 1px dashed #000000;
            padding-top: 6px;
            margin-top: 4px;
        }
        .footer {
            text-align: center;
            margin-top: 20px;
            font-size: 9px;
            font-weight: 500;
        }
        
        /* Print layout optimizations */
        @@media print {
            body {
                padding: 0;
            }
            .receipt-container {
                border: none;
                max-width: 100%;
                padding: 0;
            }
        }
    </style>
</head>
<body>

    <!-- Receipt Container Box -->
    <div class="receipt-container">
        
        <!-- Header Info -->
        <div class="header">
            <h1>HAIDILAO</h1>
            <p>Hệ thống lẩu Hadilao chính hãng Việt Nam</p>
            <p>Hadilao Center, Q.1, TP. Hồ Chí Minh</p>
            <p>Hotline: 1900 6006</p>
        </div>

        <div class="divider"></div>

        <!-- Meta Details -->
        <div class="meta-grid">
            <div>Số hóa đơn:</div>
            <div>#@Model.Id</div>
            
            <div>Bàn số:</div>
            <div>Bàn @Model.TableNumber</div>

            <div>Ngày thanh toán:</div>
            <div>@Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>

            <div>Thu ngân:</div>
            <div>@(Model.Invoice?.CashierUsername ?? "cashier")</div>

            <div>Hình thức:</div>
            <div>@(Model.Invoice?.PaymentMethod == "Cash" ? "Tiền Mặt" : "Chuyển Khoản")</div>
        </div>

        <div class="divider"></div>

        <!-- Items Table Grid -->
        <table class="item-table">
            <thead>
                <tr>
                    <th style="width: 60%;">Tên món</th>
                    <th style="width: 15%; text-align: center;">SL</th>
                    <th style="width: 25%; text-align: right;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detail in Model.OrderDetails)
                {
                    <tr>
                        <td>
                            <div class="item-name">@detail.DishName</div>
                            <div class="item-options">
                                @detail.SelectedOptions
                                @if (!string.IsNullOrEmpty(detail.SelectedToppings))
                                {
                                    <span> | Món thêm: @detail.SelectedToppings</span>
                                }
                            </div>
                        </td>
                        <td style="text-align: center;">@detail.Quantity</td>
                        <td style="text-align: right;">@((detail.BasePrice * detail.Quantity).ToString("N0"))₫</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="divider"></div>

        <!-- Breakdowns Box -->
        <div class="totals-grid">
            <div>Tổng tạm tính:</div>
            <div>@Model.SubTotal.ToString("N0")₫</div>

            @if (Model.DiscountAmount > 0)
            {
                <div>Khuyến mãi giảm giá:</div>
                <div>-@Model.DiscountAmount.ToString("N0")₫</div>
            }

            <div class="final-total">Thành tiền phải trả:</div>
            <div class="final-total" style="color: #000;">@Model.TotalAmount.ToString("N0")₫</div>
        </div>

        <div class="divider"></div>

        <!-- Receipt Footer Message -->
        <div class="footer">
            <p>Cảm ơn quý khách đã dùng bữa tại Hadilao!</p>
            <p>Hẹn gặp lại quý khách lần sau.</p>
        </div>

    </div>

    <!-- Automatically open system Print Dialog -->
    <script>
        window.addEventListener('load', () => {
            window.print();
        });
    </script>
</body>
</html>
