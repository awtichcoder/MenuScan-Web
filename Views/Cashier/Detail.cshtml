@model ActiveOrder
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thanh Toán Bàn @Model.TableNumber - MenuScan</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
        }
    </style>
</head>
<body class="min-h-screen flex overflow-hidden">

    <!-- 1. Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col justify-between p-4 flex-shrink-0 border-r border-slate-800">
        <div class="space-y-8">
            <div class="flex items-center gap-3 px-2">
                <div class="w-9 h-9 rounded-xl bg-[#FF6B35] flex items-center justify-center font-black text-white text-base shadow-lg shadow-orange-500/20">MS</div>
                <div>
                    <h2 class="text-sm font-black tracking-wider">HADILAO</h2>
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Thu Ngân Panel</span>
                </div>
            </div>

            <nav class="space-y-1.5">
                <a href="/Cashier" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold bg-[#FF6B35] text-white">
                    <i data-lucide="layout-grid" class="w-4.5 h-4.5"></i>
                    <span>Sơ Đồ Bàn Ăn</span>
                </a>
            </nav>
        </div>

        <div class="space-y-4 border-t border-slate-800 pt-4">
            <form asp-controller="Account" asp-action="Logout" method="POST">
                <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold text-slate-400 hover:text-rose-400 hover:bg-rose-950/20 transition-all">
                    <i data-lucide="log-out" class="w-4.5 h-4.5"></i>
                    <span>Đăng Xuất</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Right Content Panel -->
    <div class="flex-grow flex flex-col overflow-hidden">
        
        <!-- Header -->
        <header class="h-16 bg-white border-b border-slate-200 px-6 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-3">
                <a href="/Cashier" class="p-1.5 hover:bg-slate-100 rounded-full transition-colors">
                    <i data-lucide="arrow-left" class="w-5 h-5 text-slate-500"></i>
                </a>
                <div>
                    <h1 class="text-lg font-extrabold text-slate-800">Thanh Toán Bàn @Model.TableNumber</h1>
                    <p class="text-[10px] text-slate-400 font-medium">Chi tiết hóa đơn và kết toán phiên ăn uống</p>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                @if (Model.CallStaffRequest)
                {
                    <span class="px-3 py-1 bg-rose-50 text-rose-600 text-xs font-bold rounded-lg border border-rose-100 flex items-center gap-1.5 animate-pulse">
                        <i data-lucide="bell" class="w-3.5 h-3.5"></i>
                        <span>Đang gọi tính tiền</span>
                    </span>
                }
            </div>
        </header>

        <!-- Main Split Console Area -->
        <main class="flex-grow overflow-y-auto p-6 grid grid-cols-1 xl:grid-cols-12 gap-6">

            <!-- Left: Order Details List -->
            <section class="xl:col-span-8 bg-white rounded-3xl border border-slate-200 shadow-sm p-6 space-y-4 flex flex-col justify-between">
                <div class="space-y-4">
                    <div class="flex justify-between items-center border-b border-slate-100 pb-3">
                        <h3 class="text-sm font-extrabold text-slate-700 uppercase tracking-wider">Danh Sách Món Ăn</h3>
                        <span class="text-xs text-slate-400 font-bold">@Model.Items.Count món ăn</span>
                    </div>

                    <!-- Items rows -->
                    <div class="divide-y divide-slate-100 overflow-y-auto max-h-[50vh]">
                        @foreach (var item in Model.Items)
                        {
                            <div class="py-3.5 flex justify-between gap-4">
                                <div class="min-w-0 flex-grow">
                                    <h4 class="text-sm font-bold text-slate-800">@item.Quantity × @item.DishName</h4>
                                    <div class="text-[10px] text-slate-400 font-bold mt-1 space-y-0.5">
                                        <div>Kích cỡ: @item.SelectedSize</div>
                                        @if (item.SelectedToppings != null && item.SelectedToppings.Any())
                                        {
                                            <div>Món thêm: @string.Join(", ", item.SelectedToppings)</div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.CustomerNote))
                                        {
                                            <div class="italic text-rose-500 bg-rose-50 px-1.5 py-0.5 rounded mt-1 font-bold inline-block">
                                                Ghi chú: @item.CustomerNote
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                <div class="text-right">
                                    <span class="text-sm font-bold text-slate-700 block">@((item.Price * item.Quantity).ToString("N0"))₫</span>
                                    <span class="text-[10px] text-slate-400 font-medium block mt-0.5">Đơn giá: @item.Price.ToString("N0")₫</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Footer Summary Breakdown -->
                <div class="border-t border-slate-100 pt-4 space-y-2">
                    <div class="flex justify-between text-xs text-slate-500 font-medium">
                        <span>Tổng tạm tính</span>
                        <span>@Model.SubTotal.ToString("N0")₫</span>
                    </div>
                    @if (Model.DiscountAmount > 0)
                    {
                        <div class="flex justify-between text-xs text-emerald-600 font-medium">
                            <span>Khuyến mãi áp dụng (@Model.VoucherCode)</span>
                            <span>-@Model.DiscountAmount.ToString("N0")₫</span>
                        </div>
                    }
                    <div class="flex justify-between items-center text-sm font-black text-slate-800 border-t border-slate-100 pt-2.5">
                        <span>Thành Tiền Phải Trả</span>
                        <span class="text-xl text-[#FF6B35]">@Model.TotalAmount.ToString("N0")₫</span>
                    </div>
                </div>
            </section>

            <!-- Right: Settle payment form -->
            <section class="xl:col-span-4 bg-white rounded-3xl border border-slate-200 shadow-sm p-6 space-y-6 flex flex-col justify-between">
                <div class="space-y-4">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider border-b border-slate-100 pb-3">Kết Toán & Settle</h3>
                    
                    <form id="settlePaymentForm" class="space-y-4">
                        <input type="hidden" name="tableNumber" value="@Model.TableNumber" />

                        <!-- Settle Payment Method -->
                        <div class="space-y-2">
                            <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Hình thức thanh toán</label>
                            
                            <div class="flex flex-col gap-2">
                                <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:border-[#FF6B35]/50 transition-all select-none pay-label">
                                    <input type="radio" name="paymentMethod" value="Cash" checked class="w-4 h-4 text-[#FF6B35] focus:ring-[#FF6B35] border-slate-300 pay-radio" />
                                    <i data-lucide="banknote" class="w-5 h-5 text-emerald-500"></i>
                                    <span class="text-xs font-bold text-slate-700">Tiền Mặt (Cash)</span>
                                </label>

                                <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:border-[#FF6B35]/50 transition-all select-none pay-label">
                                    <input type="radio" name="paymentMethod" value="BankTransfer" class="w-4 h-4 text-[#FF6B35] focus:ring-[#FF6B35] border-slate-300 pay-radio" />
                                    <i data-lucide="qr-code" class="w-5 h-5 text-blue-500"></i>
                                    <span class="text-xs font-bold text-slate-700">Chuyển Khoản Ngân Hàng</span>
                                </label>
                            </div>
                        </div>

                    </form>
                </div>

                <!-- Action Button -->
                <div class="space-y-3">
                    <button type="button" onclick="confirmPayment()" 
                            class="w-full py-4 bg-emerald-500 hover:bg-emerald-600 text-white font-bold rounded-xl shadow-lg shadow-emerald-500/20 active:scale-95 transition-all text-center text-xs cursor-pointer flex justify-center items-center gap-1.5">
                        <i data-lucide="check-circle" class="w-4.5 h-4.5"></i>
                        <span>Thành Toán & In Hóa Đơn</span>
                    </button>
                    
                    <a href="/Cashier" class="w-full py-3 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold rounded-xl transition-all text-center block text-xs border border-slate-200">
                        Quay Lại Sơ Đồ Bàn
                    </a>
                </div>
            </section>

        </main>
    </div>

    <!-- Scripting for Payment Settlement -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        lucide.createIcons();

        // Highlight payment methods labels
        function highlightPayLabels() {
            document.querySelectorAll('.pay-label').forEach(label => {
                const radio = label.querySelector('input');
                if (radio.checked) {
                    label.classList.add('border-[#FF6B35]', 'bg-orange-50/20');
                } else {
                    label.classList.remove('border-[#FF6B35]', 'bg-orange-50/20');
                }
            });
        }
        document.querySelectorAll('.pay-radio').forEach(r => r.addEventListener('change', highlightPayLabels));
        highlightPayLabels();

        // Confirm Settle Payment
        async function confirmPayment() {
            const tableNumber = '@Model.TableNumber';
            const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;

            Swal.fire({
                title: 'Xác nhận thanh toán?',
                text: `Sẽ kết toán hóa đơn Bàn ${tableNumber} và in hóa đơn trực quan.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#2ECC71',
                cancelButtonColor: '#64748B',
                confirmButtonText: 'Đồng Ý',
                cancelButtonText: 'Hủy'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const formData = new FormData();
                        formData.append('tableNumber', tableNumber);
                        formData.append('paymentMethod', paymentMethod);

                        const response = await fetch('/Cashier/SettlePayment', {
                            method: 'POST',
                            body: formData
                        });
                        const res = await response.json();

                        if (res.success) {
                            Swal.fire({
                                title: 'Đã thanh toán!',
                                text: 'Hóa đơn đã được lập thành công và lưu vào SQL Server.',
                                icon: 'success',
                                confirmButtonColor: '#FF6B35'
                            }).then(() => {
                                // 1. Open print simulated receipt popup window
                                window.open(`/Cashier/PrintReceipt/${res.orderId}`, '_blank', 'width=450,height=700,status=no,toolbar=no');
                                
                                // 2. Redirect back to tables map
                                window.location.href = '/Cashier';
                            });
                        } else {
                            Swal.fire({
                                title: 'Lỗi',
                                text: res.message,
                                icon: 'error',
                                confirmButtonColor: '#FF6B35'
                            });
                        }
                    } catch (err) {
                        console.error(err);
                        Swal.fire({
                            title: 'Lỗi',
                            text: 'Không thể kết nối đến máy chủ.',
                            icon: 'error',
                            confirmButtonColor: '#FF6B35'
                        });
                    }
                }
            });
        }
    </script>
</body>
</html>
