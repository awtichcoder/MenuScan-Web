@model MenuQr.Models.LoginViewModel
@{
    ViewData["Title"] = "Dang nhap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dang nhap - Menu QR</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-100 flex items-center justify-center px-4">
    <main class="w-full max-w-md bg-white border border-gray-100 rounded-2xl shadow-sm p-8">
        <div class="mb-8">
            <p class="text-sm font-semibold text-amber-600 uppercase tracking-wide">Menu QR</p>
            <h1 class="text-2xl font-bold text-gray-900 mt-2">Dang nhap he thong</h1>
            <p class="text-sm text-gray-500 mt-2">Su dung tai khoan Admin, Staff hoac Kitchen de vao dung khu vuc chuc nang.</p>
        </div>

        <form asp-action="Login" method="post" class="space-y-5">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div>
                <label asp-for="Username" class="block text-sm font-semibold text-gray-700 mb-1">Ten dang nhap</label>
                <input asp-for="Username" autocomplete="username"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-xl bg-gray-50 focus:outline-none focus:ring-2 focus:ring-amber-300" />
                <span asp-validation-for="Username" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-semibold text-gray-700 mb-1">Mat khau</label>
                <input asp-for="Password" type="password" autocomplete="current-password"
                       class="w-full px-4 py-2.5 border border-gray-300 rounded-xl bg-gray-50 focus:outline-none focus:ring-2 focus:ring-amber-300" />
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>

            <button type="submit"
                    class="w-full py-2.5 rounded-xl bg-black text-white font-bold hover:bg-gray-800 transition-colors">
                Dang nhap
            </button>
        </form>

        <div class="mt-6 rounded-xl bg-gray-50 border border-gray-100 p-4 text-sm text-gray-600">
            <p><span class="font-semibold">Admin:</span> admin / admin123</p>
            <p class="mt-1"><span class="font-semibold">Staff:</span> staff / staff123</p>
            <p class="mt-1"><span class="font-semibold">Kitchen:</span> kitchen / kitchen123</p>
        </div>
    </main>
</body>
</html>
