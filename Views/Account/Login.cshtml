@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Nhập Hệ Thống - MenuScan</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center p-4">

    <!-- Container Card -->
    <div class="w-full max-w-md bg-white rounded-3xl border border-slate-200/50 shadow-2xl p-6 md:p-8 space-y-6 relative overflow-hidden">
        
        <!-- Các vòng tròn trang trí màu cam/vàng -->
        <div class="absolute -top-12 -right-12 w-32 h-32 bg-[#FF6B35]/10 rounded-full blur-xl"></div>
        <div class="absolute -bottom-12 -left-12 w-32 h-32 bg-amber-400/10 rounded-full blur-xl"></div>

        <!-- Tiêu đề và logo -->
        <div class="flex flex-col items-center text-center space-y-2 z-10 relative">
            <div class="w-14 h-14 rounded-2xl bg-[#FF6B35] flex items-center justify-center font-black text-white text-xl shadow-lg shadow-orange-500/20">
                MS
            </div>
            <div>
                <h1 class="text-xl font-extrabold text-slate-800 tracking-tight">Đăng Nhập Hệ Thống</h1>
                <p class="text-[11px] text-slate-400 font-semibold uppercase tracking-wider mt-0.5">Nhà Hàng Haidilao</p>
            </div>
        </div>

        <!-- Form nhập thông tin -->
        <form asp-action="Login" method="POST" class="space-y-4 z-10 relative">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            
            <!-- Hiển thị lỗi đăng nhập -->
            <div asp-validation-summary="ModelOnly" class="bg-rose-50 border border-rose-100 text-rose-600 px-3 py-2.5 rounded-xl text-xs font-semibold"></div>

            <!-- Tên đăng nhập -->
            <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Tên Đăng Nhập</label>
                <div class="relative">
                    <input type="text" name="username" placeholder="Nhập admin, kitchen, cashier..." required
                           class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-[#FF6B35]/20 focus:border-[#FF6B35] transition-all" />
                    <i data-lucide="user" class="w-4 h-4 text-slate-400 absolute left-3.5 top-3.5"></i>
                </div>
            </div>

            <!-- Mật khẩu -->
            <div class="space-y-1.5">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block">Mật Khẩu</label>
                <div class="relative">
                    <input type="password" name="password" placeholder="••••••••" required
                           class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:ring-2 focus:ring-[#FF6B35]/20 focus:border-[#FF6B35] transition-all" />
                    <i data-lucide="lock" class="w-4 h-4 text-slate-400 absolute left-3.5 top-3.5"></i>
                </div>
            </div>

            <!-- Nút đăng nhập -->
            <button type="submit" class="w-full py-3.5 bg-[#FF6B35] hover:bg-[#FF8552] text-white font-bold rounded-xl shadow-lg shadow-orange-500/20 active:scale-95 transition-all text-xs cursor-pointer">
                Đăng Nhập
            </button>
        </form>

        <!-- Thẻ trợ giúp tài khoản thử nghiệm (Cực kỳ tiện lợi khi bảo vệ đồ án!) -->
        <div class="bg-slate-50 border border-slate-200/50 rounded-2xl p-4 space-y-2 z-10 relative">
            <h4 class="text-[10px] font-bold text-slate-500 uppercase tracking-wider flex items-center gap-1">
                <i data-lucide="help-circle" class="w-3.5 h-3.5 text-[#FF6B35]"></i>
                Tài Khoản Thử Nghiệm Gợi Ý
            </h4>
            <div class="grid grid-cols-3 gap-2 text-[9px] text-slate-500">
                <div class="p-1.5 bg-white border border-slate-100 rounded-lg">
                    <strong class="text-slate-700 block mb-0.5">Admin</strong>
                    <span>admin</span><br/>
                    <span>admin123</span>
                </div>
                <div class="p-1.5 bg-white border border-slate-100 rounded-lg">
                    <strong class="text-slate-700 block mb-0.5">Bếp</strong>
                    <span>kitchen</span><br/>
                    <span>kitchen123</span>
                </div>
                <div class="p-1.5 bg-white border border-slate-100 rounded-lg">
                    <strong class="text-slate-700 block mb-0.5">Thu Ngân</strong>
                    <span>cashier</span><br/>
                    <span>cashier123</span>
                </div>
            </div>
        </div>

    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
