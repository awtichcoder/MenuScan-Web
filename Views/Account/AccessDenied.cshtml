@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Từ Chối Truy Cập - MenuScan</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center p-4">

    <!-- Error Card -->
    <div class="w-full max-w-md bg-white rounded-3xl border border-slate-200/50 shadow-2xl p-8 text-center space-y-6">
        
        <div class="w-16 h-16 rounded-full bg-rose-50 text-rose-500 flex items-center justify-center mx-auto">
            <i data-lucide="shield-alert" class="w-8 h-8"></i>
        </div>

        <div class="space-y-2">
            <h1 class="text-xl font-extrabold text-slate-800 tracking-tight">Từ Chối Truy Cập</h1>
            <p class="text-xs text-slate-400 font-light leading-relaxed">Bạn không có quyền truy cập vào trang này. Vui lòng đăng nhập bằng tài khoản có vai trò phù hợp hơn.</p>
        </div>

        <div class="flex gap-2">
            <a href="/Account/Login" class="flex-grow py-3 bg-[#FF6B35] hover:bg-[#FF8552] text-white font-bold rounded-xl text-xs shadow-md shadow-orange-500/10 active:scale-95 transition-all text-center block">
                Đăng Nhập Tài Khoản Khác
            </a>
        </div>

    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
