@model ActiveOrder
@{
    ViewData["Title"] = "Giỏ Hàng";
}

<div class="px-4 py-4 space-y-4 flex-grow flex flex-col">

    <!-- Tiêu đề và tổng quan -->
    <div class="flex items-center justify-between">
        <h2 class="text-lg font-black text-slate-800">Giỏ Hàng Của Bạn</h2>
        <span class="text-xs text-slate-400 font-bold">@((Model?.Items?.Count ?? 0)) món ăn</span>
    </div>

    <!-- Thông báo TempData -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-emerald-50 border border-emerald-100 text-emerald-600 px-3 py-2.5 rounded-xl text-xs font-semibold flex items-center gap-1.5">
            <i data-lucide="check-circle" class="w-4 h-4"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="bg-rose-50 border border-rose-100 text-rose-600 px-3 py-2.5 rounded-xl text-xs font-semibold flex items-center gap-1.5">
            <i data-lucide="alert-circle" class="w-4 h-4"></i>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    @if (Model == null || !Model.Items.Any())
    {
        <!-- Empty State UI -->
        <div class="flex-grow flex flex-col items-center justify-center text-center p-8 space-y-4">
            <div class="w-20 h-20 rounded-full bg-slate-100 flex items-center justify-center text-slate-300">
                <i data-lucide="shopping-bag" class="w-10 h-10"></i>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-700">Giỏ hàng đang trống</h4>
                <p class="text-xs text-slate-400 font-light mt-1">Quét mã QR và thêm món ăn hấp dẫn để bắt đầu đặt đơn nhé!</p>
            </div>
            <a href="/Home/Menu" class="px-6 py-2.5 bg-[#FF6B35] text-white text-xs font-bold rounded-xl shadow-md shadow-orange-500/10 hover:bg-[#FF8552] transition-colors">
                Xem Thực Đơn
            </a>
        </div>
    }
    else
    {
        <!-- Danh sách món ăn trong giỏ -->
        <div class="space-y-3 flex-grow pb-32">
            @foreach (var item in Model.Items)
            {
                <div class="bg-white p-3 rounded-2xl shadow-sm border border-slate-100/50 flex gap-3 relative">
                    <!-- Thông tin chi tiết món -->
                    <div class="flex-grow min-w-0">
                        <div class="flex justify-between items-start gap-2">
                            <h4 class="text-sm font-bold text-slate-800 truncate">@item.DishName</h4>
                            <span class="text-sm font-extrabold text-[#FF6B35]">@((item.Price * item.Quantity).ToString("N0"))₫</span>
                        </div>
                        
                        <!-- Mô tả kích cỡ và topping kèm theo -->
                        <div class="text-[10px] text-slate-400 mt-1 font-semibold space-y-0.5">
                            <div>Kích cỡ: <span class="text-slate-600 font-bold">@item.SelectedSize</span></div>
                            @if (item.SelectedToppings != null && item.SelectedToppings.Any())
                            {
                                <div>Món thêm: <span class="text-slate-600 font-bold">@string.Join(", ", item.SelectedToppings)</span></div>
                            }
                            @if (!string.IsNullOrEmpty(item.CustomerNote))
                            {
                                <div class="italic text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded mt-1 inline-block">Ghi chú: @item.CustomerNote</div>
                            }
                        </div>

                        <!-- Căn chỉnh số lượng và xóa món -->
                        <div class="flex items-center justify-between mt-3 pt-3 border-t border-slate-100">
                            <!-- Nút tăng giảm số lượng -->
                            <div class="flex items-center bg-slate-50 border border-slate-100 rounded-lg p-0.5">
                                <form asp-action="UpdateQuantity" method="POST" class="inline">
                                    <input type="hidden" name="dishId" value="@item.DishId" />
                                    <input type="hidden" name="size" value="@item.SelectedSize" />
                                    @foreach (var t in item.SelectedToppings ?? new List<string>())
                                    {
                                        <input type="hidden" name="toppings" value="@t" />
                                    }
                                    <input type="hidden" name="quantity" value="@(item.Quantity - 1)" />
                                    <button type="submit" class="w-6 h-6 flex items-center justify-center text-slate-500 hover:bg-white rounded active:scale-95 transition-all">
                                        <i data-lucide="minus" class="w-3 h-3"></i>
                                    </button>
                                </form>
                                
                                <span class="w-6 text-center text-xs font-bold text-slate-700">@item.Quantity</span>
                                
                                <form asp-action="UpdateQuantity" method="POST" class="inline">
                                    <input type="hidden" name="dishId" value="@item.DishId" />
                                    <input type="hidden" name="size" value="@item.SelectedSize" />
                                    @foreach (var t in item.SelectedToppings ?? new List<string>())
                                    {
                                        <input type="hidden" name="toppings" value="@t" />
                                    }
                                    <input type="hidden" name="quantity" value="@(item.Quantity + 1)" />
                                    <button type="submit" class="w-6 h-6 flex items-center justify-center text-slate-500 hover:bg-white rounded active:scale-95 transition-all">
                                        <i data-lucide="plus" class="w-3 h-3"></i>
                                    </button>
                                </form>
                            </div>

                            <!-- Nút xóa món khỏi giỏ hàng -->
                            <form asp-action="RemoveItem" method="POST">
                                <input type="hidden" name="dishId" value="@item.DishId" />
                                <input type="hidden" name="size" value="@item.SelectedSize" />
                                @foreach (var t in item.SelectedToppings ?? new List<string>())
                                {
                                    <input type="hidden" name="toppings" value="@t" />
                                }
                                <button type="submit" class="text-rose-500 hover:text-rose-700 p-1.5 rounded-full hover:bg-rose-50 transition-colors">
                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <!-- Khu vực áp dụng Voucher khuyến mãi -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100/50 space-y-3">
                <div class="flex items-center gap-1.5 text-xs font-bold text-slate-600">
                    <i data-lucide="ticket" class="w-4 h-4 text-[#FF6B35]"></i>
                    <span>Áp Dụng Mã Khuyến Mãi</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.VoucherCode))
                {
                    <div class="flex items-center justify-between p-2 bg-emerald-50 border border-emerald-100 rounded-xl">
                        <div class="flex items-center gap-2">
                            <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
                            <span class="text-xs font-bold text-emerald-800">Đã áp dụng: @Model.VoucherCode</span>
                        </div>
                        <a href="@Url.Action("RemoveVoucher", "Cart")" class="text-xs text-rose-500 font-bold hover:underline">Gỡ bỏ</a>
                    </div>
                }
                else
                {
                    <form asp-action="ApplyVoucher" method="POST" class="flex gap-2">
                        <input type="text" name="voucherCode" placeholder="Nhập mã (Ví dụ: HADILAO10, WELCOME20...)" required
                               class="flex-grow px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-xs font-semibold focus:outline-none focus:ring-1 focus:ring-[#FF6B35] focus:border-[#FF6B35]" />
                        <button type="submit" class="px-4 py-2 bg-[#FF6B35] text-white text-xs font-bold rounded-xl shadow-md shadow-orange-500/10 active:scale-95 transition-all">
                            Áp Dụng
                        </button>
                    </form>
                }
            </div>

            <!-- Hóa đơn tính toán chi tiết -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-slate-100/50 space-y-3">
                <div class="flex justify-between items-center text-xs text-slate-500">
                    <span>Tổng tạm tính</span>
                    <span class="font-bold">@Model.SubTotal.ToString("N0")₫</span>
                </div>
                @if (Model.DiscountAmount > 0)
                {
                    <div class="flex justify-between items-center text-xs text-emerald-600">
                        <span>Giảm giá (@Model.VoucherCode)</span>
                        <span class="font-bold">-@Model.DiscountAmount.ToString("N0")₫</span>
                    </div>
                }
                <div class="border-t border-slate-100 pt-2.5 flex justify-between items-center text-sm">
                    <span class="font-bold text-slate-800">Tổng thanh toán</span>
                    <span class="text-lg font-black text-[#FF6B35]">@Model.TotalAmount.ToString("N0")₫</span>
                </div>
            </div>
        </div>

        <!-- Thanh Nút Thanh Toán Cố Định Ở Dưới -->
        <div class="fixed bottom-14 left-1/2 -translate-x-1/2 w-full max-w-[430px] bg-white border-t border-slate-100 p-4 z-40 shadow-[0_-4px_12px_rgba(0,0,0,0.03)]">
            <a href="/Cart/Checkout" class="w-full py-4 bg-[#FF6B35] hover:bg-[#FF8552] text-white font-bold rounded-xl shadow-lg shadow-orange-500/20 active:scale-95 transition-all flex justify-between px-6 items-center">
                <span>Tiến Hành Đặt Món</span>
                <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </a>
        </div>
    }
</div>
