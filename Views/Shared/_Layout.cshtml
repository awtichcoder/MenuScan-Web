@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var tableNumber = HttpContextAccessor.HttpContext?.Session.GetString("TableNumber");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MenuScan</title>
    
    <!-- Google Fonts: Poppins & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <style>
        body {
            font-family: 'Poppins', 'Inter', sans-serif;
            background-color: #F1F5F9;
        }
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center">

    <!-- Khung Màn Hình Điện Thoại Căn Giữa (390px - 430px) -->
    <div class="w-full max-w-[430px] min-h-screen bg-slate-50 shadow-2xl relative flex flex-col justify-between overflow-x-hidden border-x border-slate-200/50 pb-20">
        
        <!-- Thanh Đầu Trang Sticky -->
        <header class="sticky top-0 z-50 flex items-center justify-between px-4 py-3 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-[#FF6B35] flex items-center justify-center text-white font-black text-sm">MS</div>
                <div>
                    <h1 class="text-sm font-bold text-slate-800 leading-none">HAIDILAO</h1>
                    @if (!string.IsNullOrEmpty(tableNumber))
                    {
                        <span class="inline-flex items-center text-xs font-semibold text-[#FF6B35] mt-0.5">Bàn @tableNumber</span>
                    }
                    else
                    {
                        <span class="inline-flex items-center text-xs font-semibold text-slate-400 mt-0.5">Chưa chọn bàn</span>
                    }
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                @if (!string.IsNullOrEmpty(tableNumber))
                {
                    <button onclick="triggerCallStaff()" class="flex items-center gap-1 px-3 py-1.5 bg-red-50 hover:bg-red-100 text-[#E74C3C] text-xs font-bold rounded-full transition-colors border border-red-100">
                        <i data-lucide="bell-ring" class="w-3.5 h-3.5"></i>
                        <span>Gọi Nhân Viên</span>
                    </button>
                }
                
                <a href="/Order/Profile" class="p-1.5 text-slate-600 hover:text-slate-900 rounded-full hover:bg-slate-50 transition-colors">
                    <i data-lucide="user" class="w-5 h-5"></i>
                </a>
            </div>
        </header>

        <!-- Nội dung chính -->
        <main class="flex-grow flex flex-col">
            @RenderBody()
        </main>

        <!-- Thanh Điều Hướng Dưới Cùng (Fixed cho giao diện khách hàng) -->
        <nav class="absolute bottom-0 left-0 w-full z-40 grid grid-cols-4 bg-white border-t border-slate-100 py-2.5 shadow-[0_-4px_12px_rgba(0,0,0,0.03)]">
            <a href="/Home/Menu" class="flex flex-col items-center justify-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Menu" ? "text-[#FF6B35]" : "text-slate-400 hover:text-[#FF6B35]")">
                <i data-lucide="home" class="w-5 h-5"></i>
                <span class="text-[10px] font-semibold mt-1">Trang Chủ</span>
            </a>
            
            <a href="/Cart" class="flex flex-col items-center justify-center relative @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Cart" ? "text-[#FF6B35]" : "text-slate-400 hover:text-[#FF6B35]")">
                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                <span class="text-[10px] font-semibold mt-1">Giỏ Hàng</span>
            </a>
            
            <a href="/Order/Tracking" class="flex flex-col items-center justify-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" && ViewContext.RouteData.Values["Action"]?.ToString() == "Tracking" ? "text-[#FF6B35]" : "text-slate-400 hover:text-[#FF6B35]")">
                <i data-lucide="package" class="w-5 h-5"></i>
                <span class="text-[10px] font-semibold mt-1">Theo Dõi</span>
            </a>
            
            <a href="/Order/Profile" class="flex flex-col items-center justify-center @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" && ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "text-[#FF6B35]" : "text-slate-400 hover:text-[#FF6B35]")">
                <i data-lucide="history" class="w-5 h-5"></i>
                <span class="text-[10px] font-semibold mt-1">Lịch Sử</span>
            </a>
        </nav>

    </div>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        // Khởi tạo Lucide Icons
        lucide.createIcons();

        // AJAX Gọi nhân viên
        async function triggerCallStaff() {
            try {
                const response = await fetch('/Order/CallStaff', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    Swal.fire({
                        title: 'Đã gọi nhân viên!',
                        text: 'Yêu cầu của bạn đã được gửi, nhân viên sẽ có mặt ngay.',
                        icon: 'success',
                        confirmButtonColor: '#FF6B35',
                        timer: 3000
                    });
                } else {
                    Swal.fire({
                        title: 'Thất bại',
                        text: result.message,
                        icon: 'error',
                        confirmButtonColor: '#FF6B35'
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({
                    title: 'Lỗi',
                    text: 'Không thể kết nối đến máy chủ.',
                    icon: 'error',
                    confirmButtonColor: '#FF6B35'
                });
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
