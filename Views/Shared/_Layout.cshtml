<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .hide-scrollbar::-webkit-scrollbar {
        display: none;
        }

        .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-gray-100 font-sans antialiased">

    <div class="hidden md:flex h-screen w-full items-center justify-center bg-gray-800 p-4 text-center">
        <div class="bg-white p-8 rounded-xl shadow-2xl max-w-lg">
            <h1 class="text-2xl font-bold text-gray-800 mb-2">Trải nghiệm trên điện thoại</h1>
            <p class="text-gray-600">Vui lòng dùng điện thoại quét mã QR tại bàn để sử dụng.</p>
        </div>
    </div>

    <!-- KHUNG MOBILE CHÍNH -->
    <div class="md:hidden min-h-screen bg-white relative pb-24">

        <header class="sticky top-0 z-50 bg-white border-b px-4 py-3 flex justify-between items-center shadow-sm">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-red-600 rounded text-white flex items-center justify-center font-bold">SU</div>
                <span class="font-bold text-gray-800" id="currentTableId">Bàn: @ViewBag.TableId</span>
            </div>
        </header>

        <!-- Render Nội Dung Các Trang -->
        @RenderBody()

        <!-- Thanh Sticky Bottom (Xem Giỏ Hàng) -->
        <div onclick="openCartModal()"
             class="fixed bottom-0 left-0 right-0 bg-white border-t px-4 py-3 flex justify-between items-center shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] z-40 cursor-pointer">
            <div class="flex items-center gap-3">
                <span class="font-bold text-lg text-gray-800 underline decoration-2 underline-offset-4">Giỏ hàng</span>
                <span id="globalCartCount" class="bg-black text-white px-3 py-1 rounded-md font-bold">0</span>
            </div>
            <div class="text-right">
                <p class="text-xs text-gray-500 font-semibold mb-0.5">Tổng tiền</p>
                <p id="globalCartTotal" class="font-bold text-orange-500 leading-none text-lg">0 VNĐ</p>
            </div>
        </div>

    </div>

    <!-- ========================================== -->
    <!-- GIAO DIỆN GIỎ HÀNG (CART MODAL) -->
    <!-- ========================================== -->
    <div id="cartOverlay" class="fixed inset-0 bg-black/60 z-[80] hidden opacity-0 transition-opacity duration-300"
         onclick="closeCartModal()"></div>

    <div id="cartModal"
         class="fixed bottom-0 left-0 right-0 bg-white rounded-t-3xl z-[90] transform translate-y-full transition-transform duration-300 flex flex-col h-[85vh]">
        <div class="flex justify-between items-center p-4 border-b">
            <h2 class="text-xl font-bold text-gray-800">Giỏ hàng của bạn</h2>
            <button onclick="closeCartModal()"
                    class="w-8 h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-600">✕</button>
        </div>

        <!-- Danh sách món trong giỏ -->
        <div id="cartItemsContainer" class="flex-1 overflow-y-auto p-4 flex flex-col gap-4 bg-gray-50">
            <!-- Render bằng JS -->
        </div>

        <!-- Khu vực Footer Giỏ Hàng (Tổng tiền & Nút Action) -->
        <div class="bg-white p-4 border-t shadow-[0_-4px_15px_-3px_rgba(0,0,0,0.05)]">
            <div class="flex justify-between mb-3">
                <span class="text-gray-600 font-semibold">Tổng cộng:</span>
                <span id="cartModalTotal" class="font-bold text-xl text-black">0 VNĐ</span>
            </div>

            <div class="flex gap-2">
                <!-- Nút Xác Nhận Món (Dành cho món Mới) -->
                <button id="btnConfirmOrder" onclick="confirmOrder()"
                        class="flex-1 bg-black text-white font-bold py-3 rounded-xl transition-colors">
                    Xác nhận gọi món
                </button>
                <!-- Nút Thanh Toán -->
                <button id="btnCheckout" onclick="checkoutVnpay()"
                        class="flex-1 bg-[#F3C178] text-black font-bold py-3 rounded-xl transition-colors opacity-50 cursor-not-allowed"
                        disabled>
                    Thanh toán (VNPAY)
                </button>
            </div>
            <p id="cartWarningMsg" class="text-red-500 text-xs text-center mt-2 font-medium hidden">
                *Bạn cần "Xác nhận gọi món" cho các món mới trước khi thanh toán.
            </p>
        </div>
    </div>

    <script>
        // Lấy mã bàn từ ViewBag (Đảm bảo Controller Home có truyền ViewBag.TableId sang)
        const TABLE_ID = '@ViewBag.TableId';

        // ==========================================
        // 1. MỞ / ĐÓNG GIỎ HÀNG (Lỗi ở đây do thiếu 2 hàm này)
        // ==========================================
        function openCartModal() {
        loadCartFromDB(); // Cập nhật lại data mới nhất trước khi mở
        const overlay = document.getElementById('cartOverlay');
        const modal = document.getElementById('cartModal');
        if (overlay && modal) {
        overlay.classList.remove('hidden');
        setTimeout(() => {
        overlay.classList.remove('opacity-0');
        modal.classList.remove('translate-y-full');
        }, 10);
        }
        }

        function closeCartModal() {
        const overlay = document.getElementById('cartOverlay');
        const modal = document.getElementById('cartModal');
        if (overlay && modal) {
        overlay.classList.add('opacity-0');
        modal.classList.add('translate-y-full');
        setTimeout(() => { overlay.classList.add('hidden'); }, 300);
        }
        }

        // ==========================================
        // 2. TẢI GIỎ HÀNG TỪ MONGODB LÊN GIAO DIỆN
        // ==========================================
        async function loadCartFromDB() {
        if (!TABLE_ID) return;
        try {
        const res = await fetch(`/Order/GetCartMongo?tableId=${TABLE_ID}`);
        if (res.ok) {
        const cartItems = await res.json();
        updateGlobalCartUI(cartItems); // Cập nhật số lượng đỏ đỏ ở ngoài
        renderCartItems(cartItems);    // Vẽ danh sách món bên trong
        }
        } catch (err) {
        console.error("Lỗi tải giỏ hàng từ MongoDB:", err);
        }
        }

        // ==========================================
        // 3. CẬP NHẬT CỤC SỐ LƯỢNG MÀU ĐỎ Ở NGOÀI
        // ==========================================
        function updateGlobalCartUI(cart) {
        let totalQty = 0;
        let totalPrice = 0;
        cart.forEach(item => {
        totalQty += item.quantity;
        totalPrice += item.finalPrice * item.quantity;
        });

        const countElement = document.getElementById('globalCartCount');
        if (countElement) countElement.innerText = totalQty;

        const totalElement = document.getElementById('globalCartTotal');
        if (totalElement) totalElement.innerText = formatMoney(totalPrice);
        }

        // ==========================================
        // 4. VẼ DANH SÁCH MÓN VÀO BÊN TRONG GIỎ HÀNG
        // ==========================================
        function renderCartItems(cart) {
        const container = document.getElementById('cartItemsContainer');
        if (!container) return;

        container.innerHTML = '';

        if (cart.length === 0) {
        container.innerHTML = '<div class="text-center text-gray-400 mt-10">Giỏ hàng trống</div>';
        }

        let totalPrice = 0;
        let hasPendingItems = false; // Biến kiểm tra xem có món nào chưa gửi bếp không

        cart.forEach(item => {
        let itemTotal = item.finalPrice * item.quantity;
        totalPrice += itemTotal;
        if (item.itemStatus === 'Pending') hasPendingItems = true;

        const isPending = item.itemStatus === 'Pending';
        const statusHtml = isPending
        ? `<span class="bg-blue-100 text-blue-600 px-2 py-0.5 rounded text-xs font-bold">Mới thêm</span>`
        : `<span class="bg-green-100 text-green-600 px-2 py-0.5 rounded text-xs font-bold">Đã báo bếp</span>`;

        // Chỉ cho xóa món nếu món đó chưa báo bếp
        const deleteBtnHtml = isPending
        ? `<button onclick="removeCartItem('${item.cartItemId}')" class="text-red-500 font-medium text-sm underline mt-2">Xóa</button>` : ``;

        let optionsText = item.selectedOptions && item.selectedOptions.length > 0
        ? `<p class="text-xs text-gray-500 mt-1">Tuỳ chọn: ${item.selectedOptions.map(o => o.name).join(', ')}</p>`
        : '';

        let noteText = item.note
        ? `<p class="text-xs text-orange-500 mt-1 border-l-2 border-orange-500 pl-1">Ghi chú: ${item.note}</p>`
        : '';

        container.innerHTML += `
        <div class="bg-white p-3 rounded-xl shadow-sm border border-gray-100 flex gap-3 relative mb-2">
        <img src="${item.imageUrl || 'https://via.placeholder.com/150'}" class="w-16 h-16 object-cover rounded-lg border" />
        <div class="flex-1">
        <h3 class="font-bold text-sm text-gray-900">${item.dishName} <span class="text-gray-500 font-normal">x${item.quantity}</span></h3>
        <p class="font-semibold text-orange-500 text-sm">${formatMoney(itemTotal)}</p>
        ${optionsText}
        ${noteText}
        <div class="mt-2 flex justify-between items-center">${statusHtml}${deleteBtnHtml}</div>
        </div>
        </div>`;
        });

        // Cập nhật tổng tiền bên trong Modal giỏ hàng
        const modalTotalElement = document.getElementById('cartModalTotal');
        if (modalTotalElement) modalTotalElement.innerText = formatMoney(totalPrice);

        // Khóa / Mở khóa nút Xác Nhận & Thanh Toán dựa vào trạng thái món
        const btnConfirm = document.getElementById('btnConfirmOrder');
        const btnCheckout = document.getElementById('btnCheckout');
        const warningMsg = document.getElementById('cartWarningMsg');

        if (btnConfirm && btnCheckout) {
        if (cart.length === 0) {
        btnConfirm.disabled = true; btnConfirm.classList.add('opacity-50');
        btnCheckout.disabled = true; btnCheckout.classList.add('opacity-50');
        if (warningMsg) warningMsg.classList.add('hidden');
        } else if (hasPendingItems) {
        // Có món mới -> Bắt buộc phải bấm xác nhận xuống bếp
        btnConfirm.disabled = false; btnConfirm.classList.remove('opacity-50');
        btnCheckout.disabled = true; btnCheckout.classList.add('opacity-50', 'cursor-not-allowed');
        if (warningMsg) warningMsg.classList.remove('hidden');
        } else {
        // Toàn bộ đã xuống bếp -> Cho phép thanh toán
        btnConfirm.disabled = true; btnConfirm.classList.add('opacity-50');
        btnCheckout.disabled = false; btnCheckout.classList.remove('opacity-50', 'cursor-not-allowed');
        if (warningMsg) warningMsg.classList.add('hidden');
        }
        }
        }

        // ==========================================
        // 5. CÁC HÀM XỬ LÝ NGHIỆP VỤ (Xóa, Xác nhận, Format tiền...)
        // ==========================================
        function formatMoney(amount) {
        return new Intl.NumberFormat('vi-VN').format(amount) + ' đ';
        }

        async function removeCartItem(cartItemId) {
        try {
        await fetch(`/Order/RemovePendingItem?tableId=${TABLE_ID}&cartItemId=${cartItemId}`, { method: 'POST' });
        loadCartFromDB(); // Tải lại giỏ hàng lập tức sau khi xóa
        } catch (err) {
        alert("Lỗi khi xóa món!");
        }
        }

        async function confirmOrder() {
        try {
        await fetch(`/Order/ConfirmPendingItems?tableId=${TABLE_ID}`, { method: 'POST' });
        alert("Đã gửi order các món mới xuống bếp thành công!");
        loadCartFromDB();
        } catch (err) {
        alert("Lỗi khi xác nhận order!");
        }
        }

        // Tự động gọi API tải giỏ hàng ngay khi khách vừa load trang web xong
        document.addEventListener("DOMContentLoaded", function () {
        loadCartFromDB();
        });
    </script>
</body>

</html>