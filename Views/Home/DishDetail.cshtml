@model DishDetailViewModel
@{
    ViewData["Title"] = Model.Dish.Name;
}

<div class="flex-grow flex flex-col bg-white">
    <!-- Close / Back Header -->
    <div class="px-4 py-3 border-b border-slate-100 flex items-center gap-3">
        <a href="/Home/Menu" class="p-1.5 text-slate-500 hover:text-slate-800 rounded-full hover:bg-slate-50 transition-colors">
            <i data-lucide="arrow-left" class="w-5 h-5"></i>
        </a>
        <span class="text-sm font-bold text-slate-700">Chi tiết món ăn</span>
    </div>

    <!-- Dish Hero Image -->
    <div class="w-full h-52 bg-slate-100 overflow-hidden relative">
        <img src="@(string.IsNullOrEmpty(Model.Dish.Image) ? "/images/menu/default.webp" : Model.Dish.Image)" 
             class="w-full h-full object-cover" 
             alt="@Model.Dish.Name"
             onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400'"/>
    </div>

    <!-- Form Section -->
    <form asp-controller="Cart" asp-action="AddToCart" method="POST" id="addToCartForm" class="flex-grow flex flex-col justify-between">
        <input type="hidden" name="dishId" value="@Model.Dish.Id" />
        
        <!-- Details Area -->
        <div class="p-4 space-y-5 flex-grow">
            <!-- Header Info -->
            <div class="space-y-1">
                <div class="flex justify-between items-start gap-2">
                    <h2 class="text-lg font-black text-slate-800">@Model.Dish.Name</h2>
                    <span class="text-lg font-black text-[#FF6B35]" id="basePriceDisplay" data-base="@Model.Dish.Price">
                        @Model.Dish.Price.ToString("N0")₫
                    </span>
                </div>
                <div class="flex items-center gap-1.5 text-xs text-slate-500 font-semibold">
                    <span class="bg-amber-100 text-amber-600 px-1.5 py-0.5 rounded flex items-center gap-0.5">
                        <i data-lucide="star" class="w-3 h-3 fill-amber-500 stroke-none"></i>4.8
                    </span>
                    <span>•</span>
                    <span>Chuẩn bị: 10-15 phút</span>
                </div>
                <p class="text-xs text-slate-400 font-light leading-relaxed mt-2">@Model.Dish.Description</p>
            </div>

            <!-- Sizes Selection -->
            @if (Model.Dish.Sizes != null && Model.Dish.Sizes.Any())
            {
                <div class="space-y-2.5">
                    <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Chọn Kích Cỡ <span class="text-red-500">*</span></h3>
                    <div class="flex flex-col gap-2">
                        @foreach (var size in Model.Dish.Sizes)
                        {
                            <label class="flex items-center justify-between p-3 border border-slate-200 rounded-xl cursor-pointer hover:border-[#FF6B35]/50 transition-all select-none option-label">
                                <div class="flex items-center gap-2">
                                    <input type="radio" name="selectedSize" value="@size.Name" data-price="@size.PriceAdjustment" 
                                           class="w-4 h-4 text-[#FF6B35] focus:ring-[#FF6B35] border-slate-300 size-radio" 
                                           @(size == Model.Dish.Sizes.First() ? "checked" : "") />
                                    <span class="text-xs font-bold text-slate-700">@size.Name</span>
                                </div>
                                <span class="text-xs font-semibold text-slate-400">
                                    @(size.PriceAdjustment > 0 ? $"+{size.PriceAdjustment:N0}₫" : "Miễn Phí")
                                </span>
                            </label>
                        }
                    </div>
                </div>
            }

            <!-- Toppings Selection -->
            @if (Model.Dish.Toppings != null && Model.Dish.Toppings.Any())
            {
                <div class="space-y-2.5">
                    <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Chọn Món Thêm (Tùy chọn)</h3>
                    <div class="flex flex-col gap-2">
                        @foreach (var topping in Model.Dish.Toppings)
                        {
                            <label class="flex items-center justify-between p-3 border border-slate-200 rounded-xl cursor-pointer hover:border-[#FF6B35]/50 transition-all select-none option-label">
                                <div class="flex items-center gap-2">
                                    <input type="checkbox" name="selectedToppings" value="@topping.Name" data-price="@topping.Price" 
                                           class="w-4 h-4 text-[#FF6B35] focus:ring-[#FF6B35] border-slate-300 rounded topping-checkbox" />
                                    <span class="text-xs font-semibold text-slate-700">@topping.Name</span>
                                </div>
                                <span class="text-xs font-semibold text-slate-400">
                                    +@topping.Price.ToString("N0")₫
                                </span>
                            </label>
                        }
                    </div>
                </div>
            }

            <!-- Note Textarea -->
            <div class="space-y-2">
                <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider">Ghi chú cho nhà bếp</h3>
                <textarea name="customerNote" rows="2" placeholder="Ví dụ: Không hành, cay nhiều, ít ngọt..." 
                          class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-xs focus:outline-none focus:ring-1 focus:ring-[#FF6B35] focus:border-[#FF6B35]"></textarea>
            </div>
        </div>

        <!-- Sticky Bottom Cart Action -->
        <div class="sticky bottom-0 bg-white border-t border-slate-100 p-4 space-y-3 shadow-[0_-4px_12px_rgba(0,0,0,0.03)]">
            <div class="flex items-center justify-between">
                <span class="text-xs font-bold text-slate-400">Số Lượng</span>
                
                <!-- Counter UI -->
                <div class="flex items-center bg-slate-100 border border-slate-200 rounded-xl p-1">
                    <button type="button" onclick="adjustQuantity(-1)" class="w-8 h-8 flex items-center justify-center text-slate-600 hover:bg-white rounded-lg active:scale-95 transition-all">
                        <i data-lucide="minus" class="w-4 h-4"></i>
                    </button>
                    <input type="number" id="qtyInput" name="quantity" value="1" min="1" readonly
                           class="w-10 text-center bg-transparent border-none text-sm font-bold text-slate-800 focus:outline-none focus:ring-0" />
                    <button type="button" onclick="adjustQuantity(1)" class="w-8 h-8 flex items-center justify-center text-slate-600 hover:bg-white rounded-lg active:scale-95 transition-all">
                        <i data-lucide="plus" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <!-- Submit Button -->
            <button type="submit" class="w-full py-4 bg-[#FF6B35] hover:bg-[#FF8552] text-white font-bold rounded-xl shadow-lg shadow-orange-500/20 active:scale-95 transition-all flex justify-between px-6 items-center">
                <span>Thêm Vào Giỏ</span>
                <span id="calculatedTotalDisplay">@Model.Dish.Price.ToString("N0")₫</span>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const basePrice = parseFloat(document.getElementById('basePriceDisplay').dataset.base);
        const qtyInput = document.getElementById('qtyInput');
        const sizeRadios = document.querySelectorAll('.size-radio');
        const toppingCheckboxes = document.querySelectorAll('.topping-checkbox');
        const calculatedTotalDisplay = document.getElementById('calculatedTotalDisplay');

        // Adjust input quantity
        function adjustQuantity(amount) {
            let val = parseInt(qtyInput.value) || 1;
            val += amount;
            if (val < 1) val = 1;
            qtyInput.value = val;
            calculateTotalPrice();
        }

        // Live total price calculator
        function calculateTotalPrice() {
            let unitPrice = basePrice;

            // Size Adjustment
            sizeRadios.forEach(radio => {
                if (radio.checked) {
                    unitPrice += parseFloat(radio.dataset.price) || 0;
                }
            });

            // Toppings Sum
            toppingCheckboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    unitPrice += parseFloat(checkbox.dataset.price) || 0;
                }
            });

            // Quantity Factor
            const quantity = parseInt(qtyInput.value) || 1;
            const finalTotal = unitPrice * quantity;

            // Render Formatting
            calculatedTotalDisplay.innerText = finalTotal.toLocaleString('vi-VN') + '₫';
        }

        // Register DOM Change Listeners
        sizeRadios.forEach(radio => radio.addEventListener('change', calculateTotalPrice));
        toppingCheckboxes.forEach(cb => cb.addEventListener('change', calculateTotalPrice));

        // Highlight selected radio/checkbox labels visually
        function highlightLabels() {
            document.querySelectorAll('.option-label').forEach(label => {
                const input = label.querySelector('input');
                if (input.checked) {
                    label.classList.add('border-[#FF6B35]', 'bg-orange-50/20');
                } else {
                    label.classList.remove('border-[#FF6B35]', 'bg-orange-50/20');
                }
            });
        }

        document.getElementById('addToCartForm').addEventListener('change', highlightLabels);
        highlightLabels(); // Initial run
    </script>
}
