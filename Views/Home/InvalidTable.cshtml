@model string
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lỗi truy cập bàn</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gray-50 flex items-center justify-center min-h-screen p-4">
    <div class="max-w-md w-full bg-white p-8 rounded-3xl shadow-xl text-center border border-gray-100">
        <div
            class="w-20 h-20 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6 text-red-500 animate-bounce">
            <i class="fa-solid fa-triangle-exclamation text-4xl"></i>
        </div>
        <h1 class="text-2xl font-black text-gray-800 mb-3">Truy Cập Bị Chặn</h1>
        <p class="text-gray-600 mb-6 leading-relaxed">
            @Model
        </p>
        <div class="border-t pt-6">
            <p class="text-xs text-gray-400">
                <i class="fa-solid fa-circle-info mr-1"></i> Hệ thống gọi món tự động Menu QR
            </p>
        </div>
    </div>
</body>

</html>