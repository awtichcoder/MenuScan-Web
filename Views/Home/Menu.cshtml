@model MenuViewModel
@{
    ViewData["Title"] = "Thực Đơn - Haidilao";
}

<div class="px-4 py-4 space-y-4 flex-grow flex flex-col">

    <!-- Thông báo kết quả TempData -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-emerald-50 border border-emerald-100 text-emerald-600 px-4 py-3 rounded-2xl text-xs font-semibold flex items-center gap-2 animate-bounce">
            <i data-lucide="check-circle" class="w-4 h-4"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }

    <!-- Banner khuyến mãi -->
    <div class="bg-gradient-to-r from-[#FF6B35] to-[#FF9F1C] text-white p-4 rounded-2xl shadow-md flex items-center justify-between overflow-hidden relative">
        <div class="space-y-1 z-10">
            <h3 class="text-sm font-bold opacity-90">Giảm giá đặc biệt!</h3>
            <h2 class="text-lg font-extrabold leading-tight">Nhập mã <span class="underline">HADILAO10</span> giảm ngay 10%</h2>
        </div>
        <i data-lucide="sparkles" class="w-12 h-12 text-white/20 absolute -right-2 -bottom-2 z-0"></i>
    </div>

    <!-- Thanh tìm kiếm món ăn -->
    <form asp-action="Menu" method="GET" class="relative">
        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
        <input type="text" name="search" value="@Model.SearchQuery" placeholder="Tìm món ăn, nước lẩu, đồ uống..." 
               class="w-full pl-10 pr-4 py-2.5 bg-white border border-slate-200 rounded-full text-xs font-semibold text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-[#FF6B35]/20 focus:border-[#FF6B35]" />
        <i data-lucide="search" class="w-4 h-4 text-slate-400 absolute left-3.5 top-3"></i>
        @if (!string.IsNullOrEmpty(Model.SearchQuery))
        {
            <a href="/Home/Menu?categoryId=@Model.SelectedCategoryId" class="absolute right-3.5 top-2 text-slate-400 hover:text-slate-600">
                <i data-lucide="x" class="w-4.5 h-4.5"></i>
            </a>
        }
    </form>

    <!-- Danh mục món ăn -->
    <div class="space-y-2">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Danh mục</h4>
        <div class="flex items-center gap-2 overflow-x-auto no-scrollbar py-1">
            <!-- All Option -->
            <a href="/Home/Menu?search=@Model.SearchQuery" 
               class="flex items-center gap-1.5 px-4 py-2 text-xs font-bold rounded-full border transition-all whitespace-nowrap @(string.IsNullOrEmpty(Model.SelectedCategoryId) ? "bg-[#FF6B35] text-white border-transparent shadow-sm" : "bg-white border-slate-100 text-slate-600 hover:border-slate-200")">
                <i data-lucide="layers" class="w-3.5 h-3.5"></i>
                <span>Tất Cả Món</span>
            </a>

            @foreach (var cat in Model.Categories)
            {
                <a href="/Home/Menu?categoryId=@cat.Id&search=@Model.SearchQuery" 
                   class="flex items-center gap-1.5 px-4 py-2 text-xs font-bold rounded-full border transition-all whitespace-nowrap @(Model.SelectedCategoryId == cat.Id ? "bg-[#FF6B35] text-white border-transparent shadow-sm" : "bg-white border-slate-100 text-slate-600 hover:border-slate-200")">
                    <i data-lucide="tag" class="w-3.5 h-3.5"></i>
                    <span>@cat.Name</span>
                </a>
            }
        </div>
    </div>

    <!-- Danh sách món ăn -->
    <div class="space-y-3 flex-grow pb-16">
        <h4 class="text-xs font-bold uppercase tracking-wider text-slate-400">Thực đơn chọn lọc (@Model.Dishes.Count)</h4>
        
        @if (!Model.Dishes.Any())
        {
            <div class="bg-white rounded-2xl p-8 text-center border border-slate-100 space-y-2">
                <i data-lucide="utensils" class="w-10 h-10 text-slate-300 mx-auto"></i>
                <h5 class="text-sm font-bold text-slate-700">Không tìm thấy món ăn</h5>
                <p class="text-xs text-slate-400">Hãy thử tìm kiếm từ khóa khác hoặc chuyển danh mục.</p>
            </div>
        }
        else
        {
            <div class="flex flex-col gap-3">
                @foreach (var dish in Model.Dishes)
                {
                    <div class="flex gap-3 bg-white p-3 rounded-2xl shadow-sm border border-slate-100/50 relative hover:shadow-md transition-shadow duration-300">
                        <!-- Thumbnail -->
                        <div class="w-20 h-20 bg-slate-100 rounded-xl overflow-hidden flex-shrink-0 flex items-center justify-center relative">
                            <img src="@(string.IsNullOrEmpty(dish.Image) ? "/images/menu/default.webp" : dish.Image)" 
                                 class="w-full h-full object-cover" 
                                 alt="@dish.Name" 
                                 onerror="this.src='https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=200'"/>
                            <span class="absolute bottom-1 right-1 bg-amber-400 text-[8px] font-extrabold text-white px-1 py-0.5 rounded flex items-center gap-0.5">
                                <i data-lucide="star" class="w-2 h-2 fill-white border-none"></i>4.8
                            </span>
                        </div>

                        <!-- Info Content -->
                        <div class="flex-grow flex flex-col justify-between min-w-0">
                            <div>
                                <h4 class="text-sm font-bold text-slate-800 truncate">@dish.Name</h4>
                                <p class="text-[10px] text-slate-400 line-clamp-2 mt-0.5 leading-relaxed font-light">@dish.Description</p>
                            </div>
                            
                            <div class="flex items-center justify-between mt-1">
                                <span class="text-sm font-extrabold text-[#FF6B35]">@dish.Price.ToString("N0")₫</span>
                                <a href="/Home/DishDetail/@dish.Id" 
                                   class="w-7 h-7 bg-[#FF6B35] text-white hover:bg-[#FF8552] rounded-full flex items-center justify-center shadow-md active:scale-95 transition-all">
                                    <i data-lucide="plus" class="w-4 h-4"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

<!-- Thanh thông báo giỏ hàng nhanh (Hiện phía trên thanh điều hướng nếu có món) -->
@if (Model.ActiveOrder != null && Model.ActiveOrder.Items.Any())
{
    var totalItemsCount = Model.ActiveOrder.Items.Sum(i => i.Quantity);
    <div class="fixed bottom-16 left-1/2 -translate-x-1/2 w-[90%] max-w-[390px] bg-slate-900/95 backdrop-blur-md text-white p-3 rounded-2xl shadow-xl flex items-center justify-between z-40 transition-transform duration-300 transform translate-y-0 border border-slate-800 animate-pulse">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-[#FF6B35] flex items-center justify-center font-black text-xs">
                @totalItemsCount
            </div>
            <div>
                <h5 class="text-xs font-bold">Giỏ hàng của bạn</h5>
                <p class="text-[10px] text-slate-400">Tạm tính: <span class="text-[#FF6B35] font-bold">@Model.ActiveOrder.TotalAmount.ToString("N0")₫</span></p>
            </div>
        </div>
        <a href="/Cart" class="px-4 py-1.5 bg-[#FF6B35] hover:bg-[#FF8552] text-xs font-bold rounded-xl transition-all shadow-md">
            Xem Giỏ Hàng
        </a>
    </div>
}
