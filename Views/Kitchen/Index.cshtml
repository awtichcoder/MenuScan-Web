@model KitchenDashboardViewModel
@{
    Layout = null; // Self-contained dashboard design for tablets/desktops (min-width: 1024px)
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Màn Hình Bếp - MenuScan</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #F8FAFC;
        }
    </style>
</head>
<body class="min-h-screen flex overflow-hidden">

    <!-- 1. Left Sidebar Component -->
    <aside class="w-64 bg-slate-900 text-white flex flex-col justify-between p-4 flex-shrink-0 border-r border-slate-800">
        <div class="space-y-8">
            <!-- Brand Logo -->
            <div class="flex items-center gap-3 px-2">
                <div class="w-9 h-9 rounded-xl bg-[#FF6B35] flex items-center justify-center font-black text-white text-base shadow-lg shadow-orange-500/20">MS</div>
                <div>
                    <h2 class="text-sm font-black tracking-wider">HADILAO</h2>
                    <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Khu Vực Bếp</span>
                </div>
            </div>

            <!-- Navigation Links -->
            <nav class="space-y-1.5">
                <a href="/Kitchen" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all bg-[#FF6B35] text-white">
                    <i data-lucide="layout-dashboard" class="w-4.5 h-4.5"></i>
                    <span>Hàng Đợi Chế Biến</span>
                </a>
                <a href="/Kitchen/Dishes" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold text-slate-400 hover:text-white hover:bg-slate-800 transition-all">
                    <i data-lucide="utensils" class="w-4.5 h-4.5"></i>
                    <span>Món Ăn Tạm Ẩn</span>
                </a>
            </nav>
        </div>

        <!-- Logout Action and User Profile -->
        <div class="space-y-4 border-t border-slate-800 pt-4">
            <div class="flex items-center gap-2.5 px-2">
                <div class="w-8 h-8 rounded-full bg-slate-700 flex items-center justify-center font-bold text-slate-300 text-xs">KC</div>
                <div>
                    <h5 class="text-xs font-bold text-slate-200 leading-none">Nhân Viên Bếp</h5>
                    <span class="text-[9px] text-emerald-500 font-semibold mt-1 inline-block">Đang hoạt động</span>
                </div>
            </div>
            
            <form asp-controller="Account" asp-action="Logout" method="POST">
                <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold text-slate-400 hover:text-rose-400 hover:bg-rose-950/20 transition-all">
                    <i data-lucide="log-out" class="w-4.5 h-4.5"></i>
                    <span>Đăng Xuất</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Right Board Content -->
    <div class="flex-grow flex flex-col overflow-hidden">
        
        <!-- 2. Header Component -->
        <header class="h-16 bg-white border-b border-slate-200 px-6 flex justify-between items-center flex-shrink-0">
            <div>
                <h1 class="text-lg font-extrabold text-slate-800">Bếp - MenuScan</h1>
                <p class="text-[10px] text-slate-400 font-medium">Bảng theo dõi và chế biến món ăn thời gian thực</p>
            </div>
            
            <div class="flex items-center gap-6">
                <!-- Clock -->
                <div class="text-right">
                    <div class="text-xs font-bold text-slate-700" id="liveClock">--:--:--</div>
                    <div class="text-[9px] text-slate-400 font-semibold uppercase">@DateTime.UtcNow.ToString("dd/MM/yyyy")</div>
                </div>
                
                <!-- Notification Bell Mock -->
                <button class="relative p-2 text-slate-500 hover:text-slate-800 hover:bg-slate-100 rounded-full transition-colors">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                    @if (Model.PendingCount > 0)
                    {
                        <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-[#FF6B35] rounded-full animate-ping"></span>
                    }
                </button>
            </div>
        </header>

        <!-- Main Scrollable Panel -->
        <main class="flex-grow overflow-y-auto p-6 space-y-6">

            <!-- 3. Summary KPI Cards Row -->
            <div class="grid grid-cols-4 gap-4">
                <!-- Pending -->
                <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div>
                        <span class="text-slate-400 text-xs font-bold uppercase tracking-wider block">Đang chờ</span>
                        <span class="text-2xl font-black text-amber-500 mt-1 block">@Model.PendingCount</span>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-amber-50 text-amber-500 flex items-center justify-center">
                        <i data-lucide="clock" class="w-5 h-5"></i>
                    </div>
                </div>
                
                <!-- Cooking -->
                <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div>
                        <span class="text-slate-400 text-xs font-bold uppercase tracking-wider block">Đang nấu</span>
                        <span class="text-2xl font-black text-blue-500 mt-1 block">@Model.CookingCount</span>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-500 flex items-center justify-center">
                        <i data-lucide="flame" class="w-5 h-5"></i>
                    </div>
                </div>

                <!-- Ready -->
                <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div>
                        <span class="text-slate-400 text-xs font-bold uppercase tracking-wider block">Hoàn thành</span>
                        <span class="text-2xl font-black text-emerald-500 mt-1 block">@Model.ReadyCount</span>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-500 flex items-center justify-center">
                        <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                    </div>
                </div>

                <!-- Delayed -->
                <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between">
                    <div>
                        <span class="text-slate-400 text-xs font-bold uppercase tracking-wider block">Bị Trễ (>5 Phút)</span>
                        <span class="text-2xl font-black text-rose-500 mt-1 block">@Model.DelayedCount</span>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-rose-50 text-rose-500 flex items-center justify-center">
                        <i data-lucide="alert-triangle" class="w-5 h-5"></i>
                    </div>
                </div>
            </div>

            <!-- 4. Search, Filter Chips, and View Group Toggle -->
            <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex items-center justify-between gap-4 flex-wrap">
                <!-- Search Box -->
                <form method="GET" action="/Kitchen" class="relative w-80">
                    <input type="hidden" name="filter" value="@Model.SelectedFilter" />
                    <input type="hidden" name="groupByCategory" value="@(Model.GroupByCategory ? "true" : "false")" />
                    <input type="text" name="search" value="@Model.SearchQuery" placeholder="Tìm số bàn, mã đơn, tên món..." 
                           class="w-full pl-9 pr-4 py-2 border border-slate-200 rounded-xl text-xs focus:outline-none focus:ring-1 focus:ring-[#FF6B35] focus:border-[#FF6B35] bg-slate-50" />
                    <i data-lucide="search" class="w-4 h-4 text-slate-400 absolute left-3 top-2.5"></i>
                </form>

                <!-- Filter Chips and Mode Select -->
                <div class="flex items-center gap-3">
                    <div class="flex items-center bg-slate-100 p-1 rounded-xl">
                        <a href="/Kitchen?filter=Active&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "true" : "false")" 
                           class="px-3.5 py-1.5 text-xs font-bold rounded-lg transition-all @(Model.SelectedFilter == "Active" ? "bg-white text-slate-800 shadow-sm" : "text-slate-400 hover:text-slate-600")">Tất Cả Hoạt Động</a>
                        <a href="/Kitchen?filter=Pending&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "true" : "false")" 
                           class="px-3.5 py-1.5 text-xs font-bold rounded-lg transition-all @(Model.SelectedFilter == "Pending" ? "bg-white text-slate-800 shadow-sm" : "text-slate-400 hover:text-slate-600")">Chờ Xác Nhận</a>
                        <a href="/Kitchen?filter=Cooking&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "true" : "false")" 
                           class="px-3.5 py-1.5 text-xs font-bold rounded-lg transition-all @(Model.SelectedFilter == "Cooking" ? "bg-white text-slate-800 shadow-sm" : "text-slate-400 hover:text-slate-600")">Đang Nấu</a>
                        <a href="/Kitchen?filter=Ready&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "true" : "false")" 
                           class="px-3.5 py-1.5 text-xs font-bold rounded-lg transition-all @(Model.SelectedFilter == "Ready" ? "bg-white text-slate-800 shadow-sm" : "text-slate-400 hover:text-slate-600")">Nấu Xong</a>
                        <a href="/Kitchen?filter=Delayed&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "true" : "false")" 
                           class="px-3.5 py-1.5 text-xs font-bold rounded-lg transition-all @(Model.SelectedFilter == "Delayed" ? "bg-white text-slate-800 shadow-sm" : "text-slate-400 hover:text-slate-600")">Bị Trễ</a>
                    </div>

                    <!-- Category Grouping Toggle -->
                    <a href="/Kitchen?filter=@Model.SelectedFilter&search=@Model.SearchQuery&groupByCategory=@(Model.GroupByCategory ? "false" : "true")" 
                       class="px-4 py-2 border rounded-xl text-xs font-bold flex items-center gap-1.5 transition-all @(Model.GroupByCategory ? "bg-slate-800 border-slate-800 text-white" : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50")">
                        <i data-lucide="folders" class="w-4 h-4"></i>
                        <span>Gom Món Theo Danh Mục</span>
                    </a>
                </div>
            </div>

            <!-- 5. Active Tickets Grid -->
            @if (!Model.ActiveOrders.Any())
            {
                <!-- Empty State -->
                <div class="bg-white rounded-3xl p-16 text-center border border-slate-200 shadow-sm space-y-4 max-w-lg mx-auto mt-8">
                    <div class="w-20 h-20 rounded-full bg-slate-100 flex items-center justify-center text-slate-300 mx-auto">
                        <i data-lucide="check-square" class="w-10 h-10"></i>
                    </div>
                    <div>
                        <h4 class="text-base font-bold text-slate-800">Hàng đợi đang trống!</h4>
                        <p class="text-xs text-slate-400 font-light mt-1">Các đơn hàng của khách hàng gửi qua quét mã QR sẽ tự động hiển thị ở đây theo thời gian thực.</p>
                    </div>
                </div>
            }
            else
            {
                if (!Model.GroupByCategory)
                {
                    <!-- Standard Ticket Grid (Normal View) -->
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                        @foreach (var order in Model.ActiveOrders)
                        {
                            var waitingMinutes = (DateTime.UtcNow - order.CreatedAt).TotalMinutes;
                            bool isDelayed = waitingMinutes >= 5;
                            string ticketBorder = isDelayed ? "border-rose-300 shadow-rose-100" : "border-slate-200 shadow-slate-100";
                            string ticketHeaderBg = isDelayed ? "bg-rose-50/50" : "bg-slate-50/30";

                            <div class="bg-white rounded-2xl border-2 @ticketBorder shadow-lg overflow-hidden flex flex-col justify-between transition-all duration-300">
                                <div>
                                    <!-- Card Header -->
                                    <div class="px-4 py-3.5 @ticketHeaderBg border-b border-slate-100 flex justify-between items-center">
                                        <div>
                                            <span class="inline-block px-3 py-1 bg-slate-800 text-white font-black text-sm rounded-lg">
                                                Bàn @order.TableNumber
                                            </span>
                                            <span class="text-[10px] font-bold text-slate-400 block mt-1">Mã đơn: ...@(order.Id?.Substring(Math.Max(0, order.Id.Length - 6)))</span>
                                        </div>
                                        <div class="text-right">
                                            <!-- Elapsed Timer widget -->
                                            <div class="flex items-center gap-1 text-xs font-black @(isDelayed ? "text-rose-500" : "text-slate-600")">
                                                <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                                                <span class="elapsed-timer" data-start="@order.CreatedAt.ToString("o")">00:00</span>
                                            </div>
                                            <span class="text-[9px] font-semibold text-slate-400">Đặt lúc @order.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                                        </div>
                                    </div>

                                    <!-- Alert Warning for delay -->
                                    @if (isDelayed && order.Status == "Pending")
                                    {
                                        <div class="bg-rose-50 border-b border-rose-100 px-4 py-2 flex items-center gap-2 text-rose-600 text-[10px] font-bold">
                                            <i data-lucide="alert-circle" class="w-3.5 h-3.5 animate-bounce"></i>
                                            <span>ĐƠN CHỜ QUÁ 5 PHÚT CHƯA XÁC NHẬN</span>
                                        </div>
                                    }

                                    <!-- Dish Items List -->
                                    <div class="p-4 divide-y divide-slate-100">
                                        @foreach (var item in order.Items)
                                        {
                                            <div class="py-2.5 space-y-1">
                                                <div class="flex justify-between items-start gap-2 text-xs">
                                                    <span class="font-extrabold text-[#FF6B35] text-sm">@item.Quantity ×</span>
                                                    <span class="font-extrabold text-slate-800 flex-grow">@item.DishName</span>
                                                </div>
                                                
                                                <!-- Size & Topping summary -->
                                                <div class="pl-8 text-[10px] text-slate-400 font-bold space-y-0.5">
                                                    <div>Kích cỡ: <span class="text-slate-600">@item.SelectedSize</span></div>
                                                    @if (item.SelectedToppings != null && item.SelectedToppings.Any())
                                                    {
                                                        <div>Món thêm: <span class="text-slate-600">@string.Join(", ", item.SelectedToppings)</span></div>
                                                    }
                                                    @if (!string.IsNullOrEmpty(item.CustomerNote))
                                                    {
                                                        <div class="italic text-rose-500 bg-rose-50 px-1.5 py-0.5 rounded mt-1 font-bold">
                                                            Ghi chú: @item.CustomerNote
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Card Footer Buttons -->
                                <div class="p-4 border-t border-slate-100 bg-slate-50/50 flex justify-between items-center gap-3">
                                    <div class="text-[10px] text-slate-400 font-bold">
                                        TỔNG MÓN: @order.Items.Sum(i => i.Quantity)
                                    </div>
                                    
                                    @if (order.Status == "Pending")
                                    {
                                        <button onclick="updateStatus('@order.Id', 'Cooking')" 
                                                class="flex-grow py-2.5 bg-amber-500 hover:bg-amber-600 text-white font-bold text-xs rounded-xl shadow-md shadow-amber-500/10 active:scale-95 transition-all text-center cursor-pointer">
                                            Nhận Đơn & Nấu
                                        </button>
                                    }
                                    else if (order.Status == "Cooking")
                                    {
                                        <button onclick="updateStatus('@order.Id', 'Ready')" 
                                                class="flex-grow py-2.5 bg-blue-500 hover:bg-blue-600 text-white font-bold text-xs rounded-xl shadow-md shadow-blue-500/10 active:scale-95 transition-all text-center cursor-pointer">
                                            Đã Nấu Xong
                                        </button>
                                    }
                                    else if (order.Status == "Ready")
                                    {
                                        <span class="inline-flex items-center gap-1 px-3 py-1.5 bg-emerald-50 text-emerald-600 text-[10px] font-bold rounded-lg border border-emerald-100">
                                            <i data-lucide="check-circle" class="w-3.5 h-3.5"></i>
                                            <span>Đang giao món...</span>
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- Grouped View (Group by Food Item / Category) -->
                    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-6">
                        <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                            <h3 class="text-sm font-extrabold text-slate-700 uppercase tracking-wider flex items-center gap-2">
                                <i data-lucide="folders" class="w-4.5 h-4.5 text-[#FF6B35]"></i>
                                Danh Sách Gom Món Chế Biến Tổng Hợp
                            </h3>
                            <span class="text-xs text-slate-400 font-bold">Số lượng gom món tổng quát</span>
                        </div>

                        <!-- Manual Aggregation & Rendering in Razor -->
                        @{
                            var allItems = Model.ActiveOrders
                                .Where(o => o.Status == "Pending" || o.Status == "Cooking")
                                .SelectMany(o => o.Items.Select(i => new { Order = o, Item = i }))
                                .GroupBy(x => new { x.Item.DishName, x.Item.SelectedSize })
                                .OrderByDescending(g => g.Sum(x => x.Item.Quantity));
                        }

                        @if (!allItems.Any())
                        {
                            <div class="text-center py-8 text-slate-400 text-xs">Không có món ăn nào đang chờ chế biến.</div>
                        }
                        else
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                @foreach (var group in allItems)
                                {
                                    <div class="p-4 border border-slate-100 rounded-2xl bg-slate-50/50 flex flex-col justify-between gap-3">
                                        <div class="flex justify-between items-start gap-4">
                                            <div class="min-w-0">
                                                <h4 class="text-sm font-bold text-slate-800 truncate">@group.Key.DishName</h4>
                                                <span class="text-[10px] text-slate-400 font-bold block mt-0.5">Kích cỡ: @group.Key.SelectedSize</span>
                                            </div>
                                            <!-- Massive Badge Count -->
                                            <span class="inline-flex w-9 h-9 items-center justify-center bg-[#FF6B35] text-white font-black text-base rounded-xl shadow-md shadow-orange-500/10">
                                                @group.Sum(x => x.Item.Quantity)
                                            </span>
                                        </div>

                                        <!-- Detailed Tickets list who ordered this -->
                                        <div class="space-y-1.5 mt-2">
                                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-wider">Yêu cầu từ các bàn:</span>
                                            <div class="flex flex-wrap gap-1.5">
                                                @foreach (var orderRef in group)
                                                {
                                                    <span class="px-2 py-1 bg-white border border-slate-200 text-slate-600 text-[10px] font-bold rounded-lg flex items-center gap-1 shadow-sm">
                                                        <span>Bàn @orderRef.Order.TableNumber</span>
                                                        <span class="text-slate-400">(x@orderRef.Item.Quantity)</span>
                                                        @if (orderRef.Order.Status == "Pending")
                                                        {
                                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
                                                        }
                                                        else
                                                        {
                                                            <span class="w-1.5 h-1.5 rounded-full bg-blue-500 inline-block animate-pulse"></span>
                                                        }
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }

        </main>
    </div>

    <!-- Clock & Polling Logic -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        lucide.createIcons();

        // 1. Live Clock
        function updateClock() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString('en-US', { hour12: false });
            document.getElementById('liveClock').innerText = timeStr;
        }
        setInterval(updateClock, 1000);
        updateClock();

        // 2. Stopwatch Timers for tickets
        function updateTimers() {
            document.querySelectorAll('.elapsed-timer').forEach(span => {
                const startTimeStr = span.dataset.start;
                if (!startTimeStr) return;
                
                const startTime = new Date(startTimeStr);
                const diffMs = new Date() - startTime;
                
                const totalSec = Math.max(0, Math.floor(diffMs / 1000));
                const mins = Math.floor(totalSec / 60);
                const secs = totalSec % 60;
                
                const formatMins = String(mins).padStart(2, '0');
                const formatSecs = String(secs).padStart(2, '0');
                
                span.innerText = `${formatMins}:${formatSecs}`;
                
                // Highlight red if exceeds 5 minutes
                if (mins >= 5) {
                    span.classList.add('text-rose-500');
                    const card = span.closest('.rounded-2xl');
                    if (card) {
                        card.classList.remove('border-slate-200', 'shadow-slate-100');
                        card.classList.add('border-rose-400', 'shadow-rose-100');
                    }
                }
            });
        }
        setInterval(updateTimers, 1000);
        updateTimers();

        // 3. Status Update POST Request via AJAX
        async function updateStatus(orderId, nextStatus) {
            try {
                const formData = new FormData();
                formData.append('orderId', orderId);
                formData.append('newStatus', nextStatus);

                const response = await fetch('/Kitchen/UpdateStatus', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        title: 'Thành công!',
                        text: 'Cập nhật trạng thái chế biến thành công.',
                        icon: 'success',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 2000
                    });
                    
                    setTimeout(() => {
                        window.location.reload();
                    }, 800);
                } else {
                    Swal.fire({
                        title: 'Lỗi',
                        text: result.message,
                        icon: 'error',
                        confirmButtonColor: '#FF6B35'
                    });
                }
            } catch (err) {
                console.error(err);
                Swal.fire({
                    title: 'Lỗi',
                    text: 'Không thể cập nhật trạng thái đơn hàng.',
                    icon: 'error',
                    confirmButtonColor: '#FF6B35'
                });
            }
        }

        // 4. Live reload queue polling every 10 seconds to fetch new customer tickets
        setInterval(async () => {
            try {
                const response = await fetch(window.location.href);
                const htmlText = await response.text();
                const parser = new DOMParser();
                const newDoc = parser.parseFromString(htmlText, 'text/html');
                
                document.querySelector('main').innerHTML = newDoc.querySelector('main').innerHTML;
                document.querySelector('header').innerHTML = newDoc.querySelector('header').innerHTML;
                
                lucide.createIcons();
                updateTimers();
            } catch (err) {
                console.error("Lỗi cập nhật hàng đợi chế biến", err);
            }
        }, 10000);
    </script>
</body>
</html>
