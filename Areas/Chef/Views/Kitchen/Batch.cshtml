@model List<MenuQr.Areas.Chef.Controllers.BatchGroupViewModel>
@{
    ViewData["Title"] = "Gom món Thông Minh";
}

<div class="h-full flex flex-col p-6 overflow-hidden bg-gray-50">
    <!-- Header Banner -->
    <div class="flex flex-wrap gap-4 justify-between items-center mb-6 shrink-0 bg-white border border-gray-200 p-4 rounded-2xl shadow-sm">
        <div>
            <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-orange-500"></i>
                GOM MÓN CHẾ BIẾN THÔNG MINH
            </h2>
            <p class="text-xs text-gray-400">Gom nhóm tự động các món giống nhau từ các bàn khác nhau để chế biến hàng loạt.</p>
        </div>

        <!-- Quick Search -->
        <div class="relative w-full sm:w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-gray-400">
                <i class="fa-solid fa-magnifying-glass text-xs"></i>
            </span>
            <input type="text" id="batch-search" onkeyup="filterBatchDishes()" placeholder="Tìm kiếm món ăn..."
                   class="w-full pl-9 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-xl text-gray-850 placeholder-gray-400 text-xs font-semibold focus:outline-none focus:border-[#F3C178] focus:ring-1 focus:ring-[#F3C178] transition-all" />
        </div>
    </div>

    <!-- Batch Grid -->
    <div class="flex-1 overflow-y-auto pr-1">
        @if (Model == null || !Model.Any())
        {
            <div class="h-full min-h-[300px] flex flex-col items-center justify-center border-2 border-dashed border-gray-250 rounded-2xl p-12 text-center text-gray-400 bg-white shadow-sm">
                <div class="w-16 h-16 bg-gray-50 text-gray-300 rounded-2xl flex items-center justify-center mb-4 border border-gray-100">
                    <i class="fa-solid fa-box-open text-3xl"></i>
                </div>
                <h3 class="text-lg font-bold text-gray-700">Không có món cần gom chế biến</h3>
                <p class="text-sm text-gray-400 max-w-xs mt-1">Khi khách hàng ở các bàn tiến hành gửi đơn báo bếp, các món chưa nấu sẽ xuất hiện tại đây.</p>
            </div>
        }
        else
        {
            <div id="batch-items-container" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var item in Model)
                {
                    <div class="batch-item-card bg-white border border-gray-200 rounded-2xl p-5 shadow-sm flex flex-col transition-all duration-200 hover:-translate-y-0.5 hover:border-gray-350 hover:shadow-md" 
                          data-dish-name="@item.DishName.ToLower()">
                        
                        <!-- Header / Title -->
                        <div class="flex justify-between items-start gap-3 border-b border-gray-150 pb-3 mb-3.5">
                            <div>
                                <h3 class="font-extrabold text-gray-800 text-lg leading-tight">@item.DishName</h3>
                                <div class="mt-1">
                                    <span class="bg-gray-50 text-gray-500 text-xs font-semibold px-2 py-0.5 rounded border border-gray-200 font-mono">
                                        @item.OptionsText
                                    </span>
                                </div>
                            </div>
                            <div class="bg-gradient-to-tr from-orange-500 to-amber-400 text-white rounded-xl py-2 px-3 flex flex-col items-center justify-center min-w-[64px] shadow-sm shadow-orange-100">
                                <span class="text-[9px] font-black uppercase tracking-wider opacity-90 leading-none mb-0.5">TỔNG</span>
                                <span class="text-2xl font-black leading-none">@item.TotalQuantity</span>
                            </div>
                        </div>

                        <!-- Table breakdowns -->
                        <div class="flex-1 flex flex-col gap-2">
                            <span class="text-[10px] text-gray-400 font-extrabold uppercase tracking-wider mb-0.5">Chi tiết phân bổ tại các bàn:</span>
                            @foreach (var table in item.TableDetails)
                            {
                                <div class="bg-gray-50 border border-gray-200/60 p-3 rounded-xl flex justify-between items-center text-xs">
                                    <div class="flex items-center gap-2">
                                        <div class="w-2.5 h-2.5 bg-orange-500 rounded-full animate-pulse"></div>
                                        <span class="font-bold text-gray-700">BÀN @table.TableNumber</span>
                                    </div>
                                    <div class="flex items-center gap-4">
                                        @if (!string.IsNullOrEmpty(table.Note))
                                        {
                                            <span class="text-orange-700 text-[10px] font-bold px-2 py-0.5 rounded bg-orange-50 border border-orange-200 max-w-[120px] truncate" title="@table.Note">
                                                <i class="fa-solid fa-message mr-1"></i> @table.Note
                                            </span>
                                        }
                                        <span class="text-gray-400 text-[10px] font-mono">@table.OrderedAt.ToString("HH:mm")</span>
                                        <span class="bg-white border border-gray-200 text-gray-800 px-2.5 py-1 rounded-md font-extrabold text-sm min-w-[32px] text-center shadow-sm">
                                            x@(table.Quantity)
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<script>
    // Real-time synchronization callback via SignalR
    async function refreshQueueData() {
        console.log("Refreshing batch groupings...");
        // Since this page is simpler, reloading the window works perfectly.
        // In premium style, let's fetch and update only the container.
        try {
            const res = await fetch(window.location.href);
            if (!res.ok) return;
            const text = await res.text();
            
            const parser = new DOMParser();
            const doc = parser.parseFromString(text, 'text/html');
            
            const newContainer = doc.getElementById('batch-items-container');
            const oldContainer = document.getElementById('batch-items-container');
            
            if (newContainer && oldContainer) {
                oldContainer.innerHTML = newContainer.innerHTML;
            } else if (newContainer && !oldContainer) {
                // If previously empty, full reload to draw correct grid container layout
                window.location.reload();
            } else if (!newContainer && oldContainer) {
                window.location.reload();
            }
        } catch (e) {
            console.error("Lỗi cập nhật: ", e);
        }
    }

    // Filter dishes based on search input
    function filterBatchDishes() {
        const query = document.getElementById('batch-search').value.toLowerCase().trim();
        const cards = document.querySelectorAll('.batch-item-card');

        cards.forEach(card => {
            const dishName = card.getAttribute('data-dish-name') || '';
            if (dishName.includes(query)) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    }
</script>
