@model List<MenuQr.Areas.Chef.Controllers.BatchGroupViewModel>
@{
    ViewData["Title"] = "Gom món theo danh mục";
    var categories = ViewBag.Categories as List<MenuQr.Areas.Admin.Models.Category> ?? new List<MenuQr.Areas.Admin.Models.Category>();
}

<div class="h-full flex flex-col p-6 overflow-hidden bg-gray-50">
    
    <!-- Header Block (Form title & Category checklist) -->
    <div class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mb-6 shrink-0">
        <!-- Document Title -->
        <div class="text-center pb-5 border-b border-gray-150">
            <p class="text-xs font-mono font-bold text-gray-400 tracking-wider">BM07: Phiếu Gom món theo danh mục</p>
            <h2 class="text-2xl font-black text-gray-800 tracking-wider mt-1">PHIẾU GOM MÓN THEO DANH MỤC</h2>
        </div>
        
        <!-- Form Fields Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 pt-5 text-sm text-gray-700 items-center">
            <!-- Gather Categories list -->
            <div class="lg:col-span-2 flex flex-wrap items-center gap-3">
                <span class="font-bold text-gray-500 uppercase text-xs tracking-wider">Danh mục gom:</span>
                <div class="flex flex-wrap gap-4 items-center bg-gray-50 px-4 py-2.5 rounded-xl border border-gray-200">
                    <label class="flex items-center gap-1.5 cursor-pointer font-bold select-none text-gray-700">
                        <input type="checkbox" id="cat-all" checked onchange="onCategorySelectAll(this)" class="w-4 h-4 rounded text-orange-600 focus:ring-orange-500 border-gray-300">
                        Tất cả
                    </label>
                    <div class="w-px h-4 bg-gray-300 mx-1"></div>
                    @foreach (var cat in categories)
                    {
                        <label class="flex items-center gap-1.5 cursor-pointer font-bold select-none text-gray-650 hover:text-gray-900 transition-colors">
                            <input type="checkbox" name="cat-filter" value="@cat.Id" checked onchange="onCategorySelect(this)" class="w-4 h-4 rounded text-orange-600 focus:ring-orange-500 border-gray-300">
                            @cat.Name
                        </label>
                    }
                </div>
            </div>

            <!-- Time field -->
            <div class="flex items-center gap-3 lg:justify-end">
                <span class="font-bold text-gray-500 uppercase text-xs tracking-wider">Thời gian gom:</span>
                <span id="batch-time" class="font-mono bg-orange-50 border border-orange-200 text-orange-700 px-4 py-2 rounded-xl font-extrabold text-sm shadow-sm">
                    ... : ...
                </span>
            </div>
        </div>
    </div>

    <!-- Quick Search Row -->
    <div class="flex justify-between items-center mb-4 shrink-0">
        <span class="text-xs text-gray-400 font-semibold" id="table-summary-desc">Hiển thị danh sách món đang chờ...</span>
        <div class="relative w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <i class="fa-solid fa-magnifying-glass text-xs"></i>
            </span>
            <input type="text" id="batch-search" onkeyup="renderTable()" placeholder="Tìm kiếm món ăn chi tiết..."
                   class="w-full pl-8.5 pr-4 py-2 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 text-xs font-semibold focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all shadow-sm" />
        </div>
    </div>

    <!-- Tabular Form Container -->
    <div class="flex-1 overflow-y-auto bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden flex flex-col">
        <table class="w-full border-collapse text-left flex-1">
            <!-- Yellow Header Row with red text matching document -->
            <thead>
                <tr class="bg-yellow-300 border-b border-gray-250 select-none">
                    <th class="px-5 py-4 text-center text-[#d32f2f] font-black text-xs uppercase tracking-wider w-[80px]">STT</th>
                    <th class="px-5 py-4 text-left text-[#d32f2f] font-black text-xs uppercase tracking-wider">Tên Món Chi Tiết</th>
                    <th class="px-5 py-4 text-left text-[#d32f2f] font-black text-xs uppercase tracking-wider">Danh sách bàn (Số lượng)</th>
                    <th class="px-5 py-4 text-center text-[#d32f2f] font-black text-xs uppercase tracking-wider w-[140px]">Tổng số lượng</th>
                </tr>
            </thead>
            <tbody id="batch-table-body" class="divide-y divide-gray-200">
                <!-- Table rows will render dynamically via JS -->
            </tbody>
            <!-- Footer row spanning totals -->
            <tfoot>
                <tr class="bg-gray-50 border-t-2 border-gray-250 text-gray-800 font-bold select-none shrink-0">
                    <td class="px-5 py-5 text-left font-black text-sm uppercase" colspan="2">TỔNG CỘNG</td>
                    <td class="px-5 py-5 text-right font-extrabold text-xs tracking-wide uppercase text-gray-500" colspan="2">
                        SỐ LƯỢNG MÓN CẦN CHẾ BIẾN TRONG ĐỢT: 
                        <span id="total-sum" class="text-2xl font-black text-[#d32f2f] font-mono mx-1.5 animate-pulse">0</span> món
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<script>
    // Local data storage for reactive UI updates
    let rawBatchData = [];

    // Trigger update of time when page loads
    function updateGomTime() {
        const now = new Date();
        const hrs = now.getHours().toString().padStart(2, '0');
        const mins = now.getMinutes().toString().padStart(2, '0');
        document.getElementById('batch-time').innerText = `${hrs}:${mins}`;
    }

    // Category filter interactions
    function onCategorySelectAll(allCb) {
        const checkboxes = document.querySelectorAll('input[name="cat-filter"]');
        checkboxes.forEach(cb => {
            cb.checked = allCb.checked;
        });
        renderTable();
    }

    function onCategorySelect(cb) {
        const allCb = document.getElementById('cat-all');
        const checkboxes = document.querySelectorAll('input[name="cat-filter"]');
        const checkedCount = Array.from(checkboxes).filter(c => c.checked).length;

        if (checkedCount === checkboxes.length) {
            allCb.checked = true;
            allCb.indeterminate = false;
        } else if (checkedCount === 0) {
            allCb.checked = false;
            allCb.indeterminate = false;
        } else {
            allCb.checked = false;
            allCb.indeterminate = true;
        }
        renderTable();
    }

    // Dynamic renderer to keep STT numbers sequential and compute total count
    function renderTable() {
        const tbody = document.getElementById('batch-table-body');
        const selectedCategories = Array.from(document.querySelectorAll('input[name="cat-filter"]:checked')).map(cb => cb.value);
        const query = document.getElementById('batch-search').value.toLowerCase().trim();
        
        let html = '';
        let stt = 1;
        let grandTotal = 0;

        rawBatchData.forEach(item => {
            const matchCategory = selectedCategories.includes(item.categoryId);
            const matchSearch = item.dishName.toLowerCase().includes(query);

            if (matchCategory && matchSearch) {
                // Table Allocations formatting e.g. Bàn 03 (x1), Bàn 05 (x2)
                const tableListText = item.tableDetails.map(t => {
                    let noteText = t.note ? ` [Ghi chú: ${t.note}]` : '';
                    return `Bàn ${t.tableNumber} (x${t.quantity})${noteText}`;
                }).join(', ');

                const optionsSubText = item.optionsText && item.optionsText !== 'Mặc định' 
                    ? `<div class="text-xs text-gray-400 font-semibold italic mt-1"><i class="fa-solid fa-circle-info text-[9px] mr-1"></i>${item.optionsText}</div>` 
                    : '';

                html += `
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-5 py-4 text-center font-mono font-bold text-gray-500">${stt}</td>
                        <td class="px-5 py-4 font-extrabold text-gray-800 text-sm">
                            ${escapeHtml(item.dishName)}
                            ${optionsSubText}
                        </td>
                        <td class="px-5 py-4 text-gray-600 text-xs font-semibold leading-relaxed">${escapeHtml(tableListText)}</td>
                        <td class="px-5 py-4 text-center font-extrabold text-base text-gray-900 font-mono">${item.totalQuantity}</td>
                    </tr>
                `;
                stt++;
                grandTotal += item.totalQuantity;
            }
        });

        tbody.innerHTML = html || `
            <tr>
                <td colspan="4" class="px-5 py-16 text-center text-gray-400 font-semibold bg-gray-50/20">
                    <i class="fa-solid fa-box-open text-4xl mb-3 block opacity-25 text-gray-300"></i>
                    Không có món ăn chờ chế biến phù hợp.
                </td>
            </tr>
        `;

        document.getElementById('total-sum').innerText = grandTotal;
        document.getElementById('table-summary-desc').innerText = `Tìm thấy ${stt - 1} loại món cần nấu (Tổng cộng ${grandTotal} phần ăn).`;
    }

    // Real-time synchronization callback via SignalR
    async function refreshQueueData() {
        console.log("Synchronizing batch groupings data...");
        try {
            const res = await fetch(window.location.href);
            if (!res.ok) return;
            const text = await res.text();
            
            const parser = new DOMParser();
            const doc = parser.parseFromString(text, 'text/html');
            
            const dataJson = doc.getElementById('batch-data-json');
            if (dataJson) {
                rawBatchData = JSON.parse(dataJson.textContent);
                renderTable();
                updateGomTime();
            }
        } catch (e) {
            console.error("Lỗi cập nhật: ", e);
        }
    }

    // Utility escape HTML
    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Initialize page
    document.addEventListener("DOMContentLoaded", () => {
        const dataJson = document.getElementById('batch-data-json');
        if (dataJson) {
            rawBatchData = JSON.parse(dataJson.textContent);
            renderTable();
        }
        updateGomTime();
    });
</script>

<!-- Embedded JSON Data representation for client-side processing -->
<script type="application/json" id="batch-data-json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
</script>
