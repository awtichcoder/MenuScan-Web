@model List<MenuQr.Areas.Chef.Controllers.BatchGroupViewModel>
@{
    ViewData["Title"] = "Gom món theo danh mục";
    var categories = ViewBag.Categories as List<MenuQr.Areas.Admin.Models.Category> ?? new List<MenuQr.Areas.Admin.Models.Category>();
}

<div class="h-full flex flex-col p-6 overflow-hidden bg-gray-50">
    
    <!-- Top Control Bar (Title, Categories & Time) -->
    <div class="flex flex-col bg-white border border-gray-200 rounded-2xl p-5 shadow-sm mb-6 shrink-0 gap-4">
        <div>
            <h2 class="text-lg font-black text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-layer-group text-orange-500"></i>
                GOM MÓN CHẾ BIẾN THEO DANH MỤC
            </h2>
            <p class="text-xs text-gray-400 mt-0.5">Tự động gom nhóm các món cùng loại theo danh mục để chuẩn bị nguyên liệu và nấu hàng loạt hiệu quả.</p>
        </div>
        
        <!-- Filter Row -->
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 pt-4 border-t border-gray-100">
            <!-- Dynamic Category Filter Pills -->
            <div class="flex flex-col gap-2 flex-1">
                <span class="font-bold text-gray-400 uppercase text-[10px] tracking-wider">Danh mục gom món:</span>
                <div class="flex flex-wrap gap-2 items-center">
                    <button type="button" id="cat-pill-all" onclick="toggleAllCategories()" 
                            class="px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-orange-500 text-white border-orange-500 active:scale-95 flex items-center gap-1.5">
                        Tất cả
                        <span id="cat-badge-all" class="bg-white/20 text-white rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono">0</span>
                    </button>
                    <div class="w-px h-5 bg-gray-200 mx-1 hidden sm:block"></div>
                    @foreach (var cat in categories)
                    {
                        <button type="button" id="cat-pill-@cat.Id" onclick="toggleCategory('@cat.Id')" 
                                class="cat-pill px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-white text-gray-650 border-gray-250 hover:bg-gray-50 active:scale-95 flex items-center gap-1.5">
                            @cat.Name
                            <span id="cat-badge-@cat.Id" class="bg-gray-100 text-gray-400 rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono">0</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Time Stamp -->
            <div class="flex items-center gap-2 self-start lg:self-end">
                <i class="fa-regular fa-clock text-orange-500 text-sm"></i>
                <span class="font-bold text-gray-400 uppercase text-[10px] tracking-wider">Thời gian gom:</span>
                <span id="batch-time" class="font-mono bg-orange-50 border border-orange-100 text-orange-650 px-3.5 py-1.5 rounded-xl font-black text-xs shadow-sm">
                    ... : ...
                </span>
            </div>
        </div>
    </div>

    <!-- Quick Search & Stats Summary -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-4 shrink-0">
        <span class="text-xs text-gray-400 font-bold" id="table-summary-desc">Đang tải danh sách...</span>
        <div class="relative w-full sm:w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-gray-400">
                <i class="fa-solid fa-magnifying-glass text-xs"></i>
            </span>
            <input type="text" id="batch-search" onkeyup="renderTable()" placeholder="Tìm kiếm món ăn..."
                   class="w-full pl-9 pr-4 py-2 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 text-xs font-semibold focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-all shadow-sm" />
        </div>
    </div>

    <!-- Slips Container for Category Groups -->
    <div id="batch-slips-container" class="flex-1 overflow-y-auto pr-1">
        <!-- Separate category tables (BM07 style slips) will render dynamically here -->
    </div>

    <!-- Grand Total Summary Bar at the bottom -->
    <div class="bg-gradient-to-r from-orange-500 to-amber-500 rounded-2xl p-5 shadow-lg shadow-orange-500/10 mt-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 shrink-0 select-none text-white">
        <span class="text-sm font-black uppercase tracking-wider flex items-center gap-2">
            <i class="fa-solid fa-fire-burner text-lg animate-bounce"></i>
            TỔNG SỐ LƯỢNG MÓN CẦN CHẾ BIẾN TRONG ĐỢT
        </span>
        <div class="flex items-center gap-2 self-end sm:self-auto">
            <span class="text-xs font-extrabold opacity-90 uppercase">TỔNG CỘNG:</span>
            <span id="total-sum" class="bg-white text-orange-600 rounded-xl px-4 py-1.5 text-2xl font-black font-mono shadow-md">0</span>
            <span class="text-xs font-extrabold uppercase">phần ăn</span>
        </div>
    </div>
</div>

<script>
    // Local data storage for reactive UI updates
    let rawBatchData = [];
    
    // Initialise category pills
    const allCategoryIds = [@Html.Raw(string.Join(",", categories.Select(c => $"'{c.Id}'")))];
    let activeCategories = [...allCategoryIds]; // Copy initially all selected

    // Dictionary to look up Category Name by ID
    const categoriesMap = {
        @Html.Raw(string.Join(",", categories.Select(c => $"'{c.Id}': '{c.Name.Replace("'", "\\'")}'")))
    };

    // Trigger update of time when page loads
    function updateGomTime() {
        const now = new Date();
        const hrs = now.getHours().toString().padStart(2, '0');
        const mins = now.getMinutes().toString().padStart(2, '0');
        document.getElementById('batch-time').innerText = `${hrs}:${mins}`;
    }

    // Toggle all categories pill button
    function toggleAllCategories() {
        const allBtn = document.getElementById('cat-pill-all');
        const isAllSelected = activeCategories.length === allCategoryIds.length;

        if (isAllSelected) {
            activeCategories = []; // Clear
        } else {
            activeCategories = [...allCategoryIds]; // Select all
        }

        updatePillsUI();
        renderTable();
    }

    // Toggle individual category pill button
    function toggleCategory(catId) {
        const idx = activeCategories.indexOf(catId);
        if (idx > -1) {
            activeCategories.splice(idx, 1);
        } else {
            activeCategories.push(catId);
        }

        updatePillsUI();
        renderTable();
    }

    // Dynamic UI styling update for pills and category counts
    function updatePillsUI() {
        const allBtn = document.getElementById('cat-pill-all');
        const allBadge = document.getElementById('cat-badge-all');
        const isAllSelected = activeCategories.length === allCategoryIds.length;

        // Compute counts based on rawBatchData
        const counts = {};
        let grandTotal = 0;
        allCategoryIds.forEach(id => {
            counts[id] = 0;
        });
        rawBatchData.forEach(item => {
            if (counts[item.categoryId] !== undefined) {
                counts[item.categoryId] += item.totalQuantity;
            }
            grandTotal += item.totalQuantity;
        });

        // Style "Tất cả" pill
        if (isAllSelected) {
            allBtn.className = "px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-orange-500 text-white border-orange-500 active:scale-95 flex items-center gap-1.5";
            if (allBadge) {
                allBadge.innerText = grandTotal;
                allBadge.className = "bg-white/20 text-white rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono";
            }
        } else {
            allBtn.className = "px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-white text-gray-500 border-gray-250 hover:bg-gray-50 hover:text-gray-800 active:scale-95 flex items-center gap-1.5";
            if (allBadge) {
                allBadge.innerText = grandTotal;
                allBadge.className = "bg-gray-100 text-gray-400 rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono";
            }
        }

        allCategoryIds.forEach(id => {
            const pill = document.getElementById(`cat-pill-${id}`);
            const badge = document.getElementById(`cat-badge-${id}`);
            if (!pill) return;

            const count = counts[id] || 0;
            if (badge) {
                badge.innerText = count;
            }

            const isSelected = activeCategories.includes(id);
            if (isSelected) {
                pill.className = "cat-pill px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-orange-50 text-orange-655 border-orange-200 hover:bg-orange-100 active:scale-95 flex items-center gap-1.5";
                if (badge) {
                    badge.className = "bg-orange-200/60 text-orange-700 rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono";
                }
            } else {
                pill.className = "cat-pill px-4 py-1.5 rounded-xl border text-xs font-bold transition-all shadow-sm bg-white text-gray-650 border-gray-250 hover:bg-gray-50 hover:text-gray-800 active:scale-95 flex items-center gap-1.5";
                if (badge) {
                    badge.className = "bg-gray-100 text-gray-400 rounded-md px-1.5 py-0.5 text-[9px] font-black font-mono";
                }
            }
        });
    }

    // Dynamic renderer to keep STT numbers sequential and compute total count
    function renderTable() {
        const container = document.getElementById('batch-slips-container');
        const query = document.getElementById('batch-search').value.toLowerCase().trim();
        
        // Group rawBatchData by categoryId
        const groups = {};
        rawBatchData.forEach(item => {
            const matchCategory = activeCategories.includes(item.categoryId);
            const matchSearch = item.dishName.toLowerCase().includes(query);

            if (matchCategory && matchSearch) {
                if (!groups[item.categoryId]) {
                    groups[item.categoryId] = [];
                }
                groups[item.categoryId].push(item);
            }
        });

        let slipsHtml = '';
        let grandTotal = 0;
        let totalCategoriesCount = 0;

        // Loop through categories to preserve sorted order
        allCategoryIds.forEach(catId => {
            const items = groups[catId];
            if (!items || items.length === 0) return;

            totalCategoriesCount++;
            const categoryName = categoriesMap[catId] || 'Danh mục khác';
            let categoryTotal = 0;
            let rowsHtml = '';
            let stt = 1;

            items.forEach(item => {
                // Table chips formatting (Modern pill tags)
                const tableChips = item.tableDetails.map(t => {
                    let noteText = t.note 
                        ? ` <span class="text-orange-700 bg-orange-50 border border-orange-200/50 rounded px-1.5 py-0.5 text-[9px] font-bold inline-flex items-center gap-1 ml-1"><i class="fa-solid fa-message text-[8px]"></i>${t.note}</span>` 
                        : '';
                    const orderIdShort = t.orderId && t.orderId.length > 6 ? t.orderId.substring(t.orderId.length - 6).toUpperCase() : (t.orderId || '');
                    const orderIdHtml = orderIdShort ? `<span class="text-[9px] text-gray-400 font-mono font-bold ml-1" title="Mã đơn: ${t.orderId}">#${orderIdShort}</span>` : '';
                    return `
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-gray-50 border border-gray-200 text-xs font-semibold text-gray-700 shadow-sm hover:border-gray-300 transition-colors">
                            <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                            BÀN ${t.tableNumber} ${orderIdHtml}
                            <strong class="text-orange-600 font-black ml-0.5">x${t.quantity}</strong>
                            ${noteText}
                        </span>
                    `;
                }).join('');

                const tableListHtml = `<div class="flex flex-wrap gap-2">${tableChips}</div>`;

                const optionsSubText = item.optionsText && item.optionsText !== 'Mặc định' 
                    ? `<div class="text-xs text-gray-400 font-semibold italic mt-1"><i class="fa-solid fa-circle-info text-[9px] mr-1"></i>${item.optionsText}</div>` 
                    : '';

                rowsHtml += `
                    <tr class="hover:bg-gray-50/40 transition-colors bg-white">
                        <td class="px-6 py-4 text-center">
                            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 text-gray-500 font-mono text-xs font-bold">${stt}</span>
                        </td>
                        <td class="px-6 py-4 font-extrabold text-gray-800 text-sm">
                            ${escapeHtml(item.dishName)}
                            ${optionsSubText}
                        </td>
                        <td class="px-6 py-4">${tableListHtml}</td>
                        <td class="px-6 py-4 text-center">
                            <div class="flex justify-center">
                                <span class="w-9 h-9 rounded-full bg-orange-50 border border-orange-100 text-orange-600 font-black text-center flex items-center justify-center text-sm shadow-sm font-mono">${item.totalQuantity}</span>
                            </div>
                        </td>
                    </tr>
                `;
                stt++;
                categoryTotal += item.totalQuantity;
            });

            grandTotal += categoryTotal;

            slipsHtml += `
                <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden flex flex-col mb-8 last:mb-0">
                    <!-- Slip Header -->
                    <div class="bg-gray-50 border-b border-gray-200 px-6 py-4 flex justify-between items-center select-none">
                        <h3 class="font-extrabold text-gray-800 text-sm tracking-wider uppercase flex items-center gap-2">
                            <i class="fa-solid fa-receipt text-orange-500 text-base"></i>
                            DANH MỤC: ${escapeHtml(categoryName)}
                        </h3>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-orange-500 text-white font-extrabold text-xs shadow-md shadow-orange-500/10 select-none">
                            <i class="fa-solid fa-fire text-[10px] animate-pulse"></i>
                            CẦN CHẾ BIẾN:
                            <span class="bg-white text-orange-600 rounded-lg px-2 py-0.5 text-xs font-black font-mono shadow-sm">${categoryTotal}</span>
                        </span>
                    </div>
                    
                    <!-- Slip Table -->
                    <table class="w-full border-collapse text-left">
                        <thead>
                            <tr class="bg-yellow-300 border-b border-gray-250 select-none">
                                <th class="px-6 py-3.5 text-center text-[#d32f2f] font-black text-xs uppercase tracking-wider w-[80px]">STT</th>
                                <th class="px-6 py-3.5 text-left text-[#d32f2f] font-black text-xs uppercase tracking-wider">Tên Món Chi Tiết</th>
                                <th class="px-6 py-3.5 text-left text-[#d32f2f] font-black text-xs uppercase tracking-wider">Danh sách bàn (Số lượng)</th>
                                <th class="px-6 py-3.5 text-center text-[#d32f2f] font-black text-xs uppercase tracking-wider w-[160px]">Tổng số lượng</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-150">
                            ${rowsHtml}
                        </tbody>
                    </table>
                </div>
            `;
        });

        container.innerHTML = slipsHtml || `
            <div class="bg-white border border-gray-200 rounded-2xl p-16 text-center text-gray-400 font-bold shadow-sm">
                <i class="fa-solid fa-box-open text-4xl mb-3 block opacity-25 text-gray-300"></i>
                Không có món ăn nào cần chế biến.
            </div>
        `;

        document.getElementById('total-sum').innerText = grandTotal;
        document.getElementById('table-summary-desc').innerText = `Tìm thấy ${totalCategoriesCount} danh mục có món cần nấu (Tổng cộng ${grandTotal} phần ăn).`;
    }

    // Real-time synchronization callback via SignalR
    async function refreshQueueData() {
        console.log("Synchronizing batch groupings data...");
        try {
            const res = await fetch(window.location.href);
            if (!res.ok) return;
            const text = await res.text();
            
            const parser = new DOMParser();
            const doc = parser.parseFromString(text, 'text/html');
            
            const dataJson = doc.getElementById('batch-data-json');
            if (dataJson) {
                rawBatchData = JSON.parse(dataJson.textContent);
                renderTable();
                updateGomTime();
                updatePillsUI();
            }
        } catch (e) {
            console.error("Lỗi cập nhật: ", e);
        }
    }

    // Utility escape HTML
    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Initialize page
    document.addEventListener("DOMContentLoaded", () => {
        const dataJson = document.getElementById('batch-data-json');
        if (dataJson) {
            rawBatchData = JSON.parse(dataJson.textContent);
            renderTable();
        }
        updateGomTime();
        updatePillsUI();
    });
</script>

<!-- Embedded JSON Data representation for client-side processing -->
<script type="application/json" id="batch-data-json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
</script>
