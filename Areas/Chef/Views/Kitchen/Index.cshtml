@model List<MenuQr.Areas.Chef.Controllers.KitchenQueueItemViewModel>
@{
    ViewData["Title"] = "Hàng đợi Chế Biến";
}

<!-- Audio Unlock Overlay to satisfy browser autoplay policies -->
<div id="kitchen-audio-overlay" class="fixed inset-0 z-[10000] bg-gray-900/55 backdrop-blur-sm flex items-center justify-center transition-all duration-500">
    <div class="bg-white border border-gray-150 p-8 rounded-3xl text-center max-w-md mx-auto shadow-2xl relative">
        <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-gradient-to-tr from-orange-500 to-amber-400 rounded-3xl flex items-center justify-center text-white shadow-lg shadow-orange-200/50">
            <i class="fa-solid fa-volume-high text-3xl animate-bounce"></i>
        </div>
        <h3 class="text-2xl font-black text-gray-800 mt-8 mb-3">Vào Ca Làm Việc Bếp</h3>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">Vui lòng bấm nút phía dưới để kích hoạt âm thanh thông báo. Hệ thống sẽ phát âm thanh cảnh báo khi có món mới hoặc khi món bị trễ quá 5 phút.</p>
        <button onclick="unlockKitchenAudio()" class="w-full bg-gradient-to-r from-orange-500 to-amber-400 hover:from-orange-600 hover:to-amber-500 text-white font-bold py-4 rounded-2xl shadow-lg shadow-orange-100 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
            <i class="fa-solid fa-play"></i> Xác nhận & Bắt đầu
        </button>
    </div>
</div>

<div class="h-full flex flex-col p-6 overflow-hidden bg-gray-50">
    <!-- Stats Banner -->
    <div class="flex flex-wrap gap-4 justify-between items-center mb-6 shrink-0 bg-white border border-gray-200 p-4 rounded-2xl shadow-sm">
        <div>
            <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                <i class="fa-solid fa-rectangle-list text-orange-500"></i>
                BẢNG ĐIỀU PHỐI CHẾ BIẾN
            </h2>
            <p class="text-xs text-gray-400">Xem và quản lý quy trình nấu ăn theo thời gian thực.</p>
        </div>
        <div class="flex gap-4">
            <div class="bg-gray-50 px-4 py-2 rounded-xl border border-gray-200 flex flex-col items-center min-w-[80px]">
                <span class="text-xs text-gray-500 font-semibold">Chờ nấu</span>
                <span id="stat-ordered" class="text-lg font-black text-amber-600">0</span>
            </div>
            <div class="bg-gray-50 px-4 py-2 rounded-xl border border-gray-200 flex flex-col items-center min-w-[80px]">
                <span class="text-xs text-gray-500 font-semibold">Đang nấu</span>
                <span id="stat-cooking" class="text-lg font-black text-sky-600">0</span>
            </div>
            <div class="bg-gray-50 px-4 py-2 rounded-xl border border-gray-200 flex flex-col items-center min-w-[80px]">
                <span class="text-xs text-gray-500 font-semibold">Đã ra món</span>
                <span id="stat-served" class="text-lg font-black text-emerald-600">0</span>
            </div>
        </div>
    </div>

    <!-- Board Columns -->
    <div class="flex-1 grid grid-cols-1 lg:grid-cols-3 gap-6 overflow-hidden min-h-0">
        
        <!-- Column 1: Waiting to Cook (Ordered) -->
        <div class="bg-white border border-gray-200 rounded-2xl flex flex-col overflow-hidden shadow-sm">
            <div class="bg-amber-50/50 border-b border-gray-200 px-5 py-4 flex justify-between items-center shrink-0">
                <h3 class="font-extrabold text-amber-900 flex items-center gap-2 text-base">
                    <span class="w-2.5 h-2.5 bg-amber-500 rounded-full animate-ping"></span>
                    MÓN CHỜ CHẾ BIẾN
                </h3>
                <span class="bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full border border-amber-200 font-mono" id="badge-ordered">0</span>
            </div>
            <div id="col-ordered" class="flex-1 overflow-y-auto p-4 flex flex-col gap-4 bg-gray-50/30">
                <!-- Cards will render here -->
            </div>
        </div>

        <!-- Column 2: In Preparation (Cooking) -->
        <div class="bg-white border border-gray-200 rounded-2xl flex flex-col overflow-hidden shadow-sm">
            <div class="bg-sky-50/50 border-b border-gray-200 px-5 py-4 flex justify-between items-center shrink-0">
                <h3 class="font-extrabold text-sky-900 flex items-center gap-2 text-base">
                    <span class="w-2.5 h-2.5 bg-sky-500 rounded-full animate-pulse"></span>
                    MÓN ĐANG NẤU
                </h3>
                <span class="bg-sky-100 text-sky-700 text-xs font-bold px-2.5 py-1 rounded-full border border-sky-200 font-mono" id="badge-cooking">0</span>
            </div>
            <div id="col-cooking" class="flex-1 overflow-y-auto p-4 flex flex-col gap-4 bg-gray-50/30">
                <!-- Cards will render here -->
            </div>
        </div>

        <!-- Column 3: Served (Completed) -->
        <div class="bg-white border border-gray-200 rounded-2xl flex flex-col overflow-hidden shadow-sm">
            <div class="bg-emerald-50/50 border-b border-gray-200 px-5 py-4 flex justify-between items-center shrink-0">
                <h3 class="font-extrabold text-emerald-900 flex items-center gap-2 text-base">
                    <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full"></span>
                    MÓN ĐẠ ĐÃ RA BÀN
                </h3>
                <span class="bg-emerald-100 text-emerald-700 text-xs font-bold px-2.5 py-1 rounded-full border border-emerald-200 font-mono" id="badge-served">0</span>
            </div>
            <div id="col-served" class="flex-1 overflow-y-auto p-4 flex flex-col gap-4 bg-gray-50/30">
                <!-- Cards will render here -->
            </div>
        </div>

    </div>
</div>

<script>
    // Local data storage for reactive UI updates
    let rawQueueData = [];
    let warningAudioInterval = null;

    // Unlock Audio Context on overlay button click
    function unlockKitchenAudio() {
        if (typeof AlertAudio !== 'undefined') {
            AlertAudio.init();
            // Test beep
            AlertAudio.playNewOrder();
        }
        document.getElementById('kitchen-audio-overlay').classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => {
            document.getElementById('kitchen-audio-overlay').remove();
        }, 500);
        
        // Start timers
        startQueueTimer();
    }

    // Refresh function called by SignalR and initial load
    async function refreshQueueData() {
        try {
            const res = await fetch(window.location.href);
            if (!res.ok) return;
            const text = await res.text();
            
            // Parse response to find queue data or reload HTML
            const parser = new DOMParser();
            const doc = parser.parseFromString(text, 'text/html');
            
            // We can retrieve the queue raw model serialized as JSON inside a script tag
            // Or parse the items from JSON script. Let's embed the data directly below!
            const newDataScript = doc.getElementById('queue-data-json');
            if (newDataScript) {
                rawQueueData = JSON.parse(newDataScript.textContent);
                renderQueue();
            }
        } catch (e) {
            console.error("Lỗi đồng bộ dữ liệu: ", e);
        }
    }

    // Process Status update action (calls Controller API via AJAX)
    async function updateStatus(orderId, cartItemId, newStatus) {
        const btn = document.getElementById(`btn-${cartItemId}`);
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = `<i class="fa-solid fa-spinner animate-spin"></i> Xử lý...`;
        }

        try {
            const formData = new FormData();
            formData.append("orderId", orderId);
            formData.append("cartItemId", cartItemId);
            formData.append("newStatus", newStatus);

            const res = await fetch('/Chef/Kitchen/UpdateItemStatus', {
                method: 'POST',
                body: formData
            });

            const data = await res.json();
            if (!data.success) {
                alert(data.message || "Cập nhật trạng thái thất bại!");
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = `Lỗi`;
                }
            } else {
                // Success is broad-casted and page is refreshed via SignalR.
                // But we update immediately locally for instantaneous feeling.
                const item = rawQueueData.find(i => i.cartItemId === cartItemId);
                if (item) {
                    item.itemStatus = newStatus;
                    renderQueue();
                }
            }
        } catch (e) {
            alert("Lỗi kết nối máy chủ!");
            if (btn) btn.disabled = false;
        }
    }

    // Build option badges string
    function renderOptionsHtml(options) {
        if (!options || options.length === 0) return '';
        const badges = options.map(opt => {
            const extraText = opt.extraPrice > 0 ? ` (+${opt.extraPrice.toLocaleString('vi-VN')}đ)` : '';
            return `<span class="bg-gray-100 text-gray-600 text-xs font-semibold px-2 py-0.5 rounded border border-gray-200">${opt.name}${extraText}</span>`;
        }).join('');
        return `<div class="flex flex-wrap gap-1.5 mt-2">${badges}</div>`;
    }

    // Render the queue columns from local state
    function renderQueue() {
        const colOrdered = document.getElementById('col-ordered');
        const colCooking = document.getElementById('col-cooking');
        const colServed = document.getElementById('col-served');

        let htmlOrdered = '';
        let htmlCooking = '';
        let htmlServed = '';

        let countOrdered = 0;
        let countCooking = 0;
        let countServed = 0;

        rawQueueData.forEach(item => {
            const optionsHtml = renderOptionsHtml(item.selectedOptions);
            const noteHtml = item.note ? `<div class="mt-2 text-xs text-orange-700 bg-orange-50 border border-orange-200 p-2 rounded-lg"><i class="fa-solid fa-message mr-1.5"></i>Ghi chú: ${escapeHtml(item.note)}</div>` : '';
            const orderedTime = new Date(item.orderedAt);
            const formattedTime = orderedTime.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });

            let queueIndexHtml = '';
            if (item.itemStatus === 'Ordered') {
                queueIndexHtml = `<span class="text-xs font-black px-2 py-1 rounded bg-orange-600 text-white shadow-sm font-mono mr-1.5" title="Thứ tự chờ">#${countOrdered + 1}</span>`;
            }

            const orderIdShort = item.orderId && item.orderId.length > 6 ? item.orderId.substring(item.orderId.length - 6).toUpperCase() : (item.orderId || '');
            const orderIdHtml = orderIdShort ? `<span class="text-[10px] text-gray-400 font-bold font-mono ml-2 border border-gray-200 bg-gray-50 px-1.5 py-0.5 rounded shadow-sm" title="Mã đơn: ${item.orderId}">#${orderIdShort}</span>` : '';

            const cardHtml = `
                <div class="kitchen-card bg-white border border-gray-200 rounded-xl p-4 shadow-sm flex flex-col relative transition-all duration-200" 
                     id="card-${item.cartItemId}" 
                     data-cart-item-id="${item.cartItemId}"
                     data-ordered-at="${item.orderedAt}">
                    
                    <!-- Header -->
                    <div class="flex justify-between items-start mb-2.5">
                        <div class="flex items-center">
                            ${queueIndexHtml}
                            <span class="text-xs font-extrabold px-2.5 py-1 rounded bg-gray-100 text-gray-700 border border-gray-200 font-mono">BÀN: ${escapeHtml(item.tableNumber)}</span>
                            ${orderIdHtml}
                        </div>
                        <div class="text-right flex flex-col">
                            <span class="text-[10px] text-gray-400 font-bold uppercase">Nhận lúc</span>
                            <span class="text-xs font-mono font-bold text-gray-600">${formattedTime}</span>
                        </div>
                    </div>

                    <!-- Dish Info -->
                    <div class="flex gap-3 my-2 items-start">
                        ${item.imageUrl ? `<img src="${item.imageUrl}" class="w-12 h-12 object-cover rounded-lg border border-gray-200" />` : ''}
                        <div class="flex-1">
                            <h4 class="font-extrabold text-gray-800 text-base leading-tight">${escapeHtml(item.dishName)}</h4>
                            <p class="text-xs text-gray-500 mt-0.5">Số lượng: <strong class="text-lg text-orange-500 ml-0.5">${item.quantity}</strong></p>
                        </div>
                    </div>

                    <!-- Customizations and Notes -->
                    ${optionsHtml}
                    ${noteHtml}

                    <!-- Timer indicator (updated via timer loop) -->
                    ${item.itemStatus === 'Ordered' ? `
                        <div class="mt-4 pt-3 border-t border-gray-150 flex justify-between items-center gap-4">
                            <div class="flex flex-col">
                                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Thời gian chờ</span>
                                <span class="text-sm font-bold font-mono text-amber-600" id="timer-${item.cartItemId}">00:00</span>
                            </div>
                            <button id="btn-${item.cartItemId}" onclick="updateStatus('${item.orderId}', '${item.cartItemId}', 'Cooking')" 
                                    class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs py-2.5 px-4 rounded-xl shadow-md transition-all active:scale-[0.97] flex items-center gap-1.5">
                                <i class="fa-solid fa-fire"></i> Nhận Chế Biến
                            </button>
                        </div>
                    ` : ''}

                    ${item.itemStatus === 'Cooking' ? `
                        <div class="mt-4 pt-3 border-t border-gray-150 flex justify-between items-center gap-4">
                            <div class="flex flex-col">
                                <span class="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Đang nấu</span>
                                <span class="text-xs text-gray-600 font-mono font-bold" id="cook-timer-${item.cartItemId}">--:--</span>
                            </div>
                            <button id="btn-${item.cartItemId}" onclick="updateStatus('${item.orderId}', '${item.cartItemId}', 'Served')" 
                                    class="bg-sky-600 hover:bg-sky-500 text-white font-bold text-xs py-2.5 px-4 rounded-xl shadow-md transition-all active:scale-[0.97] flex items-center gap-1.5">
                                <i class="fa-solid fa-circle-check"></i> Hoàn Thành
                            </button>
                        </div>
                    ` : ''}

                    ${item.itemStatus === 'Served' ? `
                        <div class="mt-4 pt-3 border-t border-gray-150 flex justify-between items-center">
                            <span class="text-xs text-emerald-600 font-bold flex items-center gap-1"><i class="fa-solid fa-circle-check"></i> Đã ra bàn</span>
                            <button id="btn-${item.cartItemId}" onclick="updateStatus('${item.orderId}', '${item.cartItemId}', 'Cooking')" 
                                    class="text-[10px] text-gray-400 hover:text-gray-600 font-semibold underline decoration-dotted">
                                Hoàn tác về "Nấu"
                            </button>
                        </div>
                    ` : ''}

                </div>
            `;

            if (item.itemStatus === 'Ordered') {
                htmlOrdered += cardHtml;
                countOrdered++;
            } else if (item.itemStatus === 'Cooking') {
                htmlCooking += cardHtml;
                countCooking++;
            } else if (item.itemStatus === 'Served') {
                htmlServed += cardHtml;
                countServed++;
            }
        });

        // Set inner HTMLs
        colOrdered.innerHTML = htmlOrdered || '<div class="text-center text-gray-400 py-12 border border-dashed border-gray-200 rounded-xl bg-white"><i class="fa-solid fa-mug-hot text-3xl mb-2 opacity-25"></i> Không có món ăn chờ.</div>';
        colCooking.innerHTML = htmlCooking || '<div class="text-center text-gray-400 py-12 border border-dashed border-gray-200 rounded-xl bg-white"><i class="fa-solid fa-fire-burner text-3xl mb-2 opacity-25"></i> Bếp đang rảnh rỗi.</div>';
        colServed.innerHTML = htmlServed || '<div class="text-center text-gray-400 py-12 border border-dashed border-gray-200 rounded-xl bg-white"><i class="fa-solid fa-check-double text-3xl mb-2 opacity-25"></i> Chưa phục vụ món nào.</div>';

        // Update counts
        document.getElementById('badge-ordered').innerText = countOrdered;
        document.getElementById('badge-cooking').innerText = countCooking;
        document.getElementById('badge-served').innerText = countServed;

        document.getElementById('stat-ordered').innerText = countOrdered;
        document.getElementById('stat-cooking').innerText = countCooking;
        document.getElementById('stat-served').innerText = countServed;
    }

    // Helper to calculate seconds and format time
    function updateTimers() {
        const now = new Date();
        let hasOverdueItem = false;

        document.querySelectorAll('[id^="timer-"]').forEach(timerSpan => {
            const cartItemId = timerSpan.id.replace('timer-', '');
            const card = document.getElementById(`card-${cartItemId}`);
            if (!card) return;

            const orderedAtStr = card.getAttribute('data-ordered-at');
            const orderedAt = new Date(orderedAtStr);
            const diffMs = now - orderedAt;
            const diffSecs = Math.floor(diffMs / 1000);

            // Format timer string MM:SS
            const mins = Math.floor(diffSecs / 60).toString().padStart(2, '0');
            const secs = (diffSecs % 60).toString().padStart(2, '0');
            
            // Timeout check: > 5 minutes (300 seconds)
            if (diffSecs >= 300) {
                hasOverdueItem = true;
                timerSpan.innerHTML = `⚠️ <span class="animate-pulse">${mins}:${secs} (TRỄ)</span>`;
                timerSpan.className = "text-sm font-black font-mono text-red-600";
                
                // Add overdue highlight classes to card
                card.className = "kitchen-card bg-red-50 border-2 border-red-500 shadow-md shadow-red-100 rounded-xl p-4 flex flex-col relative transition-all duration-200";
            } else {
                timerSpan.innerText = `${mins}:${secs}`;
                timerSpan.className = "text-sm font-bold font-mono text-amber-600";
                card.className = "kitchen-card bg-white border border-gray-200 rounded-xl p-4 shadow-sm flex flex-col relative transition-all duration-200";
            }
        });

        // Also update Cooking cards timers (how long they have been in Cooking status)
        document.querySelectorAll('[id^="cook-timer-"]').forEach(timerSpan => {
            const cartItemId = timerSpan.id.replace('cook-timer-', '');
            const card = document.getElementById(`card-${cartItemId}`);
            if (!card) return;

            const orderedAtStr = card.getAttribute('data-ordered-at');
            const orderedAt = new Date(orderedAtStr);
            const diffMs = now - orderedAt;
            const diffSecs = Math.floor(diffMs / 1000);
            const mins = Math.floor(diffSecs / 60).toString().padStart(2, '0');
            const secs = (diffSecs % 60).toString().padStart(2, '0');

            timerSpan.innerText = `${mins}:${secs}`;
        });

        // Alarm trigger logic if any items are trễ (every 25 seconds)
        if (hasOverdueItem && typeof AlertAudio !== 'undefined') {
            if (!warningAudioInterval) {
                warningAudioInterval = setInterval(() => {
                    AlertAudio.playWarning();
                }, 25000);
                AlertAudio.playWarning(); // Play immediately on detect
            }
        } else if (!hasOverdueItem && warningAudioInterval) {
            clearInterval(warningAudioInterval);
            warningAudioInterval = null;
        }
    }

    // Start timer execution loop
    function startQueueTimer() {
        updateTimers();
        setInterval(updateTimers, 1000);
    }

    // Utility escape html helper to avoid injection and console errors
    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Initialize page
    document.addEventListener("DOMContentLoaded", () => {
        // Load initial data injected by ASP.NET Core Razor Engine
        const dataJson = document.getElementById('queue-data-json');
        if (dataJson) {
            rawQueueData = JSON.parse(dataJson.textContent);
            renderQueue();
        }
    });
</script>

<!-- Embedded JSON Data representation for client-side processing -->
<script type="application/json" id="queue-data-json">
    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }))
</script>
