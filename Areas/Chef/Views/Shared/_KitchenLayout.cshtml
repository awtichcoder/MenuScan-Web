<!DOCTYPE html>
<html lang="vi" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Hệ thống Bếp MenuScan</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        /* Custom scrollbar for light mode */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f4f4f5; /* gray-100 */
        }
        ::-webkit-scrollbar-thumb {
            background: #d4d4d8; /* gray-300 */
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #a1a1aa; /* gray-400 */
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans h-full flex flex-col antialiased selection:bg-[#F3C178] selection:text-white">

    <!-- Top Navigation Bar -->
    <header class="bg-white border-b border-gray-200 px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4 shrink-0 shadow-sm">
        <!-- Logo & Branding -->
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-tr from-[#F3C178] to-amber-400 rounded-xl flex items-center justify-center text-white shadow-sm shadow-[#F3C178]/30">
                <i class="fa-solid fa-fire-burner text-xl animate-pulse"></i>
            </div>
            <div>
                <span class="font-extrabold text-xl tracking-tight bg-gradient-to-r from-orange-600 to-amber-500 bg-clip-text text-transparent">MenuScan</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded bg-orange-50 text-orange-600 border border-orange-200 ml-1.5 uppercase">KITCHEN</span>
            </div>
        </div>

        <!-- Navigation Tabs -->
        <nav class="flex items-center gap-2 bg-gray-100 p-1 rounded-xl border border-gray-200">
            <a href="/Chef/Kitchen/Index" class="tab-link px-4 py-2 text-sm font-semibold rounded-lg transition-all flex items-center gap-2 @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-white text-orange-600 shadow-sm border border-gray-200/50" : "text-gray-500 hover:text-gray-800")">
                <i class="fa-solid fa-list-check"></i>
                Hàng đợi Chế Biến
            </a>
            <a href="/Chef/Kitchen/Batch" class="tab-link px-4 py-2 text-sm font-semibold rounded-lg transition-all flex items-center gap-2 @(ViewContext.RouteData.Values["action"]?.ToString() == "Batch" ? "bg-white text-orange-600 shadow-sm border border-gray-200/50" : "text-gray-500 hover:text-gray-800")">
                <i class="fa-solid fa-layer-group"></i>
                Gom Món Thông Minh
            </a>
            <a href="/Chef/Kitchen/Dishes" class="tab-link px-4 py-2 text-sm font-semibold rounded-lg transition-all flex items-center gap-2 @(ViewContext.RouteData.Values["action"]?.ToString() == "Dishes" ? "bg-white text-orange-600 shadow-sm border border-gray-200/50" : "text-gray-500 hover:text-gray-800")">
                <i class="fa-solid fa-utensils"></i>
                Thực Đơn Tạm Ẩn
            </a>
        </nav>

        <!-- User Controls -->
        <div class="flex items-center gap-4">
            <div class="hidden sm:flex flex-col text-right">
                <span class="text-xs text-gray-400 font-semibold uppercase tracking-wide">Nhân viên khu bếp</span>
                <span class="text-sm font-bold text-gray-800">@(User.Identity?.Name ?? "Bếp Trưởng")</span>
            </div>
            <div class="w-10 h-10 rounded-full bg-orange-50 border border-orange-200 flex items-center justify-center font-bold text-orange-600">
                @(User.Identity?.Name != null && User.Identity.Name.Length >= 2 ? User.Identity.Name.Substring(0, 2).ToUpper() : "BT")
            </div>
            <a href="/Account/Logout" class="px-3.5 py-2 text-sm font-semibold text-gray-500 hover:text-red-600 hover:bg-red-50 border border-transparent hover:border-red-200 rounded-lg transition-all flex items-center gap-2" title="Đăng xuất">
                <i class="fa-solid fa-power-off"></i>
                <span class="hidden md:inline">Đăng xuất</span>
            </a>
        </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-1 overflow-hidden relative bg-gray-50">
        @RenderBody()
    </main>

    <!-- SignalR Client and Toast notifications helper -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        // Web Audio API Synth sound creator to play alerts safely without file loading errors
        const AlertAudio = {
            ctx: null,
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            },
            playNewOrder() {
                this.init();
                if (!this.ctx) return;
                
                const now = this.ctx.currentTime;
                // Double chime (Ding-Ding)
                this.chime(523.25, now); // C5
                this.chime(659.25, now + 0.15); // E5
                this.chime(783.99, now + 0.3); // G5
            },
            playWarning() {
                this.init();
                if (!this.ctx) return;
                
                const now = this.ctx.currentTime;
                // Warning alarm sound (low-high beep)
                this.beep(880, 0.15, now);
                this.beep(880, 0.15, now + 0.25);
            },
            chime(frequency, time) {
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(frequency, time);
                
                gain.gain.setValueAtTime(0.2, time);
                gain.gain.exponentialRampToValueAtTime(0.01, time + 0.5);
                
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.start(time);
                osc.stop(time + 0.5);
            },
            beep(frequency, duration, time) {
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                
                osc.type = 'sine';
                osc.frequency.setValueAtTime(frequency, time);
                
                gain.gain.setValueAtTime(0.15, time);
                gain.gain.setValueAtTime(0.15, time + duration - 0.05);
                gain.gain.exponentialRampToValueAtTime(0.01, time + duration);
                
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                
                osc.start(time);
                osc.stop(time + duration);
            }
        };

        // Initialize SignalR
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/staffHub")
            .withAutomaticReconnect()
            .build();

        connection.on("NewOrder", function (tableId) {
            console.log("New order notified from table: " + tableId);
            AlertAudio.playNewOrder();
            
            // Show toast notification
            showKitchenToast(`Có đơn hàng mới từ <strong>Bàn ${tableId}</strong>!`, 'info');
            
            // If we have custom page refresh function
            if (typeof refreshQueueData === 'function') {
                refreshQueueData();
            }
        });

        connection.on("OrderUpdated", function (data) {
            console.log("Order updated:", data);
            if (typeof refreshQueueData === 'function') {
                refreshQueueData();
            }
        });

        connection.start()
            .then(() => console.log("Connected to SignalR Hub successfully."))
            .catch(err => console.error("SignalR Connection Error: ", err));

        // Toast container builder
        function showKitchenToast(message, type = 'info') {
            let container = document.getElementById('kitchen-toast-container');
            if (!container) {
                container = document.createElement('div');
                container.id = 'kitchen-toast-container';
                container.className = 'fixed top-5 right-5 z-[9999] flex flex-col gap-3 pointer-events-none';
                document.body.appendChild(container);
            }

            const toast = document.createElement('div');
            toast.className = 'pointer-events-auto bg-white border border-gray-100 border-l-4 border-orange-500 shadow-xl rounded-xl p-4 flex items-center gap-3 w-80 animate-bounce duration-300';
            toast.innerHTML = `
                <div class="bg-orange-50 text-orange-600 w-10 h-10 flex items-center justify-center rounded-lg flex-shrink-0">
                    <i class="fa-solid fa-bell text-lg"></i>
                </div>
                <div class="flex-1">
                    <p class="text-sm text-gray-700">${message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="text-gray-400 hover:text-gray-600 text-xs">✕</button>
            `;
            container.appendChild(toast);
            
            // Auto remove after 5s
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }
    </script>
</body>
</html>
