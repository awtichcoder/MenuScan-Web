@* Areas/Admin/Views/Category/Create.cshtml *@
@{
    ViewData["Title"] = "Thêm Danh Mục (Demo)";
}

<div class="max-w-2xl mx-auto p-6 bg-white rounded-lg shadow-md mt-10">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Thêm Danh Mục (Quick Setup)</h2>

    <form id="categoryForm" class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700">Tên danh mục</label>
            <input type="text" id="Name" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" placeholder="VD: Mì Khô, Nước uống">
        </div>
        
        <div>
            <label class="block text-sm font-medium text-gray-700">Mô tả ngắn</label>
            <input type="text" id="Description" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" placeholder="VD: Các món mì trộn đặc biệt">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Thứ tự hiển thị (Số)</label>
            <input type="number" id="DisplayOrder" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm p-2 border" value="1">
        </div>

        <div class="pt-4">
            <button type="button" onclick="submitCategory()" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700">
                Tạo Danh Mục Nhanh
            </button>
        </div>
    </form>
</div>

<script>
    async function submitCategory() {
        const data = {
            Name: document.getElementById('Name').value,
            Description: document.getElementById('Description').value,
            DisplayOrder: parseInt(document.getElementById('DisplayOrder').value) || 1,
            IsActive: true
        };

        if(!data.Name) {
            alert("Ít nhất cũng phải nhập cái tên danh mục chứ!");
            return;
        }

        try {
            const response = await fetch('/Admin/Category/CreateApi', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                const result = await response.json();
                alert('Tạo OK! ID trong MongoDB: ' + result.id);
                document.getElementById('categoryForm').reset();
            } else {
                alert('Lỗi khi lưu');
            }
        } catch (error) {
            console.error(error);
            alert('Lỗi kết nối mạng');
        }
    }
</script>