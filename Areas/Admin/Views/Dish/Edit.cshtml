@model MenuQr.Areas.Admin.Models.Dish
@{
    ViewData["Title"] = "Sua mon";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<MenuQr.Areas.Admin.Models.Category> ?? new();
}

<div class="max-w-3xl mx-auto bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Sua mon an</h1>

    <div class="space-y-4">
        <input id="name" value="@Model.Name" class="w-full border rounded-xl px-4 py-2" placeholder="Ten mon" />
        <select id="categoryId" class="w-full border rounded-xl px-4 py-2">
            @foreach (var category in categories)
            {
                <option value="@category.Id" selected="@(Model.CategoryId == category.Id)">@category.Name</option>
            }
        </select>
        <input id="basePrice" type="number" min="0" value="@Model.BasePrice" class="w-full border rounded-xl px-4 py-2" placeholder="Gia" />
        <input id="discountPercent" type="number" min="0" max="100" value="@Model.DiscountPercent" class="w-full border rounded-xl px-4 py-2" placeholder="Giam gia %" />
        <input id="imageUrl" value="@Model.ImageUrl" class="w-full border rounded-xl px-4 py-2" placeholder="Image URL" />
        <label class="flex items-center gap-2">
            <input id="isAvailable" type="checkbox" checked="@Model.IsAvailable" />
            <span>Dang kinh doanh</span>
        </label>
        <button onclick="saveDish()" class="px-5 py-2.5 rounded-xl bg-black text-white font-semibold">Luu thay doi</button>
    </div>
</div>

<script>
    async function saveDish() {
        const select = document.getElementById('categoryId');
        const payload = {
            name: document.getElementById('name').value.trim(),
            categoryId: select.value,
            categoryName: select.options[select.selectedIndex].text,
            basePrice: Number(document.getElementById('basePrice').value || 0),
            discountPercent: Number(document.getElementById('discountPercent').value || 0),
            imageUrl: document.getElementById('imageUrl').value.trim(),
            isAvailable: document.getElementById('isAvailable').checked,
            specifications: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Specifications))
        };

        const res = await fetch('/api/admin/dishes/@Model.Id', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        alert(data.message || (data.success ? 'Da luu.' : 'Co loi xay ra.'));
        if (data.success) location.href = '/Admin/Dish/Index';
    }
</script>
