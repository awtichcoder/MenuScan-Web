@model List<MenuQr.Areas.Admin.Models.Dish>
@{
    ViewData["Title"] = "Quản lý thực đơn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var categories = ViewBag.Categories as List<MenuQr.Areas.Admin.Models.Category> ?? new();
}

<div class="max-w-7xl mx-auto bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Thực đơn</h1>
            <p class="text-sm text-gray-500">Danh sách món, tìm kiếm, sửa và xóa mềm.</p>
        </div>
        <a href="/Admin/Dish/Create" class="px-4 py-2 rounded-xl bg-black text-white font-semibold">Thêm món</a>
    </div>

    <form class="grid md:grid-cols-[1fr_220px_auto] gap-3 mb-5">
        <input name="keyword" value="@ViewBag.Keyword" placeholder="Tìm theo tên món" class="border rounded-xl px-4 py-2" />
        <select name="categoryId" class="border rounded-xl px-4 py-2">
            <option value="">Tất cả danh mục</option>
            @foreach (var category in categories)
            {
                <option value="@category.Id" selected="@(ViewBag.CategoryId == category.Id)">@category.Name</option>
            }
        </select>
        <button class="px-4 py-2 rounded-xl bg-gray-900 text-white font-semibold">Lọc</button>
    </form>

    @if (!Model.Any())
    {
        <div class="rounded-2xl border border-dashed border-gray-300 bg-gray-50 p-8 text-center text-gray-500">
            Chưa có món nào phù hợp. Hãy thêm món mới hoặc đổi bộ lọc.
        </div>
    }
    else
    {
        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var dish in Model)
            {
                <div class="border rounded-2xl p-4 flex gap-4">
                    <img src="@(string.IsNullOrWhiteSpace(dish.ImageUrl) ? "https://via.placeholder.com/120" : dish.ImageUrl)" class="w-24 h-24 object-cover rounded-xl" />
                    <div class="min-w-0 flex-1">
                        <h3 class="font-bold text-gray-900 truncate">@dish.Name</h3>
                        <p class="text-sm text-gray-500">@dish.CategoryName</p>
                        <p class="font-semibold">@string.Format("{0:N0}", dish.BasePrice) VND</p>
                        <p class="text-xs @(dish.IsAvailable ? "text-green-600" : "text-gray-500")">@(dish.IsAvailable ? "Đang bán" : "Đang ẩn")</p>
                        <div class="flex gap-2 mt-3">
                            <a href="/Admin/Dish/Edit/@dish.Id" class="px-3 py-1.5 rounded-lg bg-amber-100 text-amber-800 text-sm font-semibold">Sửa</a>
                            <button onclick="deleteDish('@dish.Id')" class="px-3 py-1.5 rounded-lg bg-red-100 text-red-700 text-sm font-semibold">Xóa</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    async function deleteDish(id) {
        if (!confirm('Xóa món này? Món đang nằm trong đơn chưa hoàn tất sẽ bị chặn.')) return;
        const res = await fetch(`/api/admin/dishes/${id}`, { method: 'DELETE' });
        const data = await res.json();
        alert(data.message || (data.success ? 'Đã xóa.' : 'Có lỗi xảy ra.'));
        if (data.success) location.reload();
    }
</script>