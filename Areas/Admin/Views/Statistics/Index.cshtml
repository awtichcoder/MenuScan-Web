@* Areas/Admin/Views/Statistics/Index.cshtml *@
@{
    ViewData["Title"] = "Thống kê doanh thu";
}

<partial name="_AdminNav" />

<div class="max-w-5xl mx-auto p-6">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">Thống kê doanh thu</h2>

    <div id="alertBox" class="hidden mb-4 px-4 py-3 rounded text-sm"></div>

    <!-- Bộ lọc -->
    <div class="flex flex-wrap items-end gap-3 mb-4 bg-white rounded-lg shadow p-3">
        <div>
            <label class="block text-xs text-gray-500">Từ ngày</label>
            <input type="date" id="fromDate" class="rounded border p-2 text-sm">
        </div>
        <div>
            <label class="block text-xs text-gray-500">Đến ngày</label>
            <input type="date" id="toDate" class="rounded border p-2 text-sm">
        </div>
        <div>
            <label class="block text-xs text-gray-500">Nhóm theo</label>
            <select id="groupBy" class="rounded border p-2 text-sm">
                <option value="day">Ngày</option>
                <option value="month">Tháng</option>
            </select>
        </div>
        <button onclick="loadAll()" class="px-4 py-2 rounded-md bg-rose-600 hover:bg-rose-700 text-white text-sm font-medium">Xem</button>
    </div>

    <!-- Thẻ tổng quan -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="bg-white rounded-lg shadow p-4"><div class="text-xs text-gray-500">Tổng doanh thu</div><div id="cardRevenue" class="text-xl font-bold text-rose-600">—</div></div>
        <div class="bg-white rounded-lg shadow p-4"><div class="text-xs text-gray-500">Số hóa đơn</div><div id="cardCount" class="text-xl font-bold text-gray-800">—</div></div>
        <div class="bg-white rounded-lg shadow p-4"><div class="text-xs text-gray-500">TB / hóa đơn</div><div id="cardAvg" class="text-xl font-bold text-gray-800">—</div></div>
        <div class="bg-white rounded-lg shadow p-4"><div class="text-xs text-gray-500">Tổng giảm giá</div><div id="cardDiscount" class="text-xl font-bold text-gray-800">—</div></div>
    </div>

    <!-- Biểu đồ cột (CSS thuần) -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <h3 class="font-semibold text-gray-700 mb-3">Doanh thu theo thời gian</h3>
        <div id="chart" class="flex items-end gap-2 h-48 border-b border-gray-200 pb-1 overflow-x-auto"></div>
    </div>

    <!-- Top món -->
    <div class="bg-white rounded-lg shadow p-4">
        <h3 class="font-semibold text-gray-700 mb-3">Món bán chạy</h3>
        <table class="min-w-full text-sm">
            <thead class="text-gray-500 text-left"><tr><th class="py-2">#</th><th class="py-2">Tên món</th><th class="py-2">Số lượng</th><th class="py-2">Doanh thu</th></tr></thead>
            <tbody id="topDishesBody"><tr><td colspan="4" class="py-4 text-center text-gray-400">—</td></tr></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const BASE = '/Admin/Statistics';

    function showAlert(msg, ok = true) {
        const box = document.getElementById('alertBox');
        box.textContent = msg;
        box.className = 'mb-4 px-4 py-3 rounded text-sm ' + (ok ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700');
        box.classList.remove('hidden');
        setTimeout(() => box.classList.add('hidden'), 4000);
    }
    function esc(s){return (s??'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
    function money(n){return (n??0).toLocaleString('vi-VN')+'đ';}
    function fmtLabel(v){ // label có thể là ISO date (day) hoặc "M/yyyy" (month)
        if (typeof v === 'string' && v.includes('T')) { const d=new Date(v); return d.getDate()+'/'+(d.getMonth()+1); }
        return v;
    }

    function qs() {
        const f = document.getElementById('fromDate').value;
        const t = document.getElementById('toDate').value;
        const g = document.getElementById('groupBy').value;
        return `from=${f}&to=${t}&groupBy=${g}`;
    }

    async function loadSummary() {
        const res = await fetch(`${BASE}/SummaryApi?${qs()}`);
        const json = await res.json();
        if (!res.ok) { showAlert(json.message || 'Lỗi', false); return; }
        document.getElementById('cardRevenue').textContent = money(json.totalRevenue);
        document.getElementById('cardCount').textContent = json.invoiceCount;
        document.getElementById('cardAvg').textContent = money(Math.round(json.avgInvoice));
        document.getElementById('cardDiscount').textContent = money(json.totalDiscount);
        renderChart(json.series || []);
    }

    function renderChart(series) {
        const chart = document.getElementById('chart');
        if (series.length === 0) { chart.innerHTML = '<div class="text-gray-400 text-sm">Không có dữ liệu.</div>'; return; }
        const max = Math.max(...series.map(s => s.revenue), 1);
        chart.innerHTML = series.map(s => {
            const h = Math.max(4, Math.round(s.revenue / max * 170));
            return `<div class="flex flex-col items-center justify-end flex-shrink-0 w-12" title="${money(s.revenue)}">
                <div class="w-8 bg-rose-500 rounded-t" style="height:${h}px"></div>
                <div class="text-[10px] text-gray-500 mt-1 whitespace-nowrap">${esc(fmtLabel(s.label))}</div>
            </div>`;
        }).join('');
    }

    async function loadTopDishes() {
        const f = document.getElementById('fromDate').value;
        const t = document.getElementById('toDate').value;
        const res = await fetch(`${BASE}/TopDishesApi?from=${f}&to=${t}&top=10`);
        const json = await res.json();
        const body = document.getElementById('topDishesBody');
        const list = json.data || [];
        if (list.length === 0) { body.innerHTML = '<tr><td colspan="4" class="py-4 text-center text-gray-400">Không có dữ liệu.</td></tr>'; return; }
        body.innerHTML = list.map((d, i) => `
            <tr class="border-t">
                <td class="py-2">${i + 1}</td>
                <td class="py-2 font-medium text-gray-800">${esc(d.dishName)}</td>
                <td class="py-2">${d.quantity}</td>
                <td class="py-2">${money(d.revenue)}</td>
            </tr>`).join('');
    }

    async function loadAll() {
        try { await Promise.all([loadSummary(), loadTopDishes()]); }
        catch (e) { showAlert('Lỗi kết nối mạng', false); }
    }

    // Mặc định: 30 ngày gần nhất
    (function init() {
        const today = new Date();
        const from = new Date(); from.setDate(today.getDate() - 29);
        const iso = d => d.toISOString().slice(0, 10);
        document.getElementById('toDate').value = iso(today);
        document.getElementById('fromDate').value = iso(from);
        loadAll();
    })();
</script>
}
