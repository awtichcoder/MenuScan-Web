@* Areas/Admin/Views/Table/Index.cshtml *@
@{
    ViewData["Title"] = "Quản lý Bàn ăn";
}

<partial name="_AdminNav" />

<div class="max-w-5xl mx-auto p-6">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-2xl font-bold text-gray-800">Quản lý Bàn ăn</h2>
        <button type="button" onclick="openForm()"
                class="bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 rounded-md text-sm font-medium">
            + Thêm bàn
        </button>
    </div>

    <div id="alertBox" class="hidden mb-4 px-4 py-3 rounded text-sm"></div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full text-sm">
            <thead class="bg-gray-100 text-gray-600 text-left">
                <tr>
                    <th class="px-4 py-3">Mã bàn</th>
                    <th class="px-4 py-3">Tên bàn</th>
                    <th class="px-4 py-3">Khu vực</th>
                    <th class="px-4 py-3">Sức chứa</th>
                    <th class="px-4 py-3">Trạng thái</th>
                    <th class="px-4 py-3">QR</th>
                    <th class="px-4 py-3 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody id="tableBody" class="divide-y divide-gray-100">
                <tr><td colspan="7" class="px-4 py-6 text-center text-gray-400">Đang tải...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal thêm bàn -->
<div id="formModal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-lg w-full max-w-lg p-6">
        <h3 class="text-xl font-bold text-gray-800 mb-4">Thêm bàn</h3>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700">Mã bàn *</label>
                <input type="text" id="Code" class="mt-1 block w-full rounded-md border p-2" placeholder="VD: B01">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Tên bàn *</label>
                <input type="text" id="Name" class="mt-1 block w-full rounded-md border p-2" placeholder="VD: Bàn 1">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Khu vực</label>
                <input type="text" id="Area" class="mt-1 block w-full rounded-md border p-2" placeholder="VD: Tầng 1">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700">Sức chứa *</label>
                <input type="number" id="Capacity" value="4" min="1" class="mt-1 block w-full rounded-md border p-2">
            </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
            <button type="button" onclick="closeForm()" class="px-4 py-2 rounded-md border text-gray-600 text-sm">Hủy</button>
            <button type="button" onclick="submitForm()" class="px-4 py-2 rounded-md bg-amber-600 hover:bg-amber-700 text-white text-sm font-medium">Lưu</button>
        </div>
    </div>
</div>

<!-- Modal xem QR -->
<div id="qrModal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-lg shadow-lg w-full max-w-sm p-6 text-center">
        <h3 class="text-xl font-bold text-gray-800 mb-4">Mã QR bàn</h3>
        <img id="qrImage" class="mx-auto border rounded w-56 h-56 object-contain" />
        <p id="qrUrl" class="text-xs text-gray-500 mt-2 break-all"></p>
        <div class="flex justify-center gap-3 mt-4">
            <a id="qrDownload" download="qr.png" class="px-4 py-2 rounded-md bg-green-600 hover:bg-green-700 text-white text-sm">Tải xuống</a>
            <button type="button" onclick="closeQr()" class="px-4 py-2 rounded-md border text-gray-600 text-sm">Đóng</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const BASE = '/Admin/Table';

    function showAlert(msg, ok = true) {
        const box = document.getElementById('alertBox');
        box.textContent = msg;
        box.className = 'mb-4 px-4 py-3 rounded text-sm ' + (ok ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700');
        box.classList.remove('hidden');
        setTimeout(() => box.classList.add('hidden'), 4000);
    }
    function esc(s) { return (s ?? '').toString().replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

    async function loadTables() {
        const body = document.getElementById('tableBody');
        try {
            const res = await fetch(`${BASE}/List`);
            const json = await res.json();
            const list = json.data || [];
            if (list.length === 0) {
                body.innerHTML = `<tr><td colspan="7" class="px-4 py-6 text-center text-gray-400">Chưa có bàn nào.</td></tr>`;
                return;
            }
            body.innerHTML = list.map(t => `
                <tr>
                    <td class="px-4 py-2 font-medium text-gray-800">${esc(t.code)}</td>
                    <td class="px-4 py-2">${esc(t.name)}</td>
                    <td class="px-4 py-2 text-gray-500">${esc(t.area) || '—'}</td>
                    <td class="px-4 py-2">${t.capacity}</td>
                    <td class="px-4 py-2">${t.status === 'occupied' ? '<span class="text-red-600">Có khách</span>' : '<span class="text-green-600">Trống</span>'}</td>
                    <td class="px-4 py-2">${t.qrCodeUrl
                        ? `<button onclick="viewQr('${esc(t.qrCodeUrl)}','${esc(t.code)}')" class="text-indigo-600 hover:underline">Xem</button>`
                        : '<span class="text-gray-300">chưa có</span>'}</td>
                    <td class="px-4 py-2 text-right whitespace-nowrap">
                        <button onclick="genQr('${t.id}')" class="text-amber-600 hover:underline mr-3">Tạo QR</button>
                        <button onclick="deleteTable('${t.id}')" class="text-red-600 hover:underline">Xóa</button>
                    </td>
                </tr>`).join('');
        } catch (e) {
            body.innerHTML = `<tr><td colspan="7" class="px-4 py-6 text-center text-red-500">Lỗi tải dữ liệu.</td></tr>`;
        }
    }
    document.addEventListener('DOMContentLoaded', loadTables);

    function openForm() {
        document.getElementById('Code').value = '';
        document.getElementById('Name').value = '';
        document.getElementById('Area').value = '';
        document.getElementById('Capacity').value = 4;
        document.getElementById('formModal').classList.remove('hidden');
    }
    function closeForm() { document.getElementById('formModal').classList.add('hidden'); }

    async function submitForm() {
        const data = {
            Code: document.getElementById('Code').value,
            Name: document.getElementById('Name').value,
            Area: document.getElementById('Area').value,
            Capacity: parseInt(document.getElementById('Capacity').value) || 0
        };
        try {
            const res = await fetch(`${BASE}/CreateApi`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data)
            });
            const json = await res.json();
            if (res.ok) { closeForm(); showAlert(json.message || 'Thành công', true); loadTables(); }
            else { showAlert(json.message || 'Có lỗi xảy ra', false); }
        } catch (e) { showAlert('Lỗi kết nối mạng', false); }
    }

    async function deleteTable(id) {
        if (!confirm('Bạn chắc chắn muốn xóa bàn này?')) return;
        try {
            const res = await fetch(`${BASE}/DeleteApi?id=${id}`, { method: 'DELETE' });
            const json = await res.json();
            if (res.ok) { showAlert(json.message || 'Đã xóa', true); loadTables(); }
            else { showAlert(json.message || 'Không thể xóa', false); }
        } catch (e) { showAlert('Lỗi kết nối mạng', false); }
    }

    async function genQr(id) {
        showAlert('Đang tạo mã QR...', true);
        try {
            const res = await fetch(`${BASE}/GenerateQrApi?id=${id}`, { method: 'POST' });
            const json = await res.json();
            if (res.ok) {
                showAlert(json.message || 'Tạo QR thành công', true);
                loadTables();
                viewQr(json.qrCodeUrl, '', json.menuUrl);
            } else { showAlert(json.message || 'Lỗi tạo QR', false); }
        } catch (e) { showAlert('Lỗi kết nối mạng', false); }
    }

    function viewQr(dataUrl, code, menuUrl) {
        document.getElementById('qrImage').src = dataUrl;
        document.getElementById('qrUrl').textContent = menuUrl || '';
        const dl = document.getElementById('qrDownload');
        dl.href = dataUrl;
        dl.download = `qr-${code || 'ban'}.png`;
        document.getElementById('qrModal').classList.remove('hidden');
    }
    function closeQr() { document.getElementById('qrModal').classList.add('hidden'); }
</script>
}
