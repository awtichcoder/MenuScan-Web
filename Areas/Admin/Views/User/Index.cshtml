@model MenuQr.Areas.Admin.Controllers.UserManagementViewModel
@{
    ViewData["Title"] = "Quan ly tai khoan";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-7xl mx-auto space-y-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Tai khoan nhan vien</h1>
            <p class="text-sm text-gray-500 mt-1">Tao account, cap quyen va khoa/mo tai khoan noi bo. Admin la tai khoan he thong duy nhat.</p>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-600">
            <span class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-white border border-gray-200">
                <i class="fa-solid fa-users text-[#F3C178]"></i>
                @Model.Users.Count tai khoan
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded-xl border border-green-200 bg-green-50 text-green-700 px-4 py-3 font-semibold">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-xl border border-red-200 bg-red-50 text-red-700 px-4 py-3 font-semibold">
            @TempData["ErrorMessage"]
        </div>
    }

    <section class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between gap-4 mb-5">
            <div>
                <h2 class="text-lg font-bold text-gray-900">Cap account moi</h2>
                <p class="text-sm text-gray-500">Chi cap quyen van hanh: Staff, Cashier, Kitchen hoac Chef.</p>
            </div>
            <i class="fa-solid fa-user-plus text-2xl text-[#F3C178]"></i>
        </div>

        <form asp-area="Admin" asp-controller="User" asp-action="Create" method="post" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4 items-start">
            @Html.AntiForgeryToken()

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Ten dang nhap</label>
                <input name="Username" value="@Model.CreateUser.Username" autocomplete="off" class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F3C178]" />
                @Html.ValidationMessage("Username", new { @class = "text-sm text-red-600 mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Ho ten</label>
                <input name="FullName" value="@Model.CreateUser.FullName" autocomplete="off" class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F3C178]" />
                @Html.ValidationMessage("FullName", new { @class = "text-sm text-red-600 mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Mat khau</label>
                <input name="Password" type="password" autocomplete="new-password" class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F3C178]" />
                @Html.ValidationMessage("Password", new { @class = "text-sm text-red-600 mt-1 block" })
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Quyen</label>
                <select name="Role" class="w-full rounded-xl border border-gray-200 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F3C178]">
                    @foreach (var role in Model.RoleOptions)
                    {
                        <option value="@role" selected="@(string.Equals(Model.CreateUser.Role, role, StringComparison.OrdinalIgnoreCase))">@role</option>
                    }
                </select>
                @Html.ValidationMessage("Role", new { @class = "text-sm text-red-600 mt-1 block" })
            </div>

            <div class="flex md:pt-7">
                <button type="submit" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-black px-4 py-3 font-bold text-white hover:bg-gray-800">
                    <i class="fa-solid fa-plus"></i>
                    Tao tai khoan
                </button>
            </div>
        </form>
    </section>

    <section class="space-y-3">
        @foreach (var account in Model.Users)
        {
            <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-4 lg:p-5">
                <div class="grid grid-cols-1 xl:grid-cols-[1.1fr_2fr_1.2fr] gap-4 items-start">
                    <div class="flex items-center gap-3 min-w-0">
                        <div class="h-11 w-11 rounded-full bg-gray-100 flex items-center justify-center text-gray-700 font-black">
                            @(string.IsNullOrWhiteSpace(account.FullName) ? account.Username[..Math.Min(account.Username.Length, 2)].ToUpper() : account.FullName[..Math.Min(account.FullName.Length, 2)].ToUpper())
                        </div>
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                                <p class="font-bold text-gray-900 truncate">@account.FullName</p>
                                @if (account.IsSystemAdmin)
                                {
                                    <span class="text-xs font-bold px-2 py-1 rounded-full bg-black text-white">Admin he thong</span>
                                }
                                else
                                {
                                    <span class="text-xs font-bold px-2 py-1 rounded-full @(account.IsActive ? "bg-green-50 text-green-700" : "bg-gray-100 text-gray-500")">
                                        @(account.IsActive ? "Dang hoat dong" : "Da khoa")
                                    </span>
                                }
                            </div>
                            <p class="text-sm text-gray-500 truncate">@account.Username</p>
                        </div>
                    </div>

                    @if (account.IsSystemAdmin)
                    {
                        <div class="rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600 xl:col-span-1">
                            <div class="font-bold text-gray-900 mb-1">Tai khoan quan tri duy nhat</div>
                            <div>Khong the cap quyen Admin cho tai khoan khac, va khong the khoa/doi quyen account nay tai man hinh nhan vien.</div>
                        </div>
                    }
                    else
                    {
                        <form asp-area="Admin" asp-controller="User" asp-action="Update" method="post" class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr_auto_auto] gap-3 items-end">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="UserId" value="@account.UserId" />

                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Ho ten</label>
                                <input name="FullName" value="@account.FullName" class="w-full rounded-xl border border-gray-200 px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#F3C178]" />
                            </div>

                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Quyen</label>
                                <select name="Role" class="w-full rounded-xl border border-gray-200 px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#F3C178]">
                                    @foreach (var role in Model.RoleOptions)
                                    {
                                        <option value="@role" selected="@(string.Equals(account.Role, role, StringComparison.OrdinalIgnoreCase))">@role</option>
                                    }
                                </select>
                            </div>

                            <label class="inline-flex items-center gap-2 rounded-xl border border-gray-200 px-3 py-2.5 text-sm font-semibold text-gray-700 h-[42px]">
                                <input type="hidden" name="IsActive" value="false" />
                                <input type="checkbox" name="IsActive" value="true" checked="@account.IsActive" class="h-4 w-4 accent-[#F3C178]" />
                                Active
                            </label>

                            <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-xl bg-amber-100 px-4 py-2.5 font-bold text-amber-800 hover:bg-amber-200 h-[42px]">
                                <i class="fa-solid fa-floppy-disk"></i>
                                Luu
                            </button>
                        </form>
                    }

                    <form asp-area="Admin" asp-controller="User" asp-action="ResetPassword" method="post" class="grid grid-cols-[1fr_auto] gap-3 items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="UserId" value="@account.UserId" />
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Reset mat khau</label>
                            <input name="NewPassword" type="password" autocomplete="new-password" placeholder="Mat khau moi" class="w-full rounded-xl border border-gray-200 px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-[#F3C178]" />
                        </div>
                        <button type="submit" class="inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 px-4 py-2.5 font-bold text-white hover:bg-gray-700 h-[42px]" onclick="return confirm('Reset mat khau tai khoan nay?')">
                            <i class="fa-solid fa-key"></i>
                            Reset
                        </button>
                    </form>
                </div>
            </div>
        }
    </section>
</div>
