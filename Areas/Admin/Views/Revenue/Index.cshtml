@model MenuQr.Areas.Admin.Controllers.RevenueStatsViewModel
@{
    ViewData["Title"] = "Thong ke doanh thu";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="max-w-7xl mx-auto space-y-6">
    <form class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 grid md:grid-cols-[180px_1fr_1fr_auto] gap-3">
        <select name="type" class="border rounded-xl px-4 py-2">
            <option value="day" selected="@(ViewBag.Type == "day")">Ngay</option>
            <option value="week" selected="@(ViewBag.Type == "week")">7 ngay</option>
            <option value="month" selected="@(ViewBag.Type == "month")">Thang</option>
            <option value="year" selected="@(ViewBag.Type == "year")">Nam</option>
            <option value="custom" selected="@(ViewBag.Type == "custom")">Tuy chon</option>
        </select>
        <input type="date" name="from" value="@ViewBag.From" class="border rounded-xl px-4 py-2" />
        <input type="date" name="to" value="@ViewBag.To" class="border rounded-xl px-4 py-2" />
        <button class="px-4 py-2 rounded-xl bg-black text-white font-semibold">Xem</button>
    </form>

    <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-white border border-gray-100 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Tong doanh thu</p>
            <p class="text-2xl font-black">@string.Format("{0:N0}", Model.Summary.TotalRevenue) VND</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5">
            <p class="text-sm text-gray-500">So hoa don</p>
            <p class="text-2xl font-black">@Model.Summary.TotalOrders</p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Gia tri trung binh</p>
            <p class="text-2xl font-black">@string.Format("{0:N0}", Model.Summary.AvgOrderValue) VND</p>
        </div>
    </div>

    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5">
        <h2 class="font-bold text-lg mb-4">Doanh thu theo ngay</h2>
        <div class="space-y-3">
            @foreach (var point in Model.ChartData)
            {
                <div class="grid grid-cols-[120px_1fr_80px] gap-3 text-sm items-center">
                    <span class="text-gray-500">@point.Period</span>
                    <div class="h-3 rounded-full bg-gray-100 overflow-hidden">
                        <div class="h-full bg-amber-400" style="width:@(Model.Summary.TotalRevenue == 0 ? 0 : Math.Max(4, (double)(point.Revenue / Model.Summary.TotalRevenue * 100)))%"></div>
                    </div>
                    <span class="text-right font-semibold">@string.Format("{0:N0}", point.Revenue)</span>
                </div>
            }
        </div>
    </div>
</div>
