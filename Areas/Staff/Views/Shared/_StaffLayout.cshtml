<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Staff Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gray-50 text-gray-800 font-sans">

    <nav class="bg-[#2c3e50] text-white shadow-md sticky top-0 z-50">
        <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/Staff/Staff/Index"
                       class="flex items-center gap-2 font-black text-xl tracking-wide mr-8 hover:text-gray-200 transition">
                        <i class="fa-solid fa-mug-hot text-[#F3C178]"></i> COFFEE HOUSE
                    </a>
                    <div class="hidden md:flex space-x-2">
                        <a href="/Staff/Staff/Index"
                           class="bg-gray-900 text-white px-4 py-2 rounded-xl text-sm font-medium flex items-center gap-2">
                            <i class="fa-solid fa-desktop"></i> Màn hình phục vụ
                        </a>
                        <a href="#"
                           class="text-gray-300 hover:bg-gray-700 hover:text-white px-4 py-2 rounded-xl text-sm font-medium flex items-center gap-2 transition">
                            <i class="fa-solid fa-clock-rotate-left"></i> Lịch sử đơn
                        </a>
                    </div>
                </div>

                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2 text-sm font-medium">
                        <i class="fa-solid fa-circle-user text-xl text-[#F3C178]"></i>
                        <span class="hidden sm:block">@(User.Identity?.Name ?? ViewBag.StaffName)</span>
                    </div>
                    <div class="w-px h-6 bg-gray-600 mx-1"></div>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-gray-300 hover:text-white flex items-center gap-2 text-sm transition">
                            <i class="fa-solid fa-right-from-bracket"></i> <span class="hidden sm:block">Đăng xuất</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-[1400px] mx-auto p-4 sm:p-6 lg:p-8">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
