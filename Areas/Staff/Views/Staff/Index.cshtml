<div id="toast-container" class="fixed top-5 right-5 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

<div
    class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white p-5 rounded-2xl shadow-sm border border-gray-100 mb-6">
    <div>
        <h1 class="text-xl font-bold text-gray-800 flex items-center gap-2">
            <i class="fa-solid fa-gauge-high text-blue-600"></i> BẢNG ĐIỀU KHIỂN
        </h1>
        <p class="text-sm text-gray-500 mt-1">Quản lý tình trạng bàn và theo dõi order.</p>
    </div>
    <div class="mt-3 sm:mt-0 flex flex-wrap items-center gap-3">
        <button onclick="createTakeawayOrder(event)"
                class="bg-orange-500 hover:bg-orange-600 text-white px-4 py-2 rounded-xl text-sm font-bold shadow-md flex items-center gap-2 transition-transform hover:scale-105 ring-2 ring-orange-200">
            <i class="fa-solid fa-bag-shopping"></i> Tạo đơn Mang Đi
        </button>

        <span
            class="bg-gray-100 text-gray-700 px-4 py-2 rounded-xl text-sm font-medium border border-gray-200 flex items-center gap-2">
            <i class="fa-solid fa-user-tag text-gray-500"></i> Ca làm việc: <strong>@ViewBag.StaffName</strong>
        </span>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <div class="lg:col-span-7">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div
                class="bg-gray-900 text-white px-5 py-4 flex flex-wrap gap-4 justify-between items-center border-b border-gray-800">
                <h2 class="font-bold text-lg flex items-center gap-2">
                    <i class="fa-solid fa-table-cells"></i> Sơ đồ bàn ăn
                </h2>

                <div class="relative w-full sm:w-48">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <i class="fa-solid fa-magnifying-glass text-gray-400 text-xs"></i>
                    </span>
                    <input type="text" id="table-search-input" onkeyup="filterTables()" placeholder="Tìm tên bàn..."
                           class="w-full pl-8 pr-3 py-1.5 bg-gray-800 text-white placeholder-gray-400 text-xs rounded-xl border border-gray-700 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all" />
                </div>

                <div class="flex gap-2 text-xs font-bold uppercase tracking-wide">
                    <span class="bg-green-500 text-white px-2.5 py-1 rounded-md">Trống</span>
                    <span class="bg-red-500 text-white px-2.5 py-1 rounded-md">Khách</span>
                    <span class="bg-yellow-500 text-white px-2.5 py-1 rounded-md ">Gọi</span>
                </div>
            </div>

            <div class="p-5 bg-gray-50 flex flex-col h-full">
                <div id="table-grid-container" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 flex-1">
                    @foreach (var table in Model.Tables)
                    {
                        var activeOrder = Model.ActiveOrders.FirstOrDefault(o => o.TableNumber == table.TableNumber);
                        bool hasCustomer = activeOrder != null;

                        string borderClass = table.NeedsService ? "border-yellow-400 shadow-md ring-2 ring-yellow-200"
                                                                : (hasCustomer ? "border-red-300" : "border-green-300");

                        <div onclick="viewOrderDetails('@table.TableNumber', '@(hasCustomer ? activeOrder.Id.ToString() : "")')"
                             data-table-number="@table.TableNumber" data-table-name="@table.Name"
                             data-needs-service="@table.NeedsService.ToString().ToLower()"
                             class="table-item relative cursor-pointer transition-all duration-200 hover:-translate-y-1 hover:shadow-md rounded-2xl p-4 border-2 flex flex-col items-center text-center bg-white @borderClass">

                            <h3 class="table-name-text font-bold text-gray-800 text-lg mb-1">@table.Name</h3>
                            <p class="text-xs text-gray-500 font-mono mb-4 bg-gray-100 px-2 py-0.5 rounded">Mã:
                                @table.TableNumber</p>

                                <div class="mt-auto w-full">
                                    @if (table.NeedsService)
                                    {
                                        <span
                                            class="inline-block bg-yellow-100 text-yellow-700 border border-yellow-400 text-[10px] uppercase font-bold px-2 py-1.5 rounded-lg w-full truncate shadow-sm animate-pulse">
                                            <i class="fa-solid fa-bell text-red-500 mr-1"></i> Đang gọi
                                        </span>
                                    }
                                    else if (hasCustomer)
                                    {
                                        <span
                                            class="inline-block bg-red-100 text-red-700 border border-red-200 text-[10px] uppercase font-bold px-2 py-1.5 rounded-lg w-full truncate shadow-sm">
                                            <i class="fa-solid fa-user mr-1"></i> Có khách
                                        </span>
                                    }
                                    else
                                    {
                                        <span
                                            class="inline-block bg-green-100 text-green-700 border border-green-200 text-[10px] uppercase font-bold px-2 py-1.5 rounded-lg w-full truncate shadow-sm">
                                            <i class="fa-solid fa-check mr-1"></i> Trống
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div id="no-tables-message" class="hidden text-center py-8 text-gray-400 text-sm font-medium">
                        <i class="fa-solid fa-folder-open text-3xl mb-2 block opacity-30"></i> Không tìm thấy bàn phù hợp.
                    </div>

                    <div id="pagination-controls" class="mt-6 flex justify-center items-center gap-2">
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-5">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden sticky top-20">
                <div class="bg-blue-600 text-white px-5 py-4">
                    <h2 class="font-bold text-lg flex items-center gap-2">
                        <i class="fa-solid fa-receipt"></i> Chi tiết Order
                    </h2>
                </div>

                <div id="detail-panel" class="p-8 min-h-[400px] flex items-center justify-center bg-gray-50">
                    <div class="text-center text-gray-400">
                        <i class="fa-solid fa-hand-pointer text-5xl mb-4 block opacity-40"></i>
                        <p class="text-sm font-medium">Nhấp chọn một bàn bên trái<br>để xem chi tiết món ăn & thanh toán.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="menu-modal"
         class="fixed inset-0 z-[10001] hidden flex items-center justify-center bg-black/50 backdrop-blur-sm p-4 transition-opacity">
        <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl flex flex-col max-h-[80vh]">
            <div class="p-4 border-b flex justify-between items-center bg-gray-50 rounded-t-2xl">
                <h3 class="font-bold text-lg text-gray-800"><i class="fa-solid fa-utensils text-orange-500 mr-2"></i>Chọn
                    món thêm vào đơn</h3>
                    <button onclick="closeMenuModal()" class="text-gray-400 hover:text-red-500 transition-colors"><i
                        class="fa-solid fa-xmark text-2xl"></i></button>
                    </div>
                    <div id="menu-list" class="p-4 overflow-y-auto flex-1 grid grid-cols-2 gap-3 bg-gray-100">
                    </div>
                </div>
            </div>

            <script>
                let processedOrders = [];
                let notifiedTables = [];

                // BIẾN CHO PHÂN TRANG VÀ MODAL
                let currentPage = 1;
                const itemsPerPage = 12;
                let currentEditingOrderId = null;
                let currentEditingTableNumber = null;

                let globalDishes = [];
                let currentSelectedDish = null;

                const alertSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3');

                // -------------------------------------------------------------
                // LOGIC TAKEAWAY MỚI (GỌI API TẠO BÀN ẢO)
                // -------------------------------------------------------------
                async function createTakeawayOrder(event) {
                    if (!confirm("Xác nhận tạo một đơn Mang Đi mới?")) return;
                    let btn = event.currentTarget;
                    let oldHtml = btn.innerHTML;
                    btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang tạo...`;
                    btn.disabled = true;

                    try {
                        let res = await fetch('/Staff/Staff/CreateTakeaway', { method: 'POST' });
                        let data = await res.json();

                        if (data.success) {
                            await forceRefreshGrid();
                            viewOrderDetails(data.tableNumber, data.orderId);
                            let toastContainer = document.getElementById('toast-container');
                            toastContainer.insertAdjacentHTML('beforeend', `
                                    <div class="bg-green-500 text-white px-4 py-3 rounded-lg shadow-lg font-bold flex items-center gap-2 animate-[bounce_1s_ease-in-out]">
                                        <i class="fa-solid fa-check-circle"></i> Đã tạo bàn: Mang Đi #${data.tableNumber.replace('TKW-', '')}
                                    </div>
                                `);
                            setTimeout(() => toastContainer.lastElementChild.remove(), 3000);
                        } else {
                            alert("Lỗi: " + data.message);
                        }
                    } catch (e) {
                        console.error(e);
                        alert("Không thể kết nối đến server!");
                    } finally {
                        btn.innerHTML = oldHtml;
                        btn.disabled = false;
                    }
                }

                // -------------------------------------------------------------
                // LOGIC POPUP MENU VÀ TÙY CHỌN (OPTIONS/TOPPINGS)
                // -------------------------------------------------------------
                async function openMenuModal(orderId, tableNumber) {
                    currentEditingOrderId = orderId;
                    currentEditingTableNumber = tableNumber;

                    let menuList = document.getElementById('menu-list');
                    menuList.className = "p-4 overflow-y-auto flex-1 grid grid-cols-2 gap-3 bg-gray-100";
                    menuList.innerHTML = `<p class="col-span-2 text-center py-8 text-blue-500 font-medium"><i class="fa-solid fa-spinner fa-spin mr-2"></i> Đang tải thực đơn...</p>`;

                    document.getElementById('menu-modal').classList.remove('hidden');

                    try {
                        // Tải thực đơn nếu chưa có
                        if (globalDishes.length === 0) {
                            let res = await fetch('/Staff/Staff/GetAllDishes');
                            globalDishes = await res.json();
                        }
                        renderDishGrid();
                    } catch (e) {
                        menuList.innerHTML = `<p class="col-span-2 text-red-500 text-center py-4">Lỗi tải thực đơn!</p>`;
                    }
                }

                // Hiển thị danh sách các món ăn
                function renderDishGrid() {
                    let menuList = document.getElementById('menu-list');
                    menuList.className = "p-4 overflow-y-auto flex-1 grid grid-cols-2 gap-3 bg-gray-100";

                    if (globalDishes.length > 0) {
                        menuList.innerHTML = globalDishes.map(d => {
                            let id = d.id || d.Id || d._id;
                            let name = d.name || d.Name || d.DishName || "Món ăn";
                            let price = d.price || d.Price || d.basePrice || d.BasePrice || 0;
                            return `
                                <button onclick="openDishOptions('${id}')" class="bg-white p-3 border border-gray-200 shadow-sm rounded-xl hover:bg-blue-50 hover:border-blue-300 text-left transition-all duration-200 flex flex-col justify-between h-full hover:-translate-y-1">
                                    <p class="font-bold text-sm text-gray-800 mb-2">${escapeHtml(name)}</p>
                                    <div class="flex justify-between items-center w-full mt-auto">
                                        <p class="text-xs text-orange-600 font-black">${price.toLocaleString('vi-VN')}đ</p>
                                        <i class="fa-solid fa-circle-plus text-blue-500 text-lg opacity-50 hover:opacity-100"></i>
                                    </div>
                                </button>
                            `}).join('');
                    } else {
                        menuList.innerHTML = `<p class="col-span-2 text-gray-500 text-center py-4">Thực đơn trống.</p>`;
                    }
                }

                // Màn hình hiển thị và chọn Options/Topping
                function openDishOptions(dishId) {
                    currentSelectedDish = globalDishes.find(d => (d.id || d.Id || d._id) === dishId);
                    if (!currentSelectedDish) return;

                    let name = currentSelectedDish.name || currentSelectedDish.Name || currentSelectedDish.DishName;
                    let basePrice = currentSelectedDish.price || currentSelectedDish.BasePrice || currentSelectedDish.Price || 0;
                    let specs = currentSelectedDish.specifications || currentSelectedDish.Specifications || [];

                    let menuList = document.getElementById('menu-list');
                    menuList.className = "p-0 overflow-y-auto flex-1 flex flex-col bg-white";

                    let html = `
                            <div class="p-4 border-b bg-gray-50 flex items-center gap-3 sticky top-0 z-10 shadow-sm">
                                <button onclick="renderDishGrid()" class="w-8 h-8 flex items-center justify-center rounded-full bg-white border shadow-sm text-gray-600 hover:text-blue-600 transition">
                                    <i class="fa-solid fa-arrow-left"></i>
                                </button>
                                <div>
                                    <h4 class="font-bold text-lg text-gray-800">${escapeHtml(name)}</h4>
                                    <p class="text-orange-600 font-bold">${basePrice.toLocaleString('vi-VN')}đ</p>
                                </div>
                            </div>
                            <div class="p-4 flex flex-col gap-5 flex-1">
                        `;

                    if (specs.length > 0) {
                        specs.forEach((spec, sIdx) => {
                            let specName = spec.specName || spec.SpecName;
                            let isRequired = spec.isRequired || spec.IsRequired;
                            let maxChoices = spec.maxChoices || spec.MaxChoices || 1;
                            let options = spec.options || spec.Options || [];
                            let inputType = maxChoices === 1 ? 'radio' : 'checkbox';

                            html += `
                                    <div class="spec-group bg-white border rounded-xl p-4 shadow-sm" data-spec="${escapeHtml(specName)}" data-req="${isRequired}" data-max="${maxChoices}">
                                        <div class="flex justify-between items-end mb-3 pb-2 border-b border-dashed">
                                            <h5 class="font-bold text-gray-800">${escapeHtml(specName)} ${isRequired ? '<span class="text-red-500 ml-1">*</span>' : ''}</h5>
                                            <span class="text-[10px] font-bold text-gray-500 bg-gray-100 px-2 py-1 rounded-md uppercase tracking-wide">Chọn tối đa ${maxChoices}</span>
                                        </div>
                                        <div class="flex flex-col gap-2">
                                            ${options.map((opt, oIdx) => {
                                let oName = opt.name || opt.Name;
                                let oPrice = opt.extraPrice || opt.ExtraPrice || 0;
                                let optId = `spec_${sIdx}_opt_${oIdx}`;
                                return `
                                                    <label for="${optId}" class="flex items-center justify-between p-3 border rounded-xl cursor-pointer hover:bg-blue-50 transition-colors has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50">
                                                        <div class="flex items-center gap-3">
                                                            <input type="${inputType}" name="spec_${sIdx}" id="${optId}" value="${escapeHtml(oName)}" data-price="${oPrice}" onchange="updatePreviewPrice()" class="w-4 h-4 text-blue-600">
                                                            <span class="text-sm font-medium text-gray-700">${escapeHtml(oName)}</span>
                                                        </div>
                                                        ${oPrice > 0 ? `<span class="text-xs font-bold text-gray-500">+${oPrice.toLocaleString('vi-VN')}đ</span>` : ''}
                                                    </label>
                                                `;
                            }).join('')}
                                        </div>
                                    </div>
                                `;
                        });
                    } else {
                        html += `
                                <div class="flex flex-col items-center justify-center py-10 text-gray-400 opacity-50">
                                    <i class="fa-solid fa-mug-hot text-5xl mb-3"></i>
                                    <p class="italic text-sm">Món này không có tùy chọn (Topping).</p>
                                </div>`;
                    }

                    html += `
                            </div>
                            <div class="p-4 border-t sticky bottom-0 bg-white shadow-[0_-4px_10px_-1px_rgba(0,0,0,0.05)]">
                                <div class="flex justify-between items-center mb-3">
                                    <span class="font-bold text-gray-600">Tạm tính:</span>
                                    <span id="preview-price" class="text-xl font-black text-red-600" data-base="${basePrice}">${basePrice.toLocaleString('vi-VN')}đ</span>
                                </div>
                                <button onclick="confirmOptionsAndAdd()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3.5 rounded-xl shadow-md flex items-center justify-center gap-2 transition">
                                    <i class="fa-solid fa-cart-plus"></i> XÁC NHẬN THÊM VÀO ĐƠN
                                </button>
                            </div>
                        `;
                    menuList.innerHTML = html;
                }

                // Tính tiền Realtime
                function updatePreviewPrice() {
                    let priceEl = document.getElementById('preview-price');
                    let basePrice = parseFloat(priceEl.getAttribute('data-base'));
                    let extraPrice = 0;

                    document.querySelectorAll('#menu-list input:checked').forEach(input => {
                        extraPrice += parseFloat(input.getAttribute('data-price') || 0);
                    });

                    priceEl.innerText = (basePrice + extraPrice).toLocaleString('vi-VN') + 'đ';
                }

                // Lưu đơn hàng lên hệ thống
                async function confirmOptionsAndAdd() {
                    if (!currentSelectedDish) return;

                    let dishId = currentSelectedDish.id || currentSelectedDish.Id || currentSelectedDish._id;
                    let name = currentSelectedDish.name || currentSelectedDish.Name || currentSelectedDish.DishName;
                    let basePrice = currentSelectedDish.price || currentSelectedDish.BasePrice || currentSelectedDish.Price || 0;

                    let selectedOptions = [];
                    let isValid = true;

                    document.querySelectorAll('.spec-group').forEach(group => {
                        let specName = group.getAttribute('data-spec');
                        let isReq = group.getAttribute('data-req') === 'true';
                        let max = parseInt(group.getAttribute('data-max'));
                        let checkedInputs = group.querySelectorAll('input:checked');

                        if (isReq && checkedInputs.length === 0) {
                            alert(`Vui lòng chọn ít nhất 1 mục cho: ${specName}`);
                            isValid = false;
                        }
                        if (checkedInputs.length > max) {
                            alert(`Tùy chọn [${specName}] chỉ được chọn tối đa ${max} mục.`);
                            isValid = false;
                        }

                        checkedInputs.forEach(input => {
                            selectedOptions.push({
                                specName: specName,
                                name: input.value,
                                extraPrice: parseFloat(input.getAttribute('data-price'))
                            });
                        });
                    });

                    if (!isValid) return;

                    try {
                        let res = await fetch('/Staff/Staff/AddItemToOrder', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                orderId: currentEditingOrderId,
                                dishId: dishId,
                                dishName: name,
                                price: basePrice,
                                quantity: 1,
                                selectedOptions: selectedOptions
                            })
                        });

                        let data = await res.json();
                        if (data.success) {
                            closeMenuModal();
                            await forceRefreshGrid();
                            viewOrderDetails(currentEditingTableNumber, currentEditingOrderId);
                        } else {
                            alert("Lỗi: " + data.message);
                        }
                    } catch (e) {
                        alert("Lỗi kết nối khi thêm món!");
                    }
                }

                function closeMenuModal() {
                    document.getElementById('menu-modal').classList.add('hidden');
                }

                // -------------------------------------------------------------
                // LOGIC PHÂN TRANG & TÌM KIẾM
                // -------------------------------------------------------------
                function renderPagination() {
                    let tableItems = Array.from(document.querySelectorAll('.table-item'));
                    let input = document.getElementById('table-search-input');
                    let filterText = input.value.toLowerCase().trim();

                    let filteredItems = tableItems.filter(item => {
                        let tableName = item.getAttribute('data-table-name').toLowerCase();
                        return tableName.includes(filterText);
                    });

                    tableItems.forEach(item => item.style.display = "none");

                    let totalPages = Math.ceil(filteredItems.length / itemsPerPage);
                    if (totalPages === 0) totalPages = 1;
                    if (currentPage > totalPages) currentPage = totalPages;

                    let start = (currentPage - 1) * itemsPerPage;
                    let end = start + itemsPerPage;
                    let visibleCount = 0;

                    for (let i = start; i < end && i < filteredItems.length; i++) {
                        filteredItems[i].style.display = "";
                        visibleCount++;
                    }

                    let noMatchMsg = document.getElementById('no-tables-message');
                    if (visibleCount === 0) noMatchMsg.classList.remove('hidden');
                    else noMatchMsg.classList.add('hidden');

                    let paginationContainer = document.getElementById('pagination-controls');
                    let paginationHtml = '';

                    if (totalPages > 1) {
                        paginationHtml += `<button onclick="changePage(${currentPage - 1})" class="w-8 h-8 rounded-lg flex items-center justify-center bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition" ${currentPage === 1 ? 'disabled' : ''}><i class="fa-solid fa-chevron-left text-xs"></i></button>`;
                        for (let i = 1; i <= totalPages; i++) {
                            if (i === currentPage) {
                                paginationHtml += `<button class="w-8 h-8 rounded-lg flex items-center justify-center bg-blue-600 text-white font-bold text-sm shadow-md transition">${i}</button>`;
                            } else {
                                paginationHtml += `<button onclick="changePage(${i})" class="w-8 h-8 rounded-lg flex items-center justify-center bg-white border border-gray-200 text-gray-600 hover:bg-gray-50 hover:text-blue-600 font-medium text-sm transition">${i}</button>`;
                            }
                        }
                        paginationHtml += `<button onclick="changePage(${currentPage + 1})" class="w-8 h-8 rounded-lg flex items-center justify-center bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition" ${currentPage === totalPages ? 'disabled' : ''}><i class="fa-solid fa-chevron-right text-xs"></i></button>`;
                    }
                    paginationContainer.innerHTML = paginationHtml;
                }

                function changePage(page) {
                    currentPage = page;
                    renderPagination();
                }

                function filterTables() {
                    currentPage = 1;
                    renderPagination();
                }

                document.addEventListener("DOMContentLoaded", () => renderPagination());

                // -------------------------------------------------------------
                // LOGIC XỬ LÝ KHÁC (LOAD ORDER, LÀM MỚI BÀN, BÁO CHUÔNG...)
                // -------------------------------------------------------------
                function escapeHtml(text) {
                    return (text || "").toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
                }

                function unlockAudio() {
                    alertSound.play().then(() => {
                        alertSound.pause();
                        alertSound.currentTime = 0;
                    }).catch(e => console.log("Không thể mở khóa audio:", e));

                    let overlay = document.getElementById('audio-unlock-overlay');
                    if (overlay) {
                        overlay.classList.add('opacity-0');
                        setTimeout(() => overlay.remove(), 300);
                    }
                }

                async function acceptCall(tableNumber) {
                    let toast = document.getElementById('toast-' + tableNumber);
                    if (toast) toast.remove();
                    notifiedTables = notifiedTables.filter(t => t !== tableNumber);
                    await fetch(`/Staff/Staff/ClearServiceAlert?tableNumber=${tableNumber}`, { method: 'POST' });
                    forceRefreshGrid();
                }

                async function forceRefreshGrid() {
                    let res = await fetch(window.location.href);
                    let text = await res.text();
                    let doc = new DOMParser().parseFromString(text, 'text/html');
                    let newGrid = doc.getElementById('table-grid-container');
                    let oldGrid = document.getElementById('table-grid-container');
                    if (newGrid && oldGrid) {
                        oldGrid.innerHTML = newGrid.innerHTML;
                        renderPagination();
                    }
                }

                async function viewOrderDetails(tableNumber, orderId) {
                    acceptCall(tableNumber);
                    let panel = document.getElementById('detail-panel');

                    if (!orderId) {
                        panel.innerHTML = `
                                <div class="text-center w-full">
                                    <div class="w-20 h-20 bg-green-100 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm border border-green-200">
                                        <i class="fa-solid fa-check text-4xl"></i>
                                    </div>
                                    <h4 class="text-gray-800 font-bold text-xl mb-1">Bàn ${escapeHtml(tableNumber)} đang trống</h4>
                                    <p class="text-gray-500 text-sm mb-6">Chưa có khách ngồi hoặc chưa lên order.</p>
                                </div>
                            `;
                        return;
                    }

                    panel.innerHTML = `
                            <div class="text-center w-full">
                                <i class="fa-solid fa-circle-notch fa-spin text-4xl text-blue-500 mb-4"></i>
                                <p class="text-gray-500 font-medium text-sm">Đang tải hóa đơn bàn ${escapeHtml(tableNumber)}...</p>
                            </div>
                        `;

                    try {
                        let response = await fetch(`/Staff/Staff/GetOrderDetails?orderId=${orderId}`);
                        let order = await response.json();
                        let itemsList = order.items || order.Items || order.orderDetails || order.OrderDetails || [];
                        let itemsHtml = '';
                        let calculatedTotal = 0;

                        if (itemsList.length > 0) {
                            itemsHtml = itemsList.map((i, index) => {
                                let rawName = i.DishName || i.dishName || i.Name || i.name || 'Món ăn';
                                let price = i.FinalPrice || i.finalPrice || i.BasePrice || i.basePrice || i.Price || i.price || 0;
                                let qty = i.Quantity || i.quantity || 1;
                                calculatedTotal += (price * qty);

                                let safeName = escapeHtml(rawName);
                                let optionsHtml = '';
                                let opts = i.SelectedOptions || i.selectedOptions;

                                if (opts && Array.isArray(opts) && opts.length > 0) {
                                    let optTexts = opts.map(o => {
                                        if (typeof o === 'string' && o.startsWith('{')) { try { o = JSON.parse(o); } catch (e) { } }
                                        if (typeof o === 'object') {
                                            let optName = o.name || o.Name || o.OptionName || o.value || o.Value || '';
                                            let optPrice = o.extraPrice || o.ExtraPrice || 0;
                                            if (optPrice > 0) return `${escapeHtml(optName)} (+${optPrice.toLocaleString('vi-VN')}đ)`;
                                            return escapeHtml(optName);
                                        }
                                        return escapeHtml(o);
                                    });
                                    let cleanOpts = optTexts.filter(t => t !== '').join(' • ');
                                    if (cleanOpts) optionsHtml = `<p class="text-[11.5px] text-gray-500 font-medium mt-0.5"><i class="fa-solid fa-tags text-[10px] mr-1"></i> ${cleanOpts}</p>`;
                                }

                                let noteHtml = '';
                                let rawNote = i.Note || i.note || i.ItemNote || i.itemNote;
                                if (rawNote && rawNote.trim() !== '') {
                                    let safeNote = escapeHtml(rawNote);
                                    let noteId = `note-${index}-${Date.now()}`;
                                    noteHtml = `
                                            <div class="mt-1.5">
                                                <button onclick="document.getElementById('${noteId}').classList.toggle('hidden')" class="text-[11px] text-orange-600 font-bold bg-orange-50 hover:bg-orange-100 border border-orange-200 px-2 py-0.5 rounded transition-colors flex items-center gap-1.5">
                                                    <i class="fa-regular fa-comment-dots"></i> Xem ghi chú của khách
                                                </button>
                                                <div id="${noteId}" class="hidden mt-1 p-2 bg-yellow-50 border border-yellow-200 rounded-lg text-xs text-yellow-800 italic shadow-sm">
                                                    <span class="font-bold">Ghi chú:</span> ${safeNote}
                                                </div>
                                            </div>
                                        `;
                                }

                                return `
                                        <div class="flex justify-between items-start py-3 border-b border-gray-100 text-left">
                                            <div class="flex-1 pr-3">
                                                <p class="font-bold text-gray-800 text-base">${safeName}</p>
                                                <p class="text-xs text-gray-500 mb-0.5">SL: ${qty} x ${price.toLocaleString('vi-VN')}đ</p>
                                                ${optionsHtml}
                                                ${noteHtml}
                                            </div>
                                            <p class="font-bold text-blue-600 whitespace-nowrap pt-1 text-base">${(price * qty).toLocaleString('vi-VN')}đ</p>
                                        </div>`;
                            }).join('');
                        } else {
                            itemsHtml = '<div class="text-center text-gray-400 py-8"><i class="fa-solid fa-box-open text-3xl mb-2 block opacity-30"></i> Chưa có món nào.</div>';
                        }

                        let safeStatus = escapeHtml(order.status || order.Status);
                        let safeOrderId = escapeHtml(order.id || order.Id);

                        panel.innerHTML = `
                                <div class="w-full h-full flex flex-col text-left">
                                    <div class="flex justify-between items-center mb-4 border-b pb-2">
                                        <h3 class="font-bold text-xl text-gray-800">Bàn ${escapeHtml(tableNumber)}</h3>
                                        <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-xs font-bold uppercase">${safeStatus}</span>
                                    </div>
                                    <div class="flex-1 overflow-y-auto pr-2 mb-4 max-h-[300px]">
                                        ${itemsHtml}
                                    </div>
                        
                                    <div class="bg-gray-100 p-4 rounded-xl mt-auto">
                                        <div class="flex justify-between items-center mb-4 border-b border-gray-200 pb-3">
                                            <span class="text-gray-600 font-medium">Tổng thanh toán:</span>
                                            <span class="text-2xl font-black text-red-600">${calculatedTotal.toLocaleString('vi-VN')} đ</span>
                                        </div>

                                        <button onclick="openMenuModal('${safeOrderId}', '${escapeHtml(tableNumber)}')" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition shadow-md flex items-center justify-center gap-2 mb-3">
                                            <i class="fa-solid fa-plus-circle text-lg"></i> <span class="tracking-wide">THÊM MÓN VÀO ĐƠN</span>
                                        </button>

                                        <button onclick="payOrder('${safeOrderId}', '${escapeHtml(tableNumber)}')" class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 rounded-xl transition shadow-md flex items-center justify-center gap-2 mb-2">
                                            <i class="fa-solid fa-print text-lg"></i> <span class="tracking-wide">XÁC NHẬN THANH TOÁN & IN BILL</span>
                                        </button>
                                        <button onclick="printInvoice('${safeOrderId}')" class="w-full bg-white border border-gray-300 text-gray-600 hover:bg-gray-50 font-bold py-2 rounded-xl transition text-xs flex items-center justify-center gap-1 mt-1">
                                            <i class="fa-solid fa-redo"></i> In lại hóa đơn
                                        </button>
                                    </div>
                                </div>
                            `;
                    } catch (error) {
                        panel.innerHTML = `<p class="text-red-500 text-center">Lỗi tải dữ liệu. Vui lòng thử lại!</p>`;
                    }
                }

                async function payOrder(orderId, tableNumber) {
                    if (!confirm(`Xác nhận thanh toán cho Bàn ${tableNumber}?\nHệ thống sẽ dọn bàn và tự động tải file hóa đơn.`)) return;
                    let formData = new FormData();
                    formData.append("orderId", orderId);
                    formData.append("paymentMethod", "Tại quầy");

                    try {
                        let res = await fetch('/Staff/Staff/Checkout', { method: 'POST', body: formData });
                        let data = await res.json();
                        if (data.success) {
                            window.open(`/Staff/Staff/ExportInvoicePdf?orderId=${orderId}&paymentMethod=${encodeURIComponent("Thanh toán tại quầy")}`, '_blank');
                            processedOrders.push(orderId);
                            setTimeout(() => { window.location.reload(); }, 1200);
                        } else { alert(data.message); }
                    } catch (e) { alert("Lỗi hệ thống khi thanh toán!"); }
                }

                function printInvoice(orderId) {
                    window.open(`/Staff/Staff/ExportInvoicePdf?orderId=${orderId}&paymentMethod=In lại`, '_blank');
                }

                let isFirstLoad = true;
                setInterval(async () => {
                    try {
                        let res = await fetch(window.location.href);
                        let text = await res.text();
                        let doc = new DOMParser().parseFromString(text, 'text/html');
                        let newGrid = doc.getElementById('table-grid-container');
                        let oldGrid = document.getElementById('table-grid-container');

                        if (newGrid && oldGrid) {
                            let callingTables = newGrid.querySelectorAll('[data-needs-service="true"]');
                            callingTables.forEach(el => {
                                let tNum = el.getAttribute('data-table-number');
                                if (!notifiedTables.includes(tNum)) {
                                    notifiedTables.push(tNum);
                                    alertSound.play().catch(e => console.log("Trình duyệt chặn autoplay âm thanh", e));

                                    let toastContainer = document.getElementById('toast-container');
                                    let toastHtml = `
                                            <div id="toast-${escapeHtml(tNum)}" class="pointer-events-auto bg-white border-l-4 border-yellow-500 shadow-2xl rounded-xl p-4 flex items-center gap-4 w-80 animate-[bounce_1s_ease-in-out]">
                                                <div class="bg-yellow-100 text-yellow-600 w-12 h-12 flex items-center justify-center rounded-full flex-shrink-0 animate-pulse">
                                                    <i class="fa-solid fa-bell text-2xl"></i>
                                                </div>
                                                <div class="flex-1">
                                                    <h4 class="font-bold text-gray-800 text-lg uppercase">Bàn ${escapeHtml(tNum)}</h4>
                                                    <p class="text-sm text-gray-500">Đang gọi phục vụ!</p>
                                                </div>
                                                <button onclick="acceptCall('${escapeHtml(tNum)}')" class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-bold shadow-sm transition">
                                                    OK
                                                </button>
                                            </div>
                                        `;
                                    toastContainer.insertAdjacentHTML('beforeend', toastHtml);
                                }
                            });

                            oldGrid.innerHTML = newGrid.innerHTML;
                            renderPagination();
                        }

                        let apiRes = await fetch('/Staff/Staff/GetUnprintedPayments');
                        if (apiRes.ok) {
                            let onlineOrders = await apiRes.json();
                            if (isFirstLoad) {
                                onlineOrders.forEach(o => { if (!processedOrders.includes(o.id)) processedOrders.push(o.id); });
                                isFirstLoad = false;
                            } else {
                                onlineOrders.forEach(order => {
                                    if (!processedOrders.includes(order.id)) {
                                        processedOrders.push(order.id);
                                        let downloadLink = document.createElement('a');
                                        downloadLink.href = `/Staff/Staff/ExportInvoicePdf?orderId=${order.id}&paymentMethod=${encodeURIComponent("Thanh toán qua VNPay")}`;
                                        downloadLink.style.display = 'none';
                                        document.body.appendChild(downloadLink);
                                        downloadLink.click();
                                        document.body.removeChild(downloadLink);
                                    }
                                });
                            }
                        }
                    } catch (e) {
                        console.log("Đang chờ đồng bộ dữ liệu...");
                    }
                }, 5000); 
            </script>